@{
    ViewData["Title"] = "My Attendance";
    var summaryJson = ViewBag.SummaryJson as string ?? "null";
    var enrollmentsJson = ViewBag.EnrollmentsJson as string ?? "[]";
    var subjectId = ViewBag.SubjectId;
}

<div class="mb-4">
    <h4 class="fw-bold mb-1">✅ My Attendance</h4>
    <p class="text-muted mb-0">View your attendance records per subject</p>
</div>

<!-- Subject Selector -->
<div class="card border-0 shadow-sm mb-4">
    <div class="card-body py-3">
        <div class="row g-2 align-items-end">
            <div class="col-md-4">
                <label class="form-label small fw-semibold">Course</label>
                <select class="form-select form-select-sm" id="courseSelect">
                    <option value="">Select Course</option>
                </select>
            </div>
            <div class="col-md-4">
                <label class="form-label small fw-semibold">Subject</label>
                <select class="form-select form-select-sm" id="subjectSelect">
                    <option value="">Select Course First</option>
                </select>
            </div>
            <div class="col-md-2">
                <button class="btn btn-primary btn-sm w-100" onclick="loadAttendance()">View</button>
            </div>
        </div>
    </div>
</div>

<div id="summaryContainer"></div>

@section Scripts {
<script>
    const enrollments = @Html.Raw(enrollmentsJson);
    const initialSummary = @Html.Raw(summaryJson);

    // Render summary if already loaded
    if (initialSummary) renderSummary(initialSummary);

    // Load courses from enrollments
    const courseIds = [...new Set((enrollments || []).map(e => e.batchId))];
    const courseSelect = document.getElementById('courseSelect');

    // Fetch course data for enrolled batches
    async function initCourses() {
        const res = await fetch('/api/course?pageSize=100');
        const courses = await res.json();
        courses.forEach(c => {
            const opt = document.createElement('option');
            opt.value = c.id; opt.textContent = c.title;
            courseSelect.appendChild(opt);
        });
    }
    initCourses();

    courseSelect.addEventListener('change', async function() {
        const subSel = document.getElementById('subjectSelect');
        subSel.innerHTML = '<option value="">Loading...</option>';
        if (!this.value) { subSel.innerHTML = '<option value="">Select Course First</option>'; return; }
        const res = await fetch(`/api/subject/course/${this.value}`);
        const subs = await res.json();
        subSel.innerHTML = '<option value="">Select Subject</option>';
        subs.forEach(s => {
            const opt = document.createElement('option');
            opt.value = s.id; opt.textContent = s.name;
            subSel.appendChild(opt);
        });
    });

    function loadAttendance() {
        const subjectId = document.getElementById('subjectSelect').value;
        if (!subjectId) { alert('Please select a subject'); return; }
        window.location.href = `/AttendanceMvc/MyAttendance?subjectId=${subjectId}`;
    }

    function renderSummary(summary) {
        const pct = summary.attendancePercentage || 0;
        const color = pct >= 75 ? '#059669' : pct >= 50 ? '#d97706' : '#dc2626';
        const status = pct >= 75 ? 'Good Standing' : pct >= 50 ? 'Warning' : 'Critical';

        document.getElementById('summaryContainer').innerHTML = `
            <div class="row g-4">
                <div class="col-md-4">
                    <div class="card border-0 shadow-sm h-100">
                        <div class="card-body text-center py-4">
                            <h6 class="text-muted mb-3">Attendance Rate</h6>
                            <div style="font-size:3rem;font-weight:700;color:${color}">${pct.toFixed(1)}%</div>
                            <span class="badge mt-2" style="background:${color}">${status}</span>
                            <div class="mt-3 bg-light rounded" style="height:8px">
                                <div style="height:100%;width:${Math.min(pct,100)}%;background:${color};border-radius:4px;transition:width .5s"></div>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="col-md-8">
                    <div class="card border-0 shadow-sm h-100">
                        <div class="card-body p-4">
                            <h6 class="fw-semibold mb-3">${summary.subjectName || 'Subject'} — Attendance Summary</h6>
                            <div class="row g-3">
                                <div class="col-4 text-center">
                                    <div class="fw-bold fs-3">${summary.totalSessions || 0}</div>
                                    <div class="text-muted small">Total Sessions</div>
                                </div>
                                <div class="col-4 text-center">
                                    <div class="fw-bold fs-3 text-success">${summary.presentCount || 0}</div>
                                    <div class="text-muted small">Present</div>
                                </div>
                                <div class="col-4 text-center">
                                    <div class="fw-bold fs-3 text-danger">${summary.absentCount || 0}</div>
                                    <div class="text-muted small">Absent</div>
                                </div>
                            </div>
                            ${pct < 75 ? `<div class="alert alert-warning mt-3 mb-0 py-2 small">
                                ⚠️ Your attendance is below the required 75%. Please attend more classes.
                            </div>` : `<div class="alert alert-success mt-3 mb-0 py-2 small">
                                ✅ Great attendance! Keep it up.
                            </div>`}
                        </div>
                    </div>
                </div>
            </div>`;
    }
</script>
}
