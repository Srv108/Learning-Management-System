@{
    ViewData["Title"] = "My Attendance";
    var summaryJson = ViewBag.SummaryJson as string ?? "null";
    var enrollmentsJson = ViewBag.EnrollmentsJson as string ?? "[]";
    var subjectId = ViewBag.SubjectId;
}

<div class="page-header">
    <div>
        <div class="page-title">My Attendance</div>
        <div class="page-sub">View your attendance records per subject</div>
    </div>
</div>

<div class="lms-card" style="margin-bottom:20px">
    <div style="display:grid;grid-template-columns:1fr 1fr auto;gap:12px;align-items:flex-end">
        <div class="lms-form-group" style="margin-bottom:0">
            <label class="lms-label">Course</label>
            <select class="lms-select" id="courseSelect">
                <option value="">Select Course</option>
            </select>
        </div>
        <div class="lms-form-group" style="margin-bottom:0">
            <label class="lms-label">Subject</label>
            <select class="lms-select" id="subjectSelect">
                <option value="">Select Course First</option>
            </select>
        </div>
        <button class="btn-lms-primary" onclick="loadAttendance()">View</button>
    </div>
</div>

<div id="summaryContainer"></div>

@section Scripts {
<script>
    const enrollments = @Html.Raw(enrollmentsJson);
    const initialSummary = @Html.Raw(summaryJson);

    if (initialSummary) renderSummary(initialSummary);

    async function initCourses() {
        const res = await fetch('/api/course?pageSize=100');
        const courses = await res.json();
        const courseSelect = document.getElementById('courseSelect');
        courses.forEach(c => {
            const opt = document.createElement('option');
            opt.value = c.id; opt.textContent = c.title;
            courseSelect.appendChild(opt);
        });
    }
    initCourses();

    document.getElementById('courseSelect').addEventListener('change', async function() {
        const subSel = document.getElementById('subjectSelect');
        subSel.innerHTML = '<option value="">Loading...</option>';
        if (!this.value) { subSel.innerHTML = '<option value="">Select Course First</option>'; return; }
        const res = await fetch(`/api/subject/course/${this.value}`);
        const subs = await res.json();
        subSel.innerHTML = '<option value="">Select Subject</option>';
        subs.forEach(s => {
            const opt = document.createElement('option');
            opt.value = s.id; opt.textContent = s.name;
            subSel.appendChild(opt);
        });
    });

    function loadAttendance() {
        const subjectId = document.getElementById('subjectSelect').value;
        if (!subjectId) { alert('Please select a subject'); return; }
        window.location.href = `/AttendanceMvc/MyAttendance?subjectId=${subjectId}`;
    }

    function renderSummary(summary) {
        const pct = summary.attendancePercentage || 0;
        const isGood = pct >= 75;
        const isWarn = pct >= 50 && pct < 75;
        const color = isGood ? 'var(--green)' : isWarn ? 'var(--amber)' : 'var(--rose)';
        const softBg = isGood ? 'var(--green-soft)' : isWarn ? 'var(--amber-soft)' : 'var(--rose-soft)';
        const status = isGood ? 'Good Standing' : isWarn ? 'Warning' : 'Critical';

        document.getElementById('summaryContainer').innerHTML = `
            <div style="display:grid;grid-template-columns:200px 1fr;gap:20px">
                <div class="lms-card" style="text-align:center">
                    <div style="font-size:12px;color:var(--text-muted);text-transform:uppercase;letter-spacing:.06em;margin-bottom:12px">Attendance Rate</div>
                    <div style="font-size:48px;font-weight:800;color:${color};line-height:1;margin-bottom:8px">${pct.toFixed(1)}%</div>
                    <span class="lms-badge" style="background:${softBg};color:${color}">${status}</span>
                    <div class="lms-progress" style="margin-top:16px">
                        <div class="lms-progress-fill" style="width:${Math.min(pct,100)}%;background:${color}"></div>
                    </div>
                </div>
                <div class="lms-card">
                    <div style="font-weight:600;font-size:15px;margin-bottom:16px">${summary.subjectName || 'Subject'} — Attendance Summary</div>
                    <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:16px;margin-bottom:16px">
                        <div style="text-align:center">
                            <div style="font-size:32px;font-weight:800">${summary.totalSessions || 0}</div>
                            <div style="font-size:12.5px;color:var(--text-muted)">Total Sessions</div>
                        </div>
                        <div style="text-align:center">
                            <div style="font-size:32px;font-weight:800;color:var(--green)">${summary.presentCount || 0}</div>
                            <div style="font-size:12.5px;color:var(--text-muted)">Present</div>
                        </div>
                        <div style="text-align:center">
                            <div style="font-size:32px;font-weight:800;color:var(--rose)">${summary.absentCount || 0}</div>
                            <div style="font-size:12.5px;color:var(--text-muted)">Absent</div>
                        </div>
                    </div>
                    ${pct < 75 ? `<div class="lms-alert danger"><div class="alert-icon"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg></div><div>Your attendance is below the required 75%. Please attend more classes.</div></div>` :
                    `<div class="lms-alert success"><div class="alert-icon"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg></div><div>Great attendance! Keep it up.</div></div>`}
                </div>
            </div>`;
    }
</script>
}
