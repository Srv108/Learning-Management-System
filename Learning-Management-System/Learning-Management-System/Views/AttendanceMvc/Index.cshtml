@{
    ViewData["Title"] = "Attendance Sessions";
    var userRole = ViewBag.UserRole as string ?? "Teacher";
    var sessionsJson = ViewBag.SessionsJson as string ?? "[]";
    var coursesJson = ViewBag.CoursesJson as string ?? "[]";
    var subjectId = ViewBag.SubjectId;
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h4 class="fw-bold mb-1">✅ Attendance Sessions</h4>
        <p class="text-muted mb-0">Manage and mark student attendance</p>
    </div>
    <a asp-action="CreateSession" class="btn btn-primary">+ Create Session</a>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show">@TempData["Success"]<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show">@TempData["Error"]<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>
}

<!-- Subject Filter -->
<div class="card border-0 shadow-sm mb-4">
    <div class="card-body py-3">
        <div class="row g-2 align-items-end">
            <div class="col-md-4">
                <label class="form-label small fw-semibold">Course</label>
                <select class="form-select form-select-sm" id="courseFilter">
                    <option value="">Select Course</option>
                </select>
            </div>
            <div class="col-md-4">
                <label class="form-label small fw-semibold">Subject</label>
                <select class="form-select form-select-sm" id="subjectFilter">
                    <option value="">Select Subject</option>
                </select>
            </div>
            <div class="col-md-2">
                <button class="btn btn-primary btn-sm w-100" onclick="filterSessions()">Load Sessions</button>
            </div>
        </div>
    </div>
</div>

<div class="card border-0 shadow-sm">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Session Date</th>
                        <th>Subject</th>
                        <th>Course</th>
                        <th>Total</th>
                        <th>Present</th>
                        <th>Absent</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody id="sessionsBody">
                    <tr><td colspan="7" class="text-center py-4 text-muted">Select a subject to view sessions</td></tr>
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
<script>
    const courses = @Html.Raw(coursesJson);
    const initialSessions = @Html.Raw(sessionsJson);

    const courseFilter = document.getElementById('courseFilter');
    courses.forEach(c => {
        const opt = document.createElement('option');
        opt.value = c.id; opt.textContent = c.title;
        courseFilter.appendChild(opt);
    });

    courseFilter.addEventListener('change', async function() {
        const subjectSel = document.getElementById('subjectFilter');
        subjectSel.innerHTML = '<option value="">Loading...</option>';
        if (!this.value) { subjectSel.innerHTML = '<option value="">Select Subject</option>'; return; }
        const res = await fetch(`/api/subject/course/${this.value}`);
        const subs = await res.json();
        subjectSel.innerHTML = '<option value="">Select Subject</option>';
        subs.forEach(s => {
            const opt = document.createElement('option');
            opt.value = s.id; opt.textContent = s.name;
            subjectSel.appendChild(opt);
        });
    });

    function filterSessions() {
        const subjectId = document.getElementById('subjectFilter').value;
        if (!subjectId) { alert('Please select a subject'); return; }
        window.location.href = `/AttendanceMvc/Index?subjectId=${subjectId}`;
    }

    function renderSessions(sessions) {
        const tbody = document.getElementById('sessionsBody');
        if (!sessions || sessions.length === 0) {
            tbody.innerHTML = '<tr><td colspan="7" class="text-center py-4 text-muted">No sessions found</td></tr>';
            return;
        }
        tbody.innerHTML = sessions.map(s => `
            <tr>
                <td><strong>${new Date(s.sessionDate).toLocaleDateString()}</strong></td>
                <td>${s.subjectName || '-'}</td>
                <td>${s.courseName || '-'}</td>
                <td>${s.totalRecords || 0}</td>
                <td><span class="badge bg-success">${s.presentCount || 0}</span></td>
                <td><span class="badge bg-danger">${s.absentCount || 0}</span></td>
                <td>
                    <a href="/AttendanceMvc/MarkAttendance?sessionId=${s.id}" class="btn btn-sm btn-primary">Mark Attendance</a>
                </td>
            </tr>
        `).join('');
    }

    renderSessions(initialSessions);
</script>
}
