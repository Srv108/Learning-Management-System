@{
    ViewData["Title"] = "Attendance Sessions";
    var userRole = ViewBag.UserRole as string ?? "Teacher";
    var sessionsJson = ViewBag.SessionsJson as string ?? "[]";
    var coursesJson = ViewBag.CoursesJson as string ?? "[]";
    var subjectId = ViewBag.SubjectId;
}

<div class="page-header">
    <div>
        <div class="page-title">Attendance Sessions</div>
        <div class="page-sub">Manage and mark student attendance</div>
    </div>
    <a asp-action="CreateSession" class="btn-lms-primary">
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
        Create Session
    </a>
</div>

<div class="lms-card" style="margin-bottom:20px">
    <div style="display:grid;grid-template-columns:1fr 1fr auto;gap:12px;align-items:flex-end">
        <div class="lms-form-group" style="margin-bottom:0">
            <label class="lms-label">Course</label>
            <select class="lms-select" id="courseFilter">
                <option value="">Select Course</option>
            </select>
        </div>
        <div class="lms-form-group" style="margin-bottom:0">
            <label class="lms-label">Subject</label>
            <select class="lms-select" id="subjectFilter">
                <option value="">Select Course First</option>
            </select>
        </div>
        <button class="btn-lms-primary" onclick="filterSessions()">Load Sessions</button>
    </div>
</div>

<div class="lms-card" style="padding:0">
    <div style="overflow-x:auto">
        <table class="lms-table">
            <thead>
                <tr>
                    <th>Session Date</th>
                    <th>Subject</th>
                    <th>Course</th>
                    <th>Total</th>
                    <th>Present</th>
                    <th>Absent</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody id="sessionsBody">
                <tr><td colspan="7" style="text-align:center;padding:32px;color:var(--text-muted)">Select a subject to view sessions</td></tr>
            </tbody>
        </table>
    </div>
</div>

@section Scripts {
<script>
    const courses = @Html.Raw(coursesJson);
    const initialSessions = @Html.Raw(sessionsJson);

    const courseFilter = document.getElementById('courseFilter');
    courses.forEach(c => {
        const opt = document.createElement('option');
        opt.value = c.id; opt.textContent = c.title;
        courseFilter.appendChild(opt);
    });

    courseFilter.addEventListener('change', async function() {
        const subjectSel = document.getElementById('subjectFilter');
        subjectSel.innerHTML = '<option value="">Loading...</option>';
        if (!this.value) { subjectSel.innerHTML = '<option value="">Select Course First</option>'; return; }
        const res = await fetch(`/api/subject/course/${this.value}`);
        const subs = await res.json();
        subjectSel.innerHTML = '<option value="">Select Subject</option>';
        subs.forEach(s => {
            const opt = document.createElement('option');
            opt.value = s.id; opt.textContent = s.name;
            subjectSel.appendChild(opt);
        });
    });

    function filterSessions() {
        const subjectId = document.getElementById('subjectFilter').value;
        if (!subjectId) { alert('Please select a subject'); return; }
        window.location.href = `/AttendanceMvc/Index?subjectId=${subjectId}`;
    }

    function renderSessions(sessions) {
        const tbody = document.getElementById('sessionsBody');
        if (!sessions || sessions.length === 0) {
            tbody.innerHTML = '<tr><td colspan="7" style="text-align:center;padding:32px;color:var(--text-muted)">No sessions found</td></tr>';
            return;
        }
        tbody.innerHTML = sessions.map(s => `
            <tr>
                <td style="font-weight:600">${new Date(s.sessionDate).toLocaleDateString()}</td>
                <td>${s.subjectName || '-'}</td>
                <td style="color:var(--text-muted)">${s.courseName || '-'}</td>
                <td>${s.totalRecords || 0}</td>
                <td><span class="lms-badge" style="background:var(--green-soft);color:var(--green)">${s.presentCount || 0}</span></td>
                <td><span class="lms-badge" style="background:var(--rose-soft);color:var(--rose)">${s.absentCount || 0}</span></td>
                <td>
                    <a href="/AttendanceMvc/MarkAttendance?sessionId=${s.id}" class="btn-lms-primary btn-lms-sm">Mark Attendance</a>
                </td>
            </tr>
        `).join('');
    }

    renderSessions(initialSessions);
</script>
}
