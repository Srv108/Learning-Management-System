@{
    ViewData["Title"] = "Mark Attendance";
    var sessionId = ViewBag.SessionId;
    var sessionJson = ViewBag.SessionJson as string ?? "{}";
    var recordsJson = ViewBag.RecordsJson as string ?? "[]";
}

<nav aria-label="breadcrumb" class="mb-3">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a asp-action="Index">Attendance</a></li>
        <li class="breadcrumb-item active">Mark Attendance</li>
    </ol>
</nav>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show">@TempData["Success"]<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show">@TempData["Error"]<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>
}

<div id="sessionHeader" class="mb-4"></div>

<div class="card border-0 shadow-sm">
    <div class="card-header bg-white d-flex justify-content-between align-items-center py-3">
        <h6 class="fw-bold mb-0">Student Attendance</h6>
        <div class="d-flex gap-2">
            <button class="btn btn-sm btn-success" onclick="markAll('PRESENT')">Mark All Present</button>
            <button class="btn btn-sm btn-danger" onclick="markAll('ABSENT')">Mark All Absent</button>
        </div>
    </div>
    <div class="card-body p-0">
        <div id="attendanceList">
            <div class="text-center py-5">
                <div class="spinner-border text-primary"></div>
                <p class="text-muted mt-2">Loading students...</p>
            </div>
        </div>
    </div>
    <div class="card-footer bg-white d-flex gap-2 py-3">
        <button class="btn btn-primary px-4" onclick="saveAttendance()">Save Attendance</button>
        <a asp-action="Index" class="btn btn-outline-secondary">Back</a>
    </div>
</div>

@section Scripts {
<script>
    const sessionId = @Html.Raw(sessionId?.ToString() ?? "0");
    const session = @Html.Raw(sessionJson);
    const existingRecords = @Html.Raw(recordsJson);

    // Build status map from existing records
    const statusMap = {};
    existingRecords.forEach(r => { statusMap[r.studentId] = r.status; });

    document.getElementById('sessionHeader').innerHTML = `
        <div class="card border-0 shadow-sm">
            <div class="card-body py-3">
                <div class="d-flex gap-4 align-items-center flex-wrap">
                    <div><span class="text-muted small">Subject</span><div class="fw-semibold">${session.subjectName || '-'}</div></div>
                    <div><span class="text-muted small">Course</span><div class="fw-semibold">${session.courseName || '-'}</div></div>
                    <div><span class="text-muted small">Date</span><div class="fw-semibold">${session.sessionDate ? new Date(session.sessionDate).toLocaleDateString() : '-'}</div></div>
                    <div><span class="text-muted small">Present</span><div class="fw-semibold text-success">${session.presentCount || 0}</div></div>
                    <div><span class="text-muted small">Absent</span><div class="fw-semibold text-danger">${session.absentCount || 0}</div></div>
                </div>
            </div>
        </div>`;

    // Load enrolled students via batch (if records exist, show them)
    const attendanceList = document.getElementById('attendanceList');
    if (existingRecords && existingRecords.length > 0) {
        renderAttendanceList(existingRecords);
    } else {
        attendanceList.innerHTML = `<div class="p-4 text-center text-muted">
            <p>No students found for this session yet.</p>
            <p class="small">To add students, you need to manually enter their IDs below or they need to be enrolled in the batch.</p>
            <div class="input-group w-50 mx-auto mb-2">
                <input type="text" id="newStudentId" class="form-control" placeholder="Enter student ID" />
                <button class="btn btn-primary" onclick="addStudent()">Add</button>
            </div>
            <div id="manualList"></div>
        </div>`;
    }

    const students = {}; // studentId -> status map for saving

    function renderAttendanceList(records) {
        records.forEach(r => { students[r.studentId] = r.status || 'PRESENT'; });
        attendanceList.innerHTML = `<div class="table-responsive"><table class="table table-hover mb-0">
            <thead class="table-light"><tr><th>Student Name</th><th>Email</th><th>Status</th></tr></thead>
            <tbody>` +
            records.map(r => `
                <tr id="row-${r.studentId}">
                    <td class="fw-semibold">${r.studentName || r.studentId}</td>
                    <td class="text-muted small">${r.studentEmail || ''}</td>
                    <td>
                        <div class="btn-group btn-group-sm">
                            <button type="button" class="btn ${students[r.studentId] === 'PRESENT' ? 'btn-success' : 'btn-outline-success'}"
                                    onclick="setStatus('${r.studentId}','PRESENT',this)">Present</button>
                            <button type="button" class="btn ${students[r.studentId] === 'ABSENT' ? 'btn-danger' : 'btn-outline-danger'}"
                                    onclick="setStatus('${r.studentId}','ABSENT',this)">Absent</button>
                        </div>
                    </td>
                </tr>`).join('') +
            `</tbody></table></div>`;
    }

    function setStatus(studentId, status, btn) {
        students[studentId] = status;
        const row = document.getElementById('row-' + studentId);
        row.querySelectorAll('.btn').forEach(b => {
            b.className = b.className.replace('btn-success','btn-outline-success').replace('btn-danger','btn-outline-danger');
        });
        if (status === 'PRESENT') btn.className = btn.className.replace('btn-outline-success','btn-success');
        else btn.className = btn.className.replace('btn-outline-danger','btn-danger');
    }

    function markAll(status) {
        Object.keys(students).forEach(id => { students[id] = status; });
        document.querySelectorAll('[id^="row-"]').forEach(row => {
            const buttons = row.querySelectorAll('.btn');
            buttons.forEach(b => {
                b.className = b.className.replace('btn-success','btn-outline-success').replace('btn-danger','btn-outline-danger');
            });
            if (status === 'PRESENT') buttons[0].className = buttons[0].className.replace('btn-outline-success','btn-success');
            else buttons[1].className = buttons[1].className.replace('btn-outline-danger','btn-danger');
        });
    }

    async function saveAttendance() {
        const records = Object.entries(students).map(([studentId, status]) => ({ studentId, status }));
        if (records.length === 0) { alert('No students to mark'); return; }

        const token = document.cookie; // We'll use the form submit approach
        const form = document.createElement('form');
        form.method = 'post';
        form.action = '/AttendanceMvc/BulkMark';

        const addField = (name, value) => {
            const input = document.createElement('input');
            input.type = 'hidden';
            input.name = name;
            input.value = value;
            form.appendChild(input);
        };

        addField('sessionId', sessionId);
        addField('recordsJson', JSON.stringify(records));
        document.body.appendChild(form);
        form.submit();
    }

    function addStudent() {
        const id = document.getElementById('newStudentId').value.trim();
        if (!id) return;
        students[id] = 'PRESENT';
        const ml = document.getElementById('manualList');
        ml.innerHTML += `<div id="row-${id}" class="d-flex align-items-center gap-2 mb-1">
            <span class="fw-semibold">${id}</span>
            <div class="btn-group btn-group-sm">
                <button type="button" class="btn btn-success" onclick="setStatus('${id}','PRESENT',this)">Present</button>
                <button type="button" class="btn btn-outline-danger" onclick="setStatus('${id}','ABSENT',this)">Absent</button>
            </div>
        </div>`;
    }
</script>
}
