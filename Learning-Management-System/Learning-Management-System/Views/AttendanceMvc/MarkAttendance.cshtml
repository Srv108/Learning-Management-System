@{
    ViewData["Title"] = "Mark Attendance";
    var sessionId = ViewBag.SessionId;
    var sessionJson = ViewBag.SessionJson as string ?? "{}";
    var recordsJson = ViewBag.RecordsJson as string ?? "[]";
    ViewData["Breadcrumb"] = "<a href='/AttendanceMvc/Index' style='color:var(--text-muted);text-decoration:none'>Attendance</a> <span style='margin:0 6px;color:var(--border-strong)'>›</span> <span class='current'>Mark Attendance</span>";
}

<div class="page-header">
    <div>
        <div class="page-title">Mark Attendance</div>
        <div class="page-sub">Record student attendance for this session</div>
    </div>
</div>

<div id="sessionHeader" style="margin-bottom:20px"></div>

<div class="lms-card" style="padding:0">
    <div style="display:flex;justify-content:space-between;align-items:center;padding:16px 20px;border-bottom:1px solid var(--border)">
        <span style="font-weight:600;font-size:14px">Student Attendance</span>
        <div style="display:flex;gap:8px">
            <button class="btn-lms-ghost btn-lms-sm" onclick="markAll('PRESENT')">Mark All Present</button>
            <button class="btn-lms-danger btn-lms-sm" onclick="markAll('ABSENT')">Mark All Absent</button>
        </div>
    </div>
    <div id="attendanceList" style="padding:20px;text-align:center;color:var(--text-muted)">
        Loading students...
    </div>
    <div style="padding:16px 20px;border-top:1px solid var(--border);display:flex;gap:10px">
        <button class="btn-lms-primary" onclick="saveAttendance()">Save Attendance</button>
        <a asp-action="Index" class="btn-lms-ghost">Back</a>
    </div>
</div>

@section Scripts {
<script>
    const sessionId = @Html.Raw(sessionId?.ToString() ?? "0");
    const session = @Html.Raw(sessionJson);
    const existingRecords = @Html.Raw(recordsJson);
    const statusMap = {};
    existingRecords.forEach(r => { statusMap[r.studentId] = r.status; });

    document.getElementById('sessionHeader').innerHTML = `
        <div class="lms-card">
            <div style="display:flex;gap:32px;flex-wrap:wrap">
                <div><div style="font-size:11px;color:var(--text-muted);text-transform:uppercase;letter-spacing:.05em;margin-bottom:2px">Subject</div><div style="font-weight:600">${session.subjectName || '-'}</div></div>
                <div><div style="font-size:11px;color:var(--text-muted);text-transform:uppercase;letter-spacing:.05em;margin-bottom:2px">Course</div><div style="font-weight:600">${session.courseName || '-'}</div></div>
                <div><div style="font-size:11px;color:var(--text-muted);text-transform:uppercase;letter-spacing:.05em;margin-bottom:2px">Date</div><div style="font-weight:600">${session.sessionDate ? new Date(session.sessionDate).toLocaleDateString() : '-'}</div></div>
                <div><div style="font-size:11px;color:var(--text-muted);text-transform:uppercase;letter-spacing:.05em;margin-bottom:2px">Present</div><div style="font-weight:600;color:var(--green)">${session.presentCount || 0}</div></div>
                <div><div style="font-size:11px;color:var(--text-muted);text-transform:uppercase;letter-spacing:.05em;margin-bottom:2px">Absent</div><div style="font-weight:600;color:var(--rose)">${session.absentCount || 0}</div></div>
            </div>
        </div>`;

    const students = {};
    const attendanceList = document.getElementById('attendanceList');

    if (existingRecords && existingRecords.length > 0) {
        renderAttendanceList(existingRecords);
    } else {
        attendanceList.innerHTML = `<div style="padding:12px 0">
            <div style="margin-bottom:16px;color:var(--text-muted);font-size:13px">No students found. Add manually by student ID.</div>
            <div style="display:flex;gap:8px;max-width:400px">
                <input type="text" id="newStudentId" class="lms-input" placeholder="Enter student ID" />
                <button class="btn-lms-primary" onclick="addStudent()">Add</button>
            </div>
            <div id="manualList" style="margin-top:16px"></div>
        </div>`;
    }

    function renderAttendanceList(records) {
        records.forEach(r => { students[r.studentId] = r.status || 'PRESENT'; });
        attendanceList.innerHTML = `<div style="overflow-x:auto"><table class="lms-table">
            <thead><tr><th>Student Name</th><th>Email</th><th>Status</th></tr></thead>
            <tbody>` +
            records.map(r => `
                <tr id="row-${r.studentId}">
                    <td style="font-weight:600">${r.studentName || r.studentId}</td>
                    <td style="color:var(--text-muted);font-size:13px">${r.studentEmail || ''}</td>
                    <td>
                        <div style="display:flex;gap:6px">
                            <button type="button" class="att-btn ${students[r.studentId] === 'PRESENT' ? 'att-present' : 'att-outline'}"
                                    onclick="setStatus('${r.studentId}','PRESENT',this)">Present</button>
                            <button type="button" class="att-btn ${students[r.studentId] === 'ABSENT' ? 'att-absent' : 'att-outline-danger'}"
                                    onclick="setStatus('${r.studentId}','ABSENT',this)">Absent</button>
                        </div>
                    </td>
                </tr>`).join('') +
            `</tbody></table></div>`;
    }

    function setStatus(studentId, status, btn) {
        students[studentId] = status;
        const row = document.getElementById('row-' + studentId);
        row.querySelectorAll('.att-btn').forEach(b => {
            b.className = b.className.replace('att-present','att-outline').replace('att-absent','att-outline-danger');
        });
        if (status === 'PRESENT') btn.className = btn.className.replace('att-outline','att-present');
        else btn.className = btn.className.replace('att-outline-danger','att-absent');
    }

    function markAll(status) {
        Object.keys(students).forEach(id => { students[id] = status; });
        document.querySelectorAll('[id^="row-"]').forEach(row => {
            const buttons = row.querySelectorAll('.att-btn');
            buttons[0].className = status === 'PRESENT'
                ? buttons[0].className.replace('att-outline','att-present')
                : buttons[0].className.replace('att-present','att-outline');
            buttons[1].className = status === 'ABSENT'
                ? buttons[1].className.replace('att-outline-danger','att-absent')
                : buttons[1].className.replace('att-absent','att-outline-danger');
        });
    }

    async function saveAttendance() {
        const records = Object.entries(students).map(([studentId, status]) => ({ studentId, status }));
        if (records.length === 0) { alert('No students to mark'); return; }
        const form = document.createElement('form');
        form.method = 'post';
        form.action = '/AttendanceMvc/BulkMark';
        const addField = (name, value) => {
            const input = document.createElement('input');
            input.type = 'hidden'; input.name = name; input.value = value;
            form.appendChild(input);
        };
        addField('sessionId', sessionId);
        addField('recordsJson', JSON.stringify(records));
        document.body.appendChild(form);
        form.submit();
    }

    function addStudent() {
        const id = document.getElementById('newStudentId').value.trim();
        if (!id) return;
        students[id] = 'PRESENT';
        const ml = document.getElementById('manualList');
        ml.innerHTML += `<div id="row-${id}" style="display:flex;align-items:center;gap:10px;padding:8px 0;border-bottom:1px solid var(--border)">
            <span style="font-weight:600;min-width:120px">${id}</span>
            <div style="display:flex;gap:6px">
                <button type="button" class="att-btn att-present" onclick="setStatus('${id}','PRESENT',this)">Present</button>
                <button type="button" class="att-btn att-outline-danger" onclick="setStatus('${id}','ABSENT',this)">Absent</button>
            </div>
        </div>`;
        document.getElementById('newStudentId').value = '';
    }
</script>
<style>
.att-btn { padding:4px 14px;border-radius:6px;border:none;cursor:pointer;font-size:12.5px;font-weight:500;transition:all .15s }
.att-present { background:var(--green-soft);color:var(--green) }
.att-absent { background:var(--rose-soft);color:var(--rose) }
.att-outline { background:var(--bg-muted);color:var(--text-muted) }
.att-outline-danger { background:var(--bg-muted);color:var(--text-muted) }
.att-btn:hover { opacity:.85 }
</style>
}
