@{
    ViewData["Title"] = "Manage Subject Teachers";
    var teachersJson = ViewBag.TeachersJson as string ?? "[]";
    var subjectJson = ViewBag.SubjectJson as string ?? "{}";
    var allTeachersJson = ViewBag.AllTeachersJson as string ?? "[]";
    var subjectId = ViewBag.SubjectId;
    var userRole = ViewBag.UserRole as string ?? "";
    ViewData["Breadcrumb"] = "<a href='/CourseMvc/Index' style='color:var(--text-muted);text-decoration:none'>Courses</a> <span style='margin:0 6px;color:var(--border-strong)'>›</span> <span id='breadCourseLink'>Course</span> <span style='margin:0 6px;color:var(--border-strong)'>›</span> <span class='current'>Subject Teachers</span>";
}

<div class="page-header">
    <div>
        <div class="page-title">Subject Teacher Assignment</div>
        <div class="page-sub" id="subjectTitle">Loading subject...</div>
    </div>
    <a asp-controller="CourseMvc" asp-action="Index" class="btn-lms-ghost">
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="15 18 9 12 15 6"/></svg>
        Back to Courses
    </a>
</div>

<div style="display:grid;grid-template-columns:1fr 300px;gap:20px">
    <div class="lms-card" style="padding:0">
        <div style="display:flex;justify-content:space-between;align-items:center;padding:16px 20px;border-bottom:1px solid var(--border)">
            <span style="font-weight:600;font-size:14px">Assigned Teachers</span>
            <span class="lms-badge" style="background:var(--sky-soft);color:var(--sky)" id="teacherCount">0</span>
        </div>
        <div id="teacherList" style="padding:20px;text-align:center;color:var(--text-muted)">Loading...</div>
    </div>

    <div style="display:flex;flex-direction:column;gap:16px">
        <div class="lms-card">
            <div style="font-weight:600;font-size:14px;margin-bottom:16px">Assign Teacher</div>
            <form method="post" asp-action="Assign" style="display:flex;flex-direction:column;gap:14px">
                <input type="hidden" name="subjectId" value="@subjectId" />
                <div class="lms-form-group">
                    <label class="lms-label">Select Teacher</label>
                    <select name="teacherId" class="lms-select" id="teacherSelect" required>
                        <option value="">Choose a teacher...</option>
                    </select>
                </div>
                <button type="submit" class="btn-lms-primary" style="width:100%">Assign Teacher</button>
            </form>
        </div>

        <div class="lms-card" id="subjectInfoCard">
            <div style="font-weight:600;font-size:14px;margin-bottom:12px">Subject Info</div>
            <div id="subjectInfo" style="font-size:13px;color:var(--text-muted)">Loading...</div>
        </div>
    </div>
</div>

@section Scripts {
<script>
    const teachers = @Html.Raw(teachersJson);
    const subject = @Html.Raw(subjectJson);
    const allTeachers = @Html.Raw(allTeachersJson);
    const subjectId = @Html.Raw(subjectId?.ToString() ?? "0");

    if (subject && subject.name) {
        document.getElementById('subjectTitle').textContent = subject.name + (subject.courseName ? ' — ' + subject.courseName : '');
        document.getElementById('subjectInfo').innerHTML = `
            <div style="margin-bottom:4px"><span style="color:var(--text-muted)">Subject:</span> <strong>${subject.name}</strong></div>
            <div style="margin-bottom:8px"><span style="color:var(--text-muted)">Course:</span> <strong>${subject.courseName || '-'}</strong></div>
            <div>${subject.description || 'No description.'}</div>
        `;
        if (subject.courseId) {
            document.getElementById('breadCourseLink').innerHTML = `<a href="/CourseMvc/Details/${subject.courseId}" style="color:var(--text-muted);text-decoration:none">${subject.courseName || 'Course'}</a>`;
        }
    }

    const sel = document.getElementById('teacherSelect');
    const assignedIds = new Set((teachers || []).map(t => t.teacherId));
    allTeachers.forEach(t => {
        const opt = document.createElement('option');
        opt.value = t.id;
        opt.textContent = t.name + ' (' + t.email + ')' + (assignedIds.has(t.id) ? ' ✓' : '');
        if (assignedIds.has(t.id)) opt.disabled = true;
        sel.appendChild(opt);
    });

    const listEl = document.getElementById('teacherList');
    document.getElementById('teacherCount').textContent = (teachers || []).length;

    if (!teachers || teachers.length === 0) {
        listEl.innerHTML = `<div style="padding:32px 0">
            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="var(--text-faint)" stroke-width="1.2" style="margin-bottom:8px"><circle cx="9" cy="7" r="4"/><path d="M3 21v-2a4 4 0 0 1 4-4h4a4 4 0 0 1 4 4v2"/><line x1="19" y1="8" x2="19" y2="14"/><line x1="22" y1="11" x2="16" y2="11"/></svg>
            <div style="font-size:13px">No teachers assigned yet.</div>
        </div>`;
    } else {
        listEl.innerHTML = `<div style="overflow-x:auto"><table class="lms-table">
            <thead><tr><th>Teacher</th><th>Email</th><th>Assigned</th><th>Action</th></tr></thead>
            <tbody>
                ${teachers.map(t => `
                    <tr>
                        <td style="font-weight:600">${t.teacherName || '-'}</td>
                        <td style="font-size:12.5px;color:var(--text-muted)">${t.teacherEmail || ''}</td>
                        <td style="font-size:12.5px;color:var(--text-muted)">${t.assignedAt ? new Date(t.assignedAt).toLocaleDateString() : '-'}</td>
                        <td>
                            <form method="post" action="/SubjectTeacherMvc/Remove" onsubmit="return confirm('Remove this teacher?')">
                                <input type="hidden" name="id" value="${t.id}" />
                                <input type="hidden" name="subjectId" value="${subjectId}" />
                                <button class="btn-lms-danger btn-lms-sm">Remove</button>
                            </form>
                        </td>
                    </tr>`).join('')}
            </tbody>
        </table></div>`;
    }
</script>
}
