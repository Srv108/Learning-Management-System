@{
    ViewData["Title"] = "My Grades";
    var coursesJson = ViewBag.CoursesJson as string ?? "[]";
    var assignmentsJson = ViewBag.AssignmentsJson as string ?? "[]";
    var subjectId = ViewBag.SubjectId;
}

<div class="mb-4">
    <h4 class="fw-bold mb-1">🏆 My Grades</h4>
    <p class="text-muted mb-0">View your assignment grades and feedback</p>
</div>

<!-- Filter -->
<div class="card border-0 shadow-sm mb-4">
    <div class="card-body py-3">
        <div class="row g-2 align-items-end">
            <div class="col-md-4">
                <label class="form-label small fw-semibold">Course</label>
                <select class="form-select form-select-sm" id="courseFilter"><option value="">Select Course</option></select>
            </div>
            <div class="col-md-4">
                <label class="form-label small fw-semibold">Subject</label>
                <select class="form-select form-select-sm" id="subjectFilter"><option value="">Select Course First</option></select>
            </div>
            <div class="col-md-2">
                <button class="btn btn-primary btn-sm w-100" onclick="filter()">Load</button>
            </div>
        </div>
    </div>
</div>

<div id="gradesContainer"></div>

@section Scripts {
<script>
    const courses = @Html.Raw(coursesJson);
    const assignments = @Html.Raw(assignmentsJson);

    const courseFilter = document.getElementById('courseFilter');
    courses.forEach(c => {
        const opt = document.createElement('option');
        opt.value = c.id; opt.textContent = c.title;
        courseFilter.appendChild(opt);
    });

    courseFilter.addEventListener('change', async function() {
        const sel = document.getElementById('subjectFilter');
        sel.innerHTML = '<option value="">Loading...</option>';
        if (!this.value) { sel.innerHTML = '<option value="">Select Course First</option>'; return; }
        const res = await fetch(`/api/subject/course/${this.value}`);
        const subs = await res.json();
        sel.innerHTML = '<option value="">Select Subject</option>';
        subs.forEach(s => {
            const opt = document.createElement('option');
            opt.value = s.id; opt.textContent = s.name;
            sel.appendChild(opt);
        });
    });

    function filter() {
        const subId = document.getElementById('subjectFilter').value;
        if (!subId) { alert('Please select a subject'); return; }
        window.location.href = `/AssignmentMvc/MyGrades?subjectId=${subId}`;
    }

    const container = document.getElementById('gradesContainer');
    if (assignments && assignments.length > 0) {
        container.innerHTML = `<div class="card border-0 shadow-sm">
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover mb-0">
                        <thead class="table-light">
                            <tr><th>Assignment</th><th>Due Date</th><th>Max Score</th><th>Your Score</th><th>Status</th></tr>
                        </thead>
                        <tbody>
                            ${assignments.map(a => `
                            <tr>
                                <td class="fw-semibold">${a.title}</td>
                                <td class="small text-muted">${new Date(a.dueDate).toLocaleDateString()}</td>
                                <td>${a.maxScore}</td>
                                <td><span class="badge bg-secondary">Check submissions</span></td>
                                <td><a href="/AssignmentMvc/MyAssignments" class="btn btn-sm btn-outline-primary">Submit</a></td>
                            </tr>`).join('')}
                        </tbody>
                    </table>
                </div>
            </div>
        </div>`;
    } else {
        container.innerHTML = `<div class="card border-0 shadow-sm"><div class="card-body text-center py-5">
            <div class="fs-1 mb-2">🏆</div><h5 class="text-muted">No grades yet</h5>
            <p class="text-muted small">Select a subject to view your grades</p>
        </div></div>`;
    }
</script>
}
