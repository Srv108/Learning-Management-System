@{
    ViewData["Title"] = "My Grades";
    var coursesJson = ViewBag.CoursesJson as string ?? "[]";
    var assignmentsJson = ViewBag.AssignmentsJson as string ?? "[]";
    var subjectId = ViewBag.SubjectId;
}

<div class="page-header">
    <div>
        <div class="page-title">My Grades</div>
        <div class="page-sub">View your assignment grades and feedback</div>
    </div>
</div>

<div class="lms-card" style="margin-bottom:20px">
    <div style="display:grid;grid-template-columns:1fr 1fr auto;gap:12px;align-items:flex-end">
        <div class="lms-form-group" style="margin-bottom:0">
            <label class="lms-label">Course</label>
            <select class="lms-select" id="courseFilter"><option value="">Select Course</option></select>
        </div>
        <div class="lms-form-group" style="margin-bottom:0">
            <label class="lms-label">Subject</label>
            <select class="lms-select" id="subjectFilter"><option value="">Select Course First</option></select>
        </div>
        <button class="btn-lms-primary" onclick="filter()">Load</button>
    </div>
</div>

<div id="gradesContainer"></div>

@section Scripts {
<script>
    const courses = @Html.Raw(coursesJson);
    const assignments = @Html.Raw(assignmentsJson);

    const courseFilter = document.getElementById('courseFilter');
    courses.forEach(c => {
        const opt = document.createElement('option');
        opt.value = c.id; opt.textContent = c.title;
        courseFilter.appendChild(opt);
    });

    courseFilter.addEventListener('change', async function() {
        const sel = document.getElementById('subjectFilter');
        sel.innerHTML = '<option value="">Loading...</option>';
        if (!this.value) { sel.innerHTML = '<option value="">Select Course First</option>'; return; }
        const res = await fetch(`/api/subject/course/${this.value}`);
        const subs = await res.json();
        sel.innerHTML = '<option value="">Select Subject</option>';
        subs.forEach(s => {
            const opt = document.createElement('option');
            opt.value = s.id; opt.textContent = s.name;
            sel.appendChild(opt);
        });
    });

    function filter() {
        const subId = document.getElementById('subjectFilter').value;
        if (!subId) { alert('Please select a subject'); return; }
        window.location.href = `/AssignmentMvc/MyGrades?subjectId=${subId}`;
    }

    const container = document.getElementById('gradesContainer');
    if (assignments && assignments.length > 0) {
        container.innerHTML = `<div class="lms-card" style="padding:0">
            <div style="overflow-x:auto">
                <table class="lms-table">
                    <thead>
                        <tr><th>Assignment</th><th>Due Date</th><th>Max Score</th><th>Status</th><th>Action</th></tr>
                    </thead>
                    <tbody>
                        ${assignments.map(a => `
                        <tr>
                            <td style="font-weight:600">${a.title}</td>
                            <td style="font-size:12.5px;color:var(--text-muted)">${new Date(a.dueDate).toLocaleDateString()}</td>
                            <td>${a.maxScore}</td>
                            <td><span class="lms-badge" style="background:var(--bg-muted);color:var(--text-muted)">Check submissions</span></td>
                            <td><a href="/AssignmentMvc/MyAssignments" class="btn-lms-ghost btn-lms-sm">Submit</a></td>
                        </tr>`).join('')}
                    </tbody>
                </table>
            </div>
        </div>`;
    } else {
        container.innerHTML = `<div class="lms-card" style="text-align:center;padding:48px">
            <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="var(--text-faint)" stroke-width="1.2" style="margin-bottom:12px"><circle cx="12" cy="8" r="7"/><polyline points="8.21 13.89 7 23 12 20 17 23 15.79 13.88"/></svg>
            <div style="font-weight:600;color:var(--text-dim);margin-bottom:4px">No grades yet</div>
            <div style="font-size:13px;color:var(--text-muted)">Select a subject to view your grades</div>
        </div>`;
    }
</script>
}
