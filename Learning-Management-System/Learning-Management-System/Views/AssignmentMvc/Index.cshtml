@model List<AssignmentDto>

@{
    ViewData["Title"] = "Assignments";
}

<div class="container mt-4">
    <div class="row mb-4">
        <div class="col-md-8">
            <h2>Assignments</h2>
            <p class="text-muted">Subject ID: @ViewBag.SubjectId</p>
        </div>
        <div class="col-md-4 text-end">
            <a href="@Url.Action("Create", new { subjectId = ViewBag.SubjectId })" class="btn btn-primary">
                <i class="bi bi-plus-circle"></i> New Assignment
            </a>
        </div>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            @TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @if (Model == null || Model.Count == 0)
    {
        <div class="alert alert-info">
            No assignments found for this subject.
        </div>
    }
    else
    {
        <div class="row">
            @foreach (var assignment in Model)
            {
                var isOverdue = assignment.DueDate < DateTime.UtcNow;
                var daysUntilDue = (assignment.DueDate - DateTime.UtcNow).TotalDays;
                
                <div class="col-md-6 mb-3">
                    <div class="card @(isOverdue ? "border-danger" : "border-primary")">
                        <div class="card-header @(isOverdue ? "bg-danger text-white" : "bg-primary text-white")">
                            <h5 class="mb-0">@assignment.Title</h5>
                        </div>
                        <div class="card-body">
                            <p class="card-text">@assignment.Description</p>
                            
                            <div class="row mb-3">
                                <div class="col-md-6">
                                    <small class="text-muted">Max Score</small>
                                    <p>@assignment.MaxScore points</p>
                                </div>
                                <div class="col-md-6">
                                    <small class="text-muted">Due Date</small>
                                    <p>
                                        @assignment.DueDate.ToString("MMM dd, yyyy HH:mm")
                                        @if (isOverdue)
                                        {
                                            <span class="badge bg-danger">Overdue</span>
                                        }
                                        else if (daysUntilDue < 2)
                                        {
                                            <span class="badge bg-warning">Due Soon</span>
                                        }
                                    </p>
                                </div>
                            </div>

                            <small class="text-muted">Created by: @assignment.CreatedByName</small>
                        </div>
                        <div class="card-footer">
                            <a href="@Url.Action("Details", new { id = assignment.Id })" class="btn btn-sm btn-info">
                                <i class="bi bi-eye"></i> View Details
                            </a>
                            <a href="@Url.Action("Edit", new { id = assignment.Id })" class="btn btn-sm btn-warning">
                                <i class="bi bi-pencil"></i> Edit
                            </a>
                            <form method="post" action="@Url.Action("Delete")" style="display:inline;">
                                <input type="hidden" name="id" value="@assignment.Id" />
                                <input type="hidden" name="subjectId" value="@ViewBag.SubjectId" />
                                <button type="submit" class="btn btn-sm btn-danger" onclick="return confirm('Are you sure?')">
                                    <i class="bi bi-trash"></i> Delete
                                </button>
                            </form>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>

<style>
    .card {
        transition: transform 0.2s;
    }
    .card:hover {
        transform: translateY(-5px);
        box-shadow: 0 4px 15px rgba(0, 0, 0, 0.1);
    }
</style>
