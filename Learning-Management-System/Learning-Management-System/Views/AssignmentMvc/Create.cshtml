@{
    ViewData["Title"] = "Create Assignment";
    var coursesJson = ViewBag.CoursesJson as string ?? "[]";
    ViewData["Breadcrumb"] = "<a href='/AssignmentMvc/Index' style='color:var(--text-muted);text-decoration:none'>Assignments</a> <span style='margin:0 6px;color:var(--border-strong)'>›</span> <span class='current'>Create</span>";
}

<div class="page-header">
    <div>
        <div class="page-title">Create Assignment</div>
        <div class="page-sub">Add a new assignment for a subject</div>
    </div>
    <a asp-action="Index" class="btn-lms-ghost">
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="15 18 9 12 15 6"/></svg>
        Back to Assignments
    </a>
</div>

<div style="max-width:560px">
    <div class="lms-card">
        <form method="post" asp-action="Create" style="display:flex;flex-direction:column;gap:18px">
            <div class="lms-form-group">
                <label class="lms-label">Course <span style="color:var(--rose)">*</span></label>
                <select class="lms-select" id="courseSelect" required>
                    <option value="">Select Course</option>
                </select>
            </div>
            <div class="lms-form-group">
                <label class="lms-label">Subject <span style="color:var(--rose)">*</span></label>
                <select class="lms-select" name="subjectId" id="subjectSelect" required disabled>
                    <option value="">Select Course First</option>
                </select>
            </div>
            <div class="lms-form-group">
                <label class="lms-label">Assignment Title <span style="color:var(--rose)">*</span></label>
                <input type="text" name="title" class="lms-input" required placeholder="e.g., Lab Assignment 1" />
            </div>
            <div class="lms-form-group">
                <label class="lms-label">Description</label>
                <textarea name="description" class="lms-textarea" rows="3" placeholder="Assignment instructions..."></textarea>
            </div>
            <div style="display:grid;grid-template-columns:1fr 1fr;gap:16px">
                <div class="lms-form-group">
                    <label class="lms-label">Max Score <span style="color:var(--rose)">*</span></label>
                    <input type="number" name="maxScore" class="lms-input" required min="1" max="1000" value="100" />
                </div>
                <div class="lms-form-group">
                    <label class="lms-label">Due Date <span style="color:var(--rose)">*</span></label>
                    <input type="datetime-local" name="dueDate" class="lms-input" required id="dueDate" />
                </div>
            </div>
            <div style="display:flex;gap:10px;padding-top:4px">
                <button type="submit" class="btn-lms-primary">Create Assignment</button>
                <a asp-action="Index" class="btn-lms-ghost">Cancel</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
<script>
    const courses = @Html.Raw(coursesJson);
    const csel = document.getElementById('courseSelect');
    const ssel = document.getElementById('subjectSelect');

    courses.forEach(c => {
        const opt = document.createElement('option');
        opt.value = c.id; opt.textContent = c.title;
        csel.appendChild(opt);
    });

    csel.addEventListener('change', async function() {
        ssel.innerHTML = '<option value="">Loading...</option>';
        ssel.disabled = true;
        if (!this.value) { ssel.innerHTML = '<option value="">Select Course First</option>'; return; }
        const res = await fetch(`/api/subject/course/${this.value}`);
        const subs = await res.json();
        ssel.innerHTML = '<option value="">Select Subject</option>';
        subs.forEach(s => {
            const opt = document.createElement('option');
            opt.value = s.id; opt.textContent = s.name;
            ssel.appendChild(opt);
        });
        ssel.disabled = false;
    });

    // Default due date: 7 days from now
    const d = new Date();
    d.setDate(d.getDate() + 7);
    document.getElementById('dueDate').value = d.toISOString().slice(0, 16);
</script>
}
