@{
    ViewData["Title"] = "Grade Submissions";
    var submissionsJson = ViewBag.SubmissionsJson as string ?? "[]";
    var assignmentJson = ViewBag.AssignmentJson as string ?? "{}";
    var assignmentId = ViewBag.AssignmentId;
    ViewData["Breadcrumb"] = "<a href='/AssignmentMvc/Index' style='color:var(--text-muted);text-decoration:none'>Assignments</a> <span style='margin:0 6px;color:var(--border-strong)'>›</span> <span class='current'>Submissions</span>";
}

<div class="page-header">
    <div>
        <div class="page-title">Grade Submissions</div>
        <div class="page-sub">Review and grade student submissions</div>
    </div>
    <a asp-action="Index" class="btn-lms-ghost">
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="15 18 9 12 15 6"/></svg>
        Back to Assignments
    </a>
</div>

<div id="assignmentHeader" style="margin-bottom:20px"></div>

<div class="lms-card" style="padding:0">
    <div style="padding:16px 20px;border-bottom:1px solid var(--border);font-weight:600;font-size:14px">Student Submissions</div>
    <div style="overflow-x:auto">
        <table class="lms-table">
            <thead>
                <tr>
                    <th>Student</th>
                    <th>Submitted At</th>
                    <th>Status</th>
                    <th>File</th>
                    <th>Action</th>
                </tr>
            </thead>
            <tbody id="submissionsBody"></tbody>
        </table>
    </div>
</div>

<!-- Grade Modal -->
<div id="gradeModal" style="display:none;position:fixed;inset:0;background:rgba(0,0,0,0.5);z-index:1000;align-items:center;justify-content:center">
    <div class="lms-card" style="width:480px;max-width:90vw">
        <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:20px">
            <span style="font-weight:600;font-size:16px">Grade Submission</span>
            <button onclick="closeGradeModal()" style="background:none;border:none;cursor:pointer;color:var(--text-muted);font-size:20px;line-height:1">&times;</button>
        </div>
        <form method="post" asp-action="Grade" style="display:flex;flex-direction:column;gap:14px">
            <input type="hidden" name="submissionId" id="gradeSubmissionId" />
            <input type="hidden" name="assignmentId" value="@assignmentId" />
            <div class="lms-form-group">
                <label class="lms-label">Student</label>
                <input type="text" id="gradeStudentName" class="lms-input" disabled />
            </div>
            <div class="lms-form-group">
                <label class="lms-label">Score <span style="color:var(--rose)">*</span></label>
                <input type="number" name="score" id="gradeScore" class="lms-input" required min="0" step="0.5" />
                <span id="maxScoreHint" style="font-size:12px;color:var(--text-muted);margin-top:4px;display:block"></span>
            </div>
            <div class="lms-form-group">
                <label class="lms-label">Feedback</label>
                <textarea name="feedback" id="gradeFeedback" class="lms-textarea" rows="3" placeholder="Optional feedback to student..."></textarea>
            </div>
            <div style="display:flex;gap:10px;justify-content:flex-end">
                <button type="button" class="btn-lms-ghost" onclick="closeGradeModal()">Cancel</button>
                <button type="submit" class="btn-lms-primary">Save Grade</button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
<script>
    const assignment = @Html.Raw(assignmentJson);
    const submissions = @Html.Raw(submissionsJson);
    const assignmentId = @Html.Raw(assignmentId?.ToString() ?? "0");

    document.getElementById('assignmentHeader').innerHTML = assignment.id ? `
        <div class="lms-card">
            <div style="display:flex;gap:32px;flex-wrap:wrap">
                <div><div style="font-size:11px;color:var(--text-muted);text-transform:uppercase;letter-spacing:.05em;margin-bottom:2px">Assignment</div><div style="font-weight:600">${assignment.title}</div></div>
                <div><div style="font-size:11px;color:var(--text-muted);text-transform:uppercase;letter-spacing:.05em;margin-bottom:2px">Subject</div><div style="font-weight:600">${assignment.subjectName || '-'}</div></div>
                <div><div style="font-size:11px;color:var(--text-muted);text-transform:uppercase;letter-spacing:.05em;margin-bottom:2px">Max Score</div><div style="font-weight:600">${assignment.maxScore}</div></div>
                <div><div style="font-size:11px;color:var(--text-muted);text-transform:uppercase;letter-spacing:.05em;margin-bottom:2px">Due Date</div><div style="font-weight:600">${new Date(assignment.dueDate).toLocaleDateString()}</div></div>
                <div><div style="font-size:11px;color:var(--text-muted);text-transform:uppercase;letter-spacing:.05em;margin-bottom:2px">Submissions</div><div style="font-weight:600">${submissions.length}</div></div>
            </div>
        </div>` : '';

    const statusStyle = s => {
        if (s === 'SUBMITTED') return 'background:var(--green-soft);color:var(--green)';
        if (s === 'LATE') return 'background:var(--amber-soft);color:var(--amber)';
        return 'background:var(--bg-muted);color:var(--text-muted)';
    };

    const tbody = document.getElementById('submissionsBody');
    if (!submissions || submissions.length === 0) {
        tbody.innerHTML = '<tr><td colspan="5" style="text-align:center;padding:32px;color:var(--text-muted)">No submissions yet</td></tr>';
    } else {
        tbody.innerHTML = submissions.map(s => `
            <tr>
                <td>
                    <div style="font-weight:600">${s.studentName || '-'}</div>
                    <div style="font-size:12.5px;color:var(--text-muted)">${s.studentEmail || ''}</div>
                </td>
                <td style="font-size:12.5px;color:var(--text-muted)">${s.submittedAt ? new Date(s.submittedAt).toLocaleString() : '-'}</td>
                <td><span class="lms-badge" style="${statusStyle(s.status)}">${s.status}</span></td>
                <td>${s.fileUrl ? `<a href="${s.fileUrl}" target="_blank" class="btn-lms-ghost btn-lms-sm">View File</a>` : '<span style="color:var(--text-faint);font-size:12.5px">No file</span>'}</td>
                <td>
                    <button class="btn-lms-primary btn-lms-sm"
                            onclick="openGradeModal(${s.id}, '${(s.studentName||'').replace(/'/g,"\\'")}')">
                        Grade
                    </button>
                </td>
            </tr>
        `).join('');
    }

    function openGradeModal(submissionId, studentName) {
        document.getElementById('gradeSubmissionId').value = submissionId;
        document.getElementById('gradeStudentName').value = studentName;
        document.getElementById('gradeScore').max = assignment.maxScore || 100;
        document.getElementById('maxScoreHint').textContent = `Max score: ${assignment.maxScore || 100}`;
        document.getElementById('gradeModal').style.display = 'flex';
    }

    function closeGradeModal() {
        document.getElementById('gradeModal').style.display = 'none';
    }
</script>
}
