@{
    ViewData["Title"] = "Grade Submissions";
    var submissionsJson = ViewBag.SubmissionsJson as string ?? "[]";
    var assignmentJson = ViewBag.AssignmentJson as string ?? "{}";
    var assignmentId = ViewBag.AssignmentId;
}

<nav aria-label="breadcrumb" class="mb-3">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a asp-action="Index">Assignments</a></li>
        <li class="breadcrumb-item active">Submissions</li>
    </ol>
</nav>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show">@TempData["Success"]<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show">@TempData["Error"]<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>
}

<div id="assignmentHeader" class="mb-4"></div>

<div class="card border-0 shadow-sm">
    <div class="card-header bg-white fw-bold py-3">Student Submissions</div>
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Student</th>
                        <th>Submitted At</th>
                        <th>Status</th>
                        <th>File</th>
                        <th>Grade Action</th>
                    </tr>
                </thead>
                <tbody id="submissionsBody"></tbody>
            </table>
        </div>
    </div>
</div>

<!-- Grade Modal -->
<div class="modal fade" id="gradeModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content border-0 shadow">
            <div class="modal-header">
                <h5 class="modal-title">Grade Submission</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <form method="post" asp-action="Grade">
                <div class="modal-body">
                    <input type="hidden" name="submissionId" id="gradeSubmissionId" />
                    <input type="hidden" name="assignmentId" value="@assignmentId" />
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Student</label>
                        <input type="text" id="gradeStudentName" class="form-control" disabled />
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Score *</label>
                        <input type="number" name="score" id="gradeScore" class="form-control" required min="0" step="0.5" />
                        <div class="form-text" id="maxScoreHint"></div>
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Feedback</label>
                        <textarea name="feedback" id="gradeFeedback" class="form-control" rows="3" placeholder="Optional feedback to student..."></textarea>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary">Save Grade</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
<script>
    const assignment = @Html.Raw(assignmentJson);
    const submissions = @Html.Raw(submissionsJson);
    const assignmentId = @Html.Raw(assignmentId?.ToString() ?? "0");

    document.getElementById('assignmentHeader').innerHTML = assignment.id ? `
        <div class="card border-0 shadow-sm">
            <div class="card-body py-3">
                <div class="d-flex gap-4 flex-wrap align-items-center">
                    <div><span class="text-muted small">Assignment</span><div class="fw-semibold">${assignment.title}</div></div>
                    <div><span class="text-muted small">Subject</span><div class="fw-semibold">${assignment.subjectName || '-'}</div></div>
                    <div><span class="text-muted small">Max Score</span><div class="fw-semibold">${assignment.maxScore}</div></div>
                    <div><span class="text-muted small">Due Date</span><div class="fw-semibold">${new Date(assignment.dueDate).toLocaleDateString()}</div></div>
                    <div><span class="text-muted small">Submissions</span><div class="fw-semibold">${submissions.length}</div></div>
                </div>
            </div>
        </div>` : '';

    const tbody = document.getElementById('submissionsBody');
    if (!submissions || submissions.length === 0) {
        tbody.innerHTML = '<tr><td colspan="5" class="text-center py-4 text-muted">No submissions yet</td></tr>';
    } else {
        tbody.innerHTML = submissions.map(s => `
            <tr>
                <td>
                    <div class="fw-semibold">${s.studentName || '-'}</div>
                    <div class="text-muted small">${s.studentEmail || ''}</div>
                </td>
                <td class="small text-muted">${s.submittedAt ? new Date(s.submittedAt).toLocaleString() : '-'}</td>
                <td><span class="badge ${s.status === 'SUBMITTED' ? 'bg-success' : s.status === 'LATE' ? 'bg-warning' : 'bg-secondary'}">${s.status}</span></td>
                <td>${s.fileUrl ? `<a href="${s.fileUrl}" target="_blank" class="btn btn-sm btn-outline-secondary">View File</a>` : '<span class="text-muted small">No file</span>'}</td>
                <td>
                    <button class="btn btn-sm btn-primary"
                            onclick="openGradeModal(${s.id}, '${s.studentName?.replace("'", "\\'")}')">
                        Grade
                    </button>
                </td>
            </tr>
        `).join('');
    }

    function openGradeModal(submissionId, studentName) {
        document.getElementById('gradeSubmissionId').value = submissionId;
        document.getElementById('gradeStudentName').value = studentName;
        document.getElementById('gradeScore').max = assignment.maxScore || 100;
        document.getElementById('maxScoreHint').textContent = `Max score: ${assignment.maxScore || 100}`;
        new bootstrap.Modal(document.getElementById('gradeModal')).show();
    }
</script>
}
