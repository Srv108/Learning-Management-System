@using Learning_Management_System.Controllers;
@model AssignmentDetailsViewModel

@{
    ViewData["Title"] = Model.Assignment.Title;
    var isOverdue = Model.Assignment.DueDate < DateTime.UtcNow;
}

<div class="container mt-4">
    <div class="row mb-4">
        <div class="col-md-8">
            <h2>@Model.Assignment.Title</h2>
            <p class="text-muted">Subject: @Model.Assignment.SubjectName | Created by: @Model.Assignment.CreatedByName</p>
        </div>
        <div class="col-md-4 text-end">
            <a href="@Url.Action("Index", new { subjectId = Model.Assignment.SubjectId })" class="btn btn-secondary">
                <i class="bi bi-arrow-left"></i> Back
            </a>
        </div>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            @TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="row mb-4">
        <div class="col-md-8">
            <div class="card">
                <div class="card-header @(isOverdue ? "bg-danger text-white" : "bg-primary text-white")">
                    <h5 class="mb-0">Assignment Details</h5>
                </div>
                <div class="card-body">
                    <div class="row mb-3">
                        <div class="col-md-6">
                            <h6>Max Score</h6>
                            <p class="fs-5">@Model.Assignment.MaxScore points</p>
                        </div>
                        <div class="col-md-6">
                            <h6>Due Date</h6>
                            <p class="fs-5">
                                @Model.Assignment.DueDate.ToString("MMM dd, yyyy HH:mm")
                                @if (isOverdue)
                                {
                                    <span class="badge bg-danger">Overdue</span>
                                }
                            </p>
                        </div>
                    </div>

                    <div class="row mb-3">
                        <div class="col-md-12">
                            <h6>Description</h6>
                            <p>@(string.IsNullOrEmpty(Model.Assignment.Description) ? "No description provided." : Model.Assignment.Description)</p>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-12">
                            <h6>Created</h6>
                            <p class="text-muted">@Model.Assignment.CreatedAt.ToString("MMM dd, yyyy HH:mm")</p>
                        </div>
                    </div>
                </div>
                <div class="card-footer">
                    <a href="@Url.Action("Edit", new { id = Model.Assignment.Id })" class="btn btn-warning">
                        <i class="bi bi-pencil"></i> Edit
                    </a>
                    <a href="@Url.Action("Submit", new { assignmentId = Model.Assignment.Id })" class="btn btn-success">
                        <i class="bi bi-upload"></i> Submit Assignment
                    </a>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card">
                <div class="card-header bg-info text-white">
                    <h5 class="mb-0">Statistics</h5>
                </div>
                <div class="card-body">
                    <p>
                        <strong>Total Submissions:</strong>
                        <br />
                        <span class="badge bg-primary">@Model.Submissions.Count</span>
                    </p>

                    @{
                        var onTimeSubmissions = Model.Submissions.Count(s => s.SubmittedAt <= Model.Assignment.DueDate);
                        var lateSubmissions = Model.Submissions.Count(s => s.SubmittedAt > Model.Assignment.DueDate);
                    }

                    <p>
                        <strong>On Time:</strong>
                        <br />
                        <span class="badge bg-success">@onTimeSubmissions</span>
                    </p>

                    <p>
                        <strong>Late:</strong>
                        <br />
                        <span class="badge bg-danger">@lateSubmissions</span>
                    </p>
                </div>
            </div>
        </div>
    </div>

    <div class="card">
        <div class="card-header bg-secondary text-white">
            <h5 class="mb-0">Submissions</h5>
        </div>
        <div class="card-body">
            @if (Model.Submissions == null || Model.Submissions.Count == 0)
            {
                <p class="text-muted">No submissions yet.</p>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-striped table-hover">
                        <thead class="table-light">
                            <tr>
                                <th>Student</th>
                                <th>Email</th>
                                <th>Status</th>
                                <th>Submitted At</th>
                                <th>File</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var submission in Model.Submissions.OrderByDescending(s => s.SubmittedAt))
                            {
                                <tr>
                                    <td>@submission.StudentName</td>
                                    <td><small>@submission.StudentEmail</small></td>
                                    <td>
                                        @if (submission.Status == "LATE")
                                        {
                                            <span class="badge bg-warning">Late</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-success">@submission.Status</span>
                                        }
                                    </td>
                                    <td><small>@submission.SubmittedAt.ToString("MMM dd, yyyy HH:mm")</small></td>
                                    <td>
                                        @if (!string.IsNullOrEmpty(submission.FileUrl))
                                        {
                                            <a href="@submission.FileUrl" target="_blank" class="btn btn-sm btn-info">
                                                <i class="bi bi-download"></i> Download
                                            </a>
                                        }
                                        else
                                        {
                                            <span class="text-muted">—</span>
                                        }
                                    </td>
                                    <td>
                                        <a href="@Url.Action("Grade", new { submissionId = submission.Id })" class="btn btn-sm btn-primary">
                                            <i class="bi bi-pencil"></i> Grade
                                        </a>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>
</div>

<style>
    .badge {
        padding: 0.5em 0.75em;
    }
</style>
