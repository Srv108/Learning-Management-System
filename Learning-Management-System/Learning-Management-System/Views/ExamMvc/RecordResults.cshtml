@{
    ViewData["Title"] = "Record Results";
    var examId = ViewBag.ExamId;
    var examJson = ViewBag.ExamJson as string ?? "{}";
    var resultsJson = ViewBag.ResultsJson as string ?? "[]";
    var coursesJson = ViewBag.CoursesJson as string ?? "[]";
    ViewData["Breadcrumb"] = "<a href='/ExamMvc/Index' style='color:var(--text-muted);text-decoration:none'>Exams</a> <span style='margin:0 6px;color:var(--border-strong)'>›</span> <span class='current'>Record Results</span>";
}

<div class="page-header">
    <div>
        <div class="page-title">Record Results</div>
        <div class="page-sub">Enter and manage exam results</div>
    </div>
</div>

@if (examId == null)
{
    <div class="lms-card" style="margin-bottom:20px">
        <div style="font-weight:600;font-size:14px;margin-bottom:16px">Select an Exam</div>
        <div style="display:grid;grid-template-columns:1fr 1fr 1fr;gap:12px;align-items:flex-end">
            <div class="lms-form-group" style="margin-bottom:0">
                <label class="lms-label">Course</label>
                <select class="lms-select" id="courseFilter"><option value="">Select Course</option></select>
            </div>
            <div class="lms-form-group" style="margin-bottom:0">
                <label class="lms-label">Subject</label>
                <select class="lms-select" id="subjectFilter"><option value="">Select Course First</option></select>
            </div>
            <div class="lms-form-group" style="margin-bottom:0">
                <label class="lms-label">Exam</label>
                <select class="lms-select" id="examFilter" onchange="if(this.value) window.location.href='/ExamMvc/RecordResults?examId='+this.value">
                    <option value="">Select Subject First</option>
                </select>
            </div>
        </div>
    </div>
}

<div id="examHeader" style="margin-bottom:20px"></div>

@if (examId != null)
{
    <div style="display:grid;grid-template-columns:300px 1fr;gap:20px">
        <div class="lms-card" style="height:fit-content">
            <div style="font-weight:600;font-size:14px;margin-bottom:16px">Add Result</div>
            <form method="post" asp-action="AddResult" style="display:flex;flex-direction:column;gap:14px">
                <input type="hidden" name="examId" value="@examId" />
                <div class="lms-form-group">
                    <label class="lms-label">Student ID <span style="color:var(--rose)">*</span></label>
                    <input type="text" name="studentId" class="lms-input" required placeholder="Enter student user ID" />
                </div>
                <div class="lms-form-group">
                    <label class="lms-label">Marks <span style="color:var(--rose)">*</span></label>
                    <input type="number" name="marks" class="lms-input" required min="0" max="100" />
                </div>
                <div class="lms-form-group">
                    <label class="lms-label">Grade <span style="color:var(--rose)">*</span></label>
                    <select name="grade" class="lms-select" required>
                        <option value="A+">A+ (90-100)</option>
                        <option value="A">A (80-89)</option>
                        <option value="B">B (70-79)</option>
                        <option value="C">C (60-69)</option>
                        <option value="D">D (50-59)</option>
                        <option value="F">F (Below 50)</option>
                    </select>
                </div>
                <button type="submit" class="btn-lms-primary" style="width:100%">Record Result</button>
            </form>
        </div>

        <div class="lms-card" style="padding:0">
            <div style="padding:16px 20px;border-bottom:1px solid var(--border);font-weight:600;font-size:14px">Recorded Results</div>
            <div style="overflow-x:auto">
                <table class="lms-table">
                    <thead>
                        <tr><th>Student</th><th>Marks</th><th>Grade</th><th>Actions</th></tr>
                    </thead>
                    <tbody id="resultsBody"></tbody>
                </table>
            </div>
        </div>
    </div>

    <!-- Edit Modal -->
    <div id="editResultModal" style="display:none;position:fixed;inset:0;background:rgba(0,0,0,0.5);z-index:1000;align-items:center;justify-content:center">
        <div class="lms-card" style="width:380px;max-width:90vw">
            <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:20px">
                <span style="font-weight:600;font-size:16px">Edit Result</span>
                <button onclick="document.getElementById('editResultModal').style.display='none'" style="background:none;border:none;cursor:pointer;color:var(--text-muted);font-size:20px;line-height:1">&times;</button>
            </div>
            <form method="post" asp-action="UpdateResult" style="display:flex;flex-direction:column;gap:14px">
                <input type="hidden" name="resultId" id="editResultId" />
                <input type="hidden" name="examId" value="@examId" />
                <div class="lms-form-group">
                    <label class="lms-label">Marks</label>
                    <input type="number" name="marks" id="editMarks" class="lms-input" min="0" required />
                </div>
                <div class="lms-form-group">
                    <label class="lms-label">Grade</label>
                    <select name="grade" id="editGrade" class="lms-select">
                        <option value="A+">A+</option><option value="A">A</option>
                        <option value="B">B</option><option value="C">C</option>
                        <option value="D">D</option><option value="F">F</option>
                    </select>
                </div>
                <div style="display:flex;gap:10px;justify-content:flex-end">
                    <button type="button" class="btn-lms-ghost" onclick="document.getElementById('editResultModal').style.display='none'">Cancel</button>
                    <button type="submit" class="btn-lms-primary">Update</button>
                </div>
            </form>
        </div>
    </div>
}

@section Scripts {
<script>
    const exam = @Html.Raw(examJson);
    const results = @Html.Raw(resultsJson);
    const courses = @Html.Raw(coursesJson);
    const examIdVal = @Html.Raw(examId?.ToString() ?? "0");

    if (exam && exam.id) {
        document.getElementById('examHeader').innerHTML = `
            <div class="lms-card">
                <div style="display:flex;gap:32px;flex-wrap:wrap">
                    <div><div style="font-size:11px;color:var(--text-muted);text-transform:uppercase;letter-spacing:.05em;margin-bottom:2px">Exam</div><div style="font-weight:600">${exam.title}</div></div>
                    <div><div style="font-size:11px;color:var(--text-muted);text-transform:uppercase;letter-spacing:.05em;margin-bottom:2px">Type</div><div style="font-weight:600">${exam.examType}</div></div>
                    <div><div style="font-size:11px;color:var(--text-muted);text-transform:uppercase;letter-spacing:.05em;margin-bottom:2px">Subject</div><div style="font-weight:600">${exam.subjectName}</div></div>
                    <div><div style="font-size:11px;color:var(--text-muted);text-transform:uppercase;letter-spacing:.05em;margin-bottom:2px">Date</div><div style="font-weight:600">${new Date(exam.examDate).toLocaleDateString()}</div></div>
                    <div><div style="font-size:11px;color:var(--text-muted);text-transform:uppercase;letter-spacing:.05em;margin-bottom:2px">Max Score</div><div style="font-weight:600">${exam.maxScore}</div></div>
                </div>
            </div>`;
    }

    const gradeStyle = g => {
        if (g === 'A+' || g === 'A') return 'background:var(--green-soft);color:var(--green)';
        if (g === 'B') return 'background:var(--sky-soft);color:var(--sky)';
        if (g === 'C' || g === 'D') return 'background:var(--amber-soft);color:var(--amber)';
        if (g === 'F') return 'background:var(--rose-soft);color:var(--rose)';
        return 'background:var(--bg-muted);color:var(--text-muted)';
    };

    const tbody = document.getElementById('resultsBody');
    if (tbody) {
        if (!results || results.length === 0) {
            tbody.innerHTML = '<tr><td colspan="4" style="text-align:center;padding:32px;color:var(--text-muted)">No results recorded yet</td></tr>';
        } else {
            tbody.innerHTML = results.map(r => `
                <tr>
                    <td>
                        <div style="font-weight:600">${r.studentName || r.studentId || '-'}</div>
                        <div style="font-size:12.5px;color:var(--text-muted)">${r.studentEmail || ''}</div>
                    </td>
                    <td><strong>${r.marks ?? '-'}</strong></td>
                    <td><span class="lms-badge" style="${gradeStyle(r.grade)}">${r.grade||'-'}</span></td>
                    <td>
                        <div style="display:flex;gap:6px">
                            <button class="btn-lms-ghost btn-lms-sm"
                                    onclick="openEditResult(${r.id},${r.marks||0},'${r.grade||'A'}')">Edit</button>
                            <form method="post" action="/ExamMvc/DeleteResult" style="display:inline"
                                  onsubmit="return confirm('Delete this result?')">
                                <input type="hidden" name="resultId" value="${r.id}" />
                                <input type="hidden" name="examId" value="${examIdVal}" />
                                <button class="btn-lms-danger btn-lms-sm">Delete</button>
                            </form>
                        </div>
                    </td>
                </tr>`).join('');
        }
    }

    function openEditResult(id, marks, grade) {
        document.getElementById('editResultId').value = id;
        document.getElementById('editMarks').value = marks;
        document.getElementById('editGrade').value = grade;
        document.getElementById('editResultModal').style.display = 'flex';
    }

    const courseFilter = document.getElementById('courseFilter');
    if (courseFilter && courses) {
        courses.forEach(c => {
            const opt = document.createElement('option');
            opt.value = c.id; opt.textContent = c.title;
            courseFilter.appendChild(opt);
        });

        courseFilter.addEventListener('change', async function() {
            const sel = document.getElementById('subjectFilter');
            sel.innerHTML = '<option value="">Loading...</option>';
            document.getElementById('examFilter').innerHTML = '<option value="">Select Subject First</option>';
            if (!this.value) { sel.innerHTML = '<option value="">Select Course First</option>'; return; }
            const res = await fetch(`/api/subject/course/${this.value}`);
            const subs = await res.json();
            sel.innerHTML = '<option value="">Select Subject</option>';
            subs.forEach(s => {
                const opt = document.createElement('option');
                opt.value = s.id; opt.textContent = s.name;
                sel.appendChild(opt);
            });
        });

        document.getElementById('subjectFilter').addEventListener('change', async function() {
            const examSel = document.getElementById('examFilter');
            examSel.innerHTML = '<option value="">Loading...</option>';
            if (!this.value) { examSel.innerHTML = '<option value="">Select Subject First</option>'; return; }
            const res = await fetch(`/api/exam/subject/${this.value}`);
            const exams = await res.json();
            examSel.innerHTML = '<option value="">Select Exam</option>';
            exams.forEach(e => {
                const opt = document.createElement('option');
                opt.value = e.id; opt.textContent = `${e.title} (${e.examType})`;
                examSel.appendChild(opt);
            });
        });
    }
</script>
}
