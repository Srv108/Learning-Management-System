@{
    ViewData["Title"] = "Record Results";
    var examId = ViewBag.ExamId;
    var examJson = ViewBag.ExamJson as string ?? "{}";
    var resultsJson = ViewBag.ResultsJson as string ?? "[]";
    var coursesJson = ViewBag.CoursesJson as string ?? "[]";
}

<nav aria-label="breadcrumb" class="mb-3">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a asp-action="Index">Exams</a></li>
        <li class="breadcrumb-item active">Record Results</li>
    </ol>
</nav>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show">@TempData["Success"]<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show">@TempData["Error"]<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>
}

<!-- Exam Selector (if no exam selected) -->
@if (examId == null)
{
    <div class="card border-0 shadow-sm mb-4">
        <div class="card-header bg-white fw-semibold py-3">Select an Exam</div>
        <div class="card-body">
            <div class="row g-2 align-items-end">
                <div class="col-md-4">
                    <label class="form-label small fw-semibold">Course</label>
                    <select class="form-select" id="courseFilter"><option value="">Select Course</option></select>
                </div>
                <div class="col-md-4">
                    <label class="form-label small fw-semibold">Subject</label>
                    <select class="form-select" id="subjectFilter"><option value="">Select Course First</option></select>
                </div>
                <div class="col-md-4">
                    <label class="form-label small fw-semibold">Exam</label>
                    <select class="form-select" id="examFilter" onchange="if(this.value) window.location.href='/ExamMvc/RecordResults?examId='+this.value">
                        <option value="">Select Subject First</option>
                    </select>
                </div>
            </div>
        </div>
    </div>
}

<div id="examHeader" class="mb-4"></div>

@if (examId != null)
{
    <div class="row">
        <div class="col-md-5">
            <div class="card border-0 shadow-sm">
                <div class="card-header bg-white fw-semibold py-3">Add Result</div>
                <div class="card-body p-4">
                    <form method="post" asp-action="AddResult">
                        <input type="hidden" name="examId" value="@examId" />
                        <div class="mb-3">
                            <label class="form-label fw-semibold">Student ID *</label>
                            <input type="text" name="studentId" class="form-control" required placeholder="Enter student user ID" />
                        </div>
                        <div class="mb-3">
                            <label class="form-label fw-semibold">Marks *</label>
                            <input type="number" name="marks" class="form-control" required min="0" max="100" />
                        </div>
                        <div class="mb-3">
                            <label class="form-label fw-semibold">Grade *</label>
                            <select name="grade" class="form-select" required>
                                <option value="A+">A+ (90-100)</option>
                                <option value="A">A (80-89)</option>
                                <option value="B">B (70-79)</option>
                                <option value="C">C (60-69)</option>
                                <option value="D">D (50-59)</option>
                                <option value="F">F (Below 50)</option>
                            </select>
                        </div>
                        <button type="submit" class="btn btn-primary w-100">Record Result</button>
                    </form>
                </div>
            </div>
        </div>
        <div class="col-md-7">
            <div class="card border-0 shadow-sm">
                <div class="card-header bg-white fw-semibold py-3">Recorded Results</div>
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-hover mb-0">
                            <thead class="table-light">
                                <tr><th>Student</th><th>Marks</th><th>Grade</th><th>Actions</th></tr>
                            </thead>
                            <tbody id="resultsBody"></tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
}

<!-- Edit Result Modal -->
@if (examId != null)
{
    <div class="modal fade" id="editResultModal" tabindex="-1">
        <div class="modal-dialog modal-sm">
            <div class="modal-content border-0 shadow">
                <div class="modal-header">
                    <h5 class="modal-title">Edit Result</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <form method="post" asp-action="UpdateResult">
                    <div class="modal-body">
                        <input type="hidden" name="resultId" id="editResultId" />
                        <input type="hidden" name="examId" value="@examId" />
                        <div class="mb-3">
                            <label class="form-label fw-semibold">Marks</label>
                            <input type="number" name="marks" id="editMarks" class="form-control" min="0" required />
                        </div>
                        <div class="mb-2">
                            <label class="form-label fw-semibold">Grade</label>
                            <select name="grade" id="editGrade" class="form-select">
                                <option value="A+">A+</option><option value="A">A</option>
                                <option value="B">B</option><option value="C">C</option>
                                <option value="D">D</option><option value="F">F</option>
                            </select>
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary btn-sm" data-bs-dismiss="modal">Cancel</button>
                        <button type="submit" class="btn btn-primary btn-sm">Update</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
}

@section Scripts {
<script>
    const exam = @Html.Raw(examJson);
    const results = @Html.Raw(resultsJson);
    const courses = @Html.Raw(coursesJson);

    if (exam && exam.id) {
        document.getElementById('examHeader').innerHTML = `
            <div class="card border-0 shadow-sm">
                <div class="card-body py-3">
                    <div class="d-flex gap-4 flex-wrap align-items-center">
                        <div><span class="text-muted small">Exam</span><div class="fw-semibold">${exam.title}</div></div>
                        <div><span class="text-muted small">Type</span><span class="badge ${exam.examType === 'FINAL' ? 'bg-danger' : 'bg-warning text-dark'} ms-1">${exam.examType}</span></div>
                        <div><span class="text-muted small">Subject</span><div class="fw-semibold">${exam.subjectName}</div></div>
                        <div><span class="text-muted small">Date</span><div class="fw-semibold">${new Date(exam.examDate).toLocaleDateString()}</div></div>
                        <div><span class="text-muted small">Max Score</span><div class="fw-semibold">${exam.maxScore}</div></div>
                    </div>
                </div>
            </div>`;
    }

    const tbody = document.getElementById('resultsBody');
    const examIdVal = @Html.Raw(examId?.ToString() ?? "0");
    if (tbody) {
        if (!results || results.length === 0) {
            tbody.innerHTML = '<tr><td colspan="4" class="text-center py-4 text-muted">No results recorded yet</td></tr>';
        } else {
            tbody.innerHTML = results.map(r => `
                <tr>
                    <td>
                        <div class="fw-semibold">${r.studentName || r.studentId || '-'}</div>
                        <div class="text-muted small">${r.studentEmail || ''}</div>
                    </td>
                    <td><strong>${r.marks ?? '-'}</strong></td>
                    <td><span class="badge ${r.grade==='F'?'bg-danger':r.grade==='A+'||r.grade==='A'?'bg-success':'bg-secondary'}">${r.grade||'-'}</span></td>
                    <td>
                        <button class="btn btn-sm btn-outline-primary py-0 me-1"
                                onclick="openEditResult(${r.id},${r.marks||0},'${r.grade||'A'}')">Edit</button>
                        <form method="post" action="/ExamMvc/DeleteResult" class="d-inline"
                              onsubmit="return confirm('Delete this result?')">
                            <input type="hidden" name="resultId" value="${r.id}" />
                            <input type="hidden" name="examId" value="${examIdVal}" />
                            <button class="btn btn-sm btn-outline-danger py-0">Del</button>
                        </form>
                    </td>
                </tr>`).join('');
        }
    }

    function openEditResult(id, marks, grade) {
        document.getElementById('editResultId').value = id;
        document.getElementById('editMarks').value = marks;
        document.getElementById('editGrade').value = grade;
        const modal = new bootstrap.Modal(document.getElementById('editResultModal'));
        modal.show();
    }

    // Course/Subject/Exam selectors
    const courseFilter = document.getElementById('courseFilter');
    if (courseFilter && courses) {
        courses.forEach(c => {
            const opt = document.createElement('option');
            opt.value = c.id; opt.textContent = c.title;
            courseFilter.appendChild(opt);
        });

        courseFilter.addEventListener('change', async function() {
            const sel = document.getElementById('subjectFilter');
            sel.innerHTML = '<option value="">Loading...</option>';
            document.getElementById('examFilter').innerHTML = '<option value="">Select Subject First</option>';
            if (!this.value) { sel.innerHTML = '<option value="">Select Course First</option>'; return; }
            const res = await fetch(`/api/subject/course/${this.value}`);
            const subs = await res.json();
            sel.innerHTML = '<option value="">Select Subject</option>';
            subs.forEach(s => {
                const opt = document.createElement('option');
                opt.value = s.id; opt.textContent = s.name;
                sel.appendChild(opt);
            });
        });

        document.getElementById('subjectFilter').addEventListener('change', async function() {
            const examSel = document.getElementById('examFilter');
            examSel.innerHTML = '<option value="">Loading...</option>';
            if (!this.value) { examSel.innerHTML = '<option value="">Select Subject First</option>'; return; }
            const res = await fetch(`/api/exam/subject/${this.value}`);
            const exams = await res.json();
            examSel.innerHTML = '<option value="">Select Exam</option>';
            exams.forEach(e => {
                const opt = document.createElement('option');
                opt.value = e.id; opt.textContent = `${e.title} (${e.examType})`;
                examSel.appendChild(opt);
            });
        });
    }
</script>
}
