@model List<ExamResult>

@{
    ViewData["Title"] = "Exam Results";
    var exam = ViewBag.Exam as Exam;
    var students = ViewBag.Students as List<dynamic>;
}

<div class="container-fluid">
    <div class="row">
        <div class="col-12">
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb">
                    <li class="breadcrumb-item"><a asp-action="Index">Exam Management</a></li>
                    <li class="breadcrumb-item active" aria-current="page">Results</li>
                </ol>
            </nav>
        </div>
    </div>

    <div class="row mb-4">
        <div class="col-12">
            <div class="card">
                <div class="card-header bg-info text-white">
                    <h4 class="card-title mb-0">
                        <i class="bi bi-bar-chart-line"></i> Results for: @exam?.Title
                    </h4>
                </div>
                <div class="card-body">
                    <div class="row">
                        <div class="col-md-3">
                            <strong>Subject:</strong> @exam?.Subject?.Name
                        </div>
                        <div class="col-md-3">
                            <strong>Date:</strong> @exam?.ExamDate.ToString("MMM dd, yyyy")
                        </div>
                        <div class="col-md-3">
                            <strong>Type:</strong> <span class="badge bg-secondary">@exam?.ExamType</span>
                        </div>
                        <div class="col-md-3">
                            <strong>Max Score:</strong> @exam?.MaxScore
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="row">
        @if (User.IsInRole("Teacher"))
        {
            <div class="col-md-4">
                <div class="card">
                    <div class="card-header bg-success text-white">
                        <h5 class="card-title mb-0">
                            <i class="bi bi-plus-circle"></i> Add New Result
                        </h5>
                    </div>
                    <div class="card-body">
                        @if (TempData["Message"] != null)
                        {
                            <div class="alert alert-warning alert-dismissible fade show" role="alert">
                                @TempData["Message"]
                                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                            </div>
                        }

                        <form asp-action="AddResult" method="post">
                            <input type="hidden" name="ExamId" value="@exam?.Id" />

                            <div class="mb-3">
                                <label class="form-label">
                                    <i class="bi bi-person"></i> Student
                                </label>
                                <select name="StudentId" class="form-select" required>
                                    <option value="">-- Select student --</option>
                                    @if (students != null)
                                    {
                                        @foreach (var student in students)
                                        {
                                            <option value="@student.Id">@student.FullName (@student.Email)</option>
                                        }
                                    }
                                </select>
                            </div>

                            <div class="row">
                                <div class="col-6 mb-3">
                                    <label class="form-label">
                                        <i class="bi bi-trophy"></i> Marks
                                    </label>
                                    <input name="Marks" type="number" min="0" max="@exam?.MaxScore" class="form-control" required placeholder="0" />
                                </div>
                                <div class="col-6 mb-3">
                                    <label class="form-label">
                                        <i class="bi bi-star"></i> Grade
                                    </label>
                                    <input name="Grade" type="text" class="form-control" maxlength="10" placeholder="A+/A/B" />
                                </div>
                            </div>

                            <button type="submit" class="btn btn-success w-100">
                                <i class="bi bi-check-circle"></i> Save Result
                            </button>
                        </form>
                    </div>
                </div>
            </div>
        }
        else
        {
            <div class="col-md-4">
                <div class="card">
                    <div class="card-body text-center text-muted">
                        <i class="bi bi-lock" style="font-size: 2rem;"></i>
                        <p class="mt-3 mb-0">Only teachers can enter exam results.</p>
                    </div>
                </div>
            </div>
        }

        <div class="col-md-8">
            <div class="card">
                <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center">
                    <h5 class="card-title mb-0">
                        <i class="bi bi-table"></i> Student Results (@Model.Count)
                    </h5>
                    @if (Model.Any())
                    {
                        <span class="badge bg-light text-dark">
                            Avg: @string.Format("{0:F1}", Model.Average(r => r.Marks)) / @exam?.MaxScore
                        </span>
                    }
                </div>
                <div class="card-body">
                    @if (!Model.Any())
                    {
                        <div class="text-center py-5">
                            <i class="bi bi-clipboard-x text-muted" style="font-size: 3rem;"></i>
                            <h5 class="text-muted mt-3">No results recorded yet</h5>
                            <p class="text-muted">Add student results using the form on the left.</p>
                        </div>
                    }
                    else
                    {
                        <div class="table-responsive">
                            <table class="table table-hover">
                                <thead>
                                    <tr>
                                        <th>#</th>
                                        <th>Student</th>
                                        <th>Marks</th>
                                        <th>Grade</th>
                                        <th>Percentage</th>
                                        <th>Graded By</th>
                                        <th>Date</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @{
                                        var index = 1;
                                        foreach (var item in Model.OrderByDescending(r => r.Marks))
                                        {
                                            var percentage = exam != null ? (item.Marks / (double)exam.MaxScore * 100) : 0;
                                            <tr>
                                                <td>@index</td>
                                                <td>
                                                    <strong>@item.Student?.FullName</strong><br />
                                                    <small class="text-muted">@item.Student?.Email</small>
                                                </td>
                                                <td><strong>@item.Marks</strong></td>
                                                <td>
                                                    <span class="badge bg-secondary">@item.Grade</span>
                                                </td>
                                                <td>
                                                    <div class="progress" style="height: 20px;">
                                                        <div class="progress-bar @(percentage >= 80 ? "bg-success" : percentage >= 60 ? "bg-warning" : "bg-danger")"
                                                             role="progressbar"
                                                             style="width: @percentage%"
                                                             aria-valuenow="@percentage"
                                                             aria-valuemin="0"
                                                             aria-valuemax="100">
                                                            @string.Format("{0:F1}", percentage)%
                                                        </div>
                                                    </div>
                                                </td>
                                                <td>@item.GradedBy?.FullName</td>
                                                <td>@item.CreatedAt.ToString("MMM dd")</td>
                                            </tr>
                                            index++;
                                        }
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>
