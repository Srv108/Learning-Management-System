@{
    ViewData["Title"] = "My Exam Results";
    var summaryJson = ViewBag.SummaryJson as string ?? "null";
    var coursesJson = ViewBag.CoursesJson as string ?? "[]";
    var subjectId = ViewBag.SubjectId;
}

<div class="page-header">
    <div>
        <div class="page-title">My Exam Results</div>
        <div class="page-sub">View your exam scores and performance</div>
    </div>
</div>

<div class="lms-card" style="margin-bottom:20px">
    <div style="display:grid;grid-template-columns:1fr 1fr auto;gap:12px;align-items:flex-end">
        <div class="lms-form-group" style="margin-bottom:0">
            <label class="lms-label">Course</label>
            <select class="lms-select" id="courseSelect"><option value="">Select Course</option></select>
        </div>
        <div class="lms-form-group" style="margin-bottom:0">
            <label class="lms-label">Subject</label>
            <select class="lms-select" id="subjectSelect"><option value="">Select Course First</option></select>
        </div>
        <button class="btn-lms-primary" onclick="load()">View</button>
    </div>
</div>

<div id="summaryContainer"></div>

@section Scripts {
<script>
    const courses = @Html.Raw(coursesJson);
    const summary = @Html.Raw(summaryJson);

    const courseSelect = document.getElementById('courseSelect');
    courses.forEach(c => {
        const opt = document.createElement('option');
        opt.value = c.id; opt.textContent = c.title;
        courseSelect.appendChild(opt);
    });

    courseSelect.addEventListener('change', async function() {
        const sel = document.getElementById('subjectSelect');
        sel.innerHTML = '<option value="">Loading...</option>';
        if (!this.value) { sel.innerHTML = '<option value="">Select Course First</option>'; return; }
        const res = await fetch(`/api/subject/course/${this.value}`);
        const subs = await res.json();
        sel.innerHTML = '<option value="">Select Subject</option>';
        subs.forEach(s => {
            const opt = document.createElement('option');
            opt.value = s.id; opt.textContent = s.name;
            sel.appendChild(opt);
        });
    });

    function load() {
        const subId = document.getElementById('subjectSelect').value;
        if (!subId) { alert('Please select a subject'); return; }
        window.location.href = `/ExamMvc/MyResults?subjectId=${subId}`;
    }

    const container = document.getElementById('summaryContainer');
    if (summary) {
        const avg = summary.averageScore || 0;
        const isGood = avg >= 70;
        const isAvg = avg >= 50 && avg < 70;
        const color = isGood ? 'var(--green)' : isAvg ? 'var(--amber)' : 'var(--rose)';
        const softBg = isGood ? 'var(--green-soft)' : isAvg ? 'var(--amber-soft)' : 'var(--rose-soft)';
        const status = isGood ? 'Good' : isAvg ? 'Average' : 'Needs Improvement';

        container.innerHTML = `
            <div style="display:grid;grid-template-columns:200px 1fr;gap:20px">
                <div class="lms-card" style="text-align:center">
                    <div style="font-size:12px;color:var(--text-muted);text-transform:uppercase;letter-spacing:.06em;margin-bottom:12px">Average Score</div>
                    <div style="font-size:48px;font-weight:800;color:${color};line-height:1;margin-bottom:8px">${avg.toFixed(1)}</div>
                    <span class="lms-badge" style="background:${softBg};color:${color}">${status}</span>
                </div>
                <div class="lms-card">
                    <div style="font-weight:600;font-size:15px;margin-bottom:16px">${summary.subjectName || 'Subject'} — Exam Summary</div>
                    <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:16px;margin-bottom:16px">
                        <div style="text-align:center">
                            <div style="font-size:32px;font-weight:800">${summary.examsTaken || 0}</div>
                            <div style="font-size:12.5px;color:var(--text-muted)">Exams Taken</div>
                        </div>
                        <div style="text-align:center">
                            <div style="font-size:32px;font-weight:800;color:${color}">${avg.toFixed(1)}</div>
                            <div style="font-size:12.5px;color:var(--text-muted)">Average Score</div>
                        </div>
                        <div style="text-align:center">
                            <div style="font-size:32px;font-weight:800;color:var(--amber)">${summary.bestGrade || '-'}</div>
                            <div style="font-size:12.5px;color:var(--text-muted)">Best Grade</div>
                        </div>
                    </div>
                    ${avg >= 50
                        ? `<div class="lms-alert success"><div class="alert-icon"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg></div><div>You are passing this subject.</div></div>`
                        : `<div class="lms-alert danger"><div class="alert-icon"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg></div><div>You are below passing. Please focus on improvement.</div></div>`}
                </div>
            </div>`;
    } else {
        container.innerHTML = `<div class="lms-card" style="text-align:center;padding:48px">
            <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="var(--text-faint)" stroke-width="1.2" style="margin-bottom:12px"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
            <div style="font-weight:600;color:var(--text-dim);margin-bottom:4px">No results yet</div>
            <div style="font-size:13px;color:var(--text-muted)">Select a subject to view your exam results</div>
        </div>`;
    }
</script>
}
