@{
    ViewData["Title"] = "My Exam Results";
    var summaryJson = ViewBag.SummaryJson as string ?? "null";
    var allResultsJson = ViewBag.AllResultsJson as string ?? "[]";
    var coursesJson = ViewBag.CoursesJson as string ?? "[]";
    var subjectId = ViewBag.SubjectId;
}

<div class="page-header">
    <div>
        <div class="page-title">My Exam Results</div>
        <div class="page-sub">All your exam scores across every subject</div>
    </div>
</div>

<div id="allResultsContainer" style="margin-bottom:24px"></div>

<div class="lms-card" style="margin-bottom:20px">
    <div style="font-weight:600;font-size:14px;margin-bottom:14px">Filter by Subject</div>
    <div style="display:grid;grid-template-columns:1fr 1fr auto;gap:12px;align-items:flex-end">
        <div class="lms-form-group" style="margin-bottom:0">
            <label class="lms-label">Course</label>
            <select class="lms-select" id="courseSelect"><option value="">Select Course</option></select>
        </div>
        <div class="lms-form-group" style="margin-bottom:0">
            <label class="lms-label">Subject</label>
            <select class="lms-select" id="subjectSelect"><option value="">Select Course First</option></select>
        </div>
        <button class="btn-lms-primary" onclick="loadSubjectSummary()">View Summary</button>
    </div>
</div>

<div id="summaryContainer"></div>

@section Scripts {
<script>
    const courses = @Html.Raw(coursesJson);
    const allResults = @Html.Raw(allResultsJson);
    const summary = @Html.Raw(summaryJson);

    // Grade color helpers
    const gradeColor = g => {
        if (!g) return 'var(--text-muted)';
        if (g === 'A+' || g === 'A') return 'var(--green)';
        if (g === 'B') return 'var(--sky)';
        if (g === 'C' || g === 'D') return 'var(--amber)';
        return 'var(--rose)';
    };
    const gradeStyle = g => {
        if (!g) return 'background:var(--bg-muted);color:var(--text-muted)';
        if (g === 'A+' || g === 'A') return 'background:var(--green-soft);color:var(--green)';
        if (g === 'B') return 'background:var(--sky-soft);color:var(--sky)';
        if (g === 'C' || g === 'D') return 'background:var(--amber-soft);color:var(--amber)';
        return 'background:var(--rose-soft);color:var(--rose)';
    };

    // Render all results table
    const allContainer = document.getElementById('allResultsContainer');
    if (allResults && allResults.length > 0) {
        const avgScore = allResults.reduce((s, r) => s + (r.marks || 0), 0) / allResults.length;
        const passCount = allResults.filter(r => r.marks >= 50).length;

        allContainer.innerHTML = `
            <div class="stats-grid-4" style="margin-bottom:20px">
                <div class="stat-card">
                    <div class="stat-label">Total Exams</div>
                    <div class="stat-val" style="color:var(--navy)">${allResults.length}</div>
                </div>
                <div class="stat-card">
                    <div class="stat-label">Average Score</div>
                    <div class="stat-val" style="color:${avgScore >= 60 ? 'var(--green)' : 'var(--rose)'}">${avgScore.toFixed(1)}</div>
                </div>
                <div class="stat-card">
                    <div class="stat-label">Passed</div>
                    <div class="stat-val" style="color:var(--green)">${passCount}</div>
                </div>
                <div class="stat-card">
                    <div class="stat-label">Pass Rate</div>
                    <div class="stat-val" style="color:${passCount/allResults.length>=0.6?'var(--green)':'var(--rose)'}">${Math.round(passCount/allResults.length*100)}%</div>
                </div>
            </div>
            <div class="lms-card" style="padding:0">
                <div style="display:flex;justify-content:space-between;align-items:center;padding:16px 20px;border-bottom:1px solid var(--border)">
                    <span style="font-weight:600;font-size:14px">All Exam Results</span>
                    <span class="lms-badge" style="background:var(--navy-soft);color:var(--navy)">${allResults.length} results</span>
                </div>
                <table class="lms-table">
                    <thead>
                        <tr>
                            <th>Exam</th>
                            <th>Type</th>
                            <th>Subject</th>
                            <th>Course</th>
                            <th>Marks</th>
                            <th>Max</th>
                            <th>Grade</th>
                            <th>Date</th>
                        </tr>
                    </thead>
                    <tbody>
                        ${allResults.map(r => `
                        <tr>
                            <td style="font-weight:500">${r.examTitle || 'Exam'}</td>
                            <td><span class="lms-badge" style="background:var(--bg-muted);color:var(--text-muted)">${r.examType || ''}</span></td>
                            <td style="color:var(--text-muted)">${r.subjectName || ''}</td>
                            <td style="color:var(--text-muted);font-size:12.5px">${r.courseName || ''}</td>
                            <td><strong style="color:${(r.marks||0)>=50?'var(--green)':'var(--rose)'}">${r.marks ?? 0}</strong></td>
                            <td style="color:var(--text-muted)">${r.maxScore || 100}</td>
                            <td><span class="lms-badge" style="${gradeStyle(r.grade)}">${r.grade || '-'}</span></td>
                            <td style="color:var(--text-muted);font-size:12.5px">${r.examDate ? new Date(r.examDate).toLocaleDateString() : '-'}</td>
                        </tr>`).join('')}
                    </tbody>
                </table>
            </div>`;
    } else {
        allContainer.innerHTML = `<div class="lms-card" style="text-align:center;padding:48px">
            <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="var(--text-faint)" stroke-width="1.2" style="margin-bottom:12px"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
            <div style="font-weight:600;color:var(--text-dim);margin-bottom:4px">No exam results yet</div>
            <div style="font-size:13px;color:var(--text-muted)">Your results will appear here once exams are graded.</div>
        </div>`;
    }

    // Populate course dropdown
    const courseSelect = document.getElementById('courseSelect');
    courses.forEach(c => {
        const opt = document.createElement('option');
        opt.value = c.id; opt.textContent = c.title;
        courseSelect.appendChild(opt);
    });

    courseSelect.addEventListener('change', async function() {
        const sel = document.getElementById('subjectSelect');
        sel.innerHTML = '<option value="">Loading...</option>';
        if (!this.value) { sel.innerHTML = '<option value="">Select Course First</option>'; return; }
        const res = await fetch(`/api/subject/course/${this.value}`);
        const subs = await res.json();
        sel.innerHTML = '<option value="">Select Subject</option>';
        subs.forEach(s => {
            const opt = document.createElement('option');
            opt.value = s.id; opt.textContent = s.name;
            sel.appendChild(opt);
        });
    });

    function loadSubjectSummary() {
        const subId = document.getElementById('subjectSelect').value;
        if (!subId) { alert('Please select a subject'); return; }
        window.location.href = `/ExamMvc/MyResults?subjectId=${subId}`;
    }

    // Subject-level summary panel
    const summaryContainer = document.getElementById('summaryContainer');
    if (summary) {
        const avg = summary.averageScore || 0;
        const isGood = avg >= 70, isAvg = avg >= 50 && avg < 70;
        const color = isGood ? 'var(--green)' : isAvg ? 'var(--amber)' : 'var(--rose)';
        const softBg = isGood ? 'var(--green-soft)' : isAvg ? 'var(--amber-soft)' : 'var(--rose-soft)';
        const status = isGood ? 'Good' : isAvg ? 'Average' : 'Needs Improvement';

        summaryContainer.innerHTML = `
            <div style="font-weight:600;font-size:15px;margin-bottom:14px;color:var(--text)">Subject Detail: ${summary.subjectName || ''}</div>
            <div style="display:grid;grid-template-columns:200px 1fr;gap:20px">
                <div class="lms-card" style="text-align:center">
                    <div style="font-size:12px;color:var(--text-muted);text-transform:uppercase;letter-spacing:.06em;margin-bottom:12px">Average Score</div>
                    <div style="font-size:48px;font-weight:800;color:${color};line-height:1;margin-bottom:8px">${avg.toFixed(1)}</div>
                    <span class="lms-badge" style="background:${softBg};color:${color}">${status}</span>
                </div>
                <div class="lms-card">
                    <div style="font-weight:600;font-size:15px;margin-bottom:16px">${summary.subjectName || 'Subject'} — Exam Summary</div>
                    <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:16px;margin-bottom:16px">
                        <div style="text-align:center">
                            <div style="font-size:32px;font-weight:800">${summary.examsTaken || 0}</div>
                            <div style="font-size:12.5px;color:var(--text-muted)">Exams Taken</div>
                        </div>
                        <div style="text-align:center">
                            <div style="font-size:32px;font-weight:800;color:${color}">${avg.toFixed(1)}</div>
                            <div style="font-size:12.5px;color:var(--text-muted)">Average Score</div>
                        </div>
                        <div style="text-align:center">
                            <div style="font-size:32px;font-weight:800;color:var(--amber)">${summary.bestGrade || '-'}</div>
                            <div style="font-size:12.5px;color:var(--text-muted)">Best Grade</div>
                        </div>
                    </div>
                    ${avg >= 50
                        ? `<div class="lms-alert success"><div class="alert-icon"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg></div><div>You are passing this subject.</div></div>`
                        : `<div class="lms-alert danger"><div class="alert-icon"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/></svg></div><div>You are below passing. Focus on improvement.</div></div>`}
                </div>
            </div>`;
    }
</script>
}
