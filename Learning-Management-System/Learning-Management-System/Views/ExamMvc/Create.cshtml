@model CreateExamDto

@{
    ViewData["Title"] = "Schedule Exam";
}

<div class="container">
    <div class="row justify-content-center">
        <div class="col-md-8 col-lg-6">
            <div class="card shadow">
                <div class="card-header bg-success text-white">
                    <h4 class="card-title mb-0">
                        <i class="bi bi-calendar-plus"></i> Schedule New Exam
                    </h4>
                </div>
                <div class="card-body">
                    <form asp-action="Create" method="post">
                        <div class="mb-3">
                            <label asp-for="SubjectId" class="form-label">
                                <i class="bi bi-book"></i> Subject
                            </label>
                            <select asp-for="SubjectId" class="form-select" asp-items="@(new SelectList(ViewBag.Subjects, "Id", "Name"))">
                                <option value="">-- Select subject --</option>
                            </select>
                            <span asp-validation-for="SubjectId" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Title" class="form-label">
                                <i class="bi bi-pencil"></i> Exam Title
                            </label>
                            <input asp-for="Title" class="form-control" placeholder="e.g., Midterm Exam 2024" />
                            <span asp-validation-for="Title" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="ExamType" class="form-label">
                                <i class="bi bi-tag"></i> Exam Type
                            </label>
                            <select asp-for="ExamType" class="form-select">
                                <option value="">-- Choose type --</option>
                                <option value="MIDTERM">Midterm</option>
                                <option value="FINAL">Final</option>
                            </select>
                            <span asp-validation-for="ExamType" class="text-danger"></span>
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label asp-for="MaxScore" class="form-label">
                                    <i class="bi bi-trophy"></i> Max Score
                                </label>
                                <input asp-for="MaxScore" class="form-control" type="number" min="1" max="1000" placeholder="100" />
                                <span asp-validation-for="MaxScore" class="text-danger"></span>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label asp-for="ExamDate" class="form-label">
                                    <i class="bi bi-calendar-date"></i> Exam Date
                                </label>
                                <input asp-for="ExamDate" class="form-control" type="date" />
                                <span asp-validation-for="ExamDate" class="text-danger"></span>
                            </div>
                        </div>

                        <div class="d-grid">
                            <button type="submit" class="btn btn-success btn-lg">
                                <i class="bi bi-check-circle"></i> Schedule Exam
                            </button>
                        </div>
                    </form>
                </div>
                <div class="card-footer text-center">
                    <a class="btn btn-secondary" asp-action="Index">
                        <i class="bi bi-arrow-left"></i> Back to Exams
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
