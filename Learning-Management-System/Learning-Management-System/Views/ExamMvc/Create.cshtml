@{
    ViewData["Title"] = "Schedule Exam";
    var coursesJson = ViewBag.CoursesJson as string ?? "[]";
}

<nav aria-label="breadcrumb" class="mb-3">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a asp-action="Index">Exams</a></li>
        <li class="breadcrumb-item active">Schedule Exam</li>
    </ol>
</nav>

@if (TempData["Error"] != null) { <div class="alert alert-danger">@TempData["Error"]</div> }

<div class="row justify-content-center">
    <div class="col-md-6">
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-white py-3"><h5 class="fw-bold mb-0">📊 Schedule New Exam</h5></div>
            <div class="card-body p-4">
                <form method="post" asp-action="Create">
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Course *</label>
                        <select class="form-select" id="courseSelect" required>
                            <option value="">Select Course</option>
                        </select>
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Subject *</label>
                        <select class="form-select" name="subjectId" id="subjectSelect" required disabled>
                            <option value="">Select Course First</option>
                        </select>
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Exam Title *</label>
                        <input type="text" name="title" class="form-control" required placeholder="e.g., Midterm Examination" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Exam Type *</label>
                        <select name="examType" class="form-select" required>
                            <option value="MIDTERM">Midterm</option>
                            <option value="FINAL">Final</option>
                            <option value="QUIZ">Quiz</option>
                            <option value="PRACTICAL">Practical</option>
                        </select>
                    </div>
                    <div class="row g-3 mb-4">
                        <div class="col-md-6">
                            <label class="form-label fw-semibold">Max Score *</label>
                            <input type="number" name="maxScore" class="form-control" required min="1" value="100" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-semibold">Exam Date *</label>
                            <input type="datetime-local" name="examDate" class="form-control" required />
                        </div>
                    </div>
                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary px-4">Schedule Exam</button>
                        <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
    const courses = @Html.Raw(coursesJson);
    const csel = document.getElementById('courseSelect');
    const ssel = document.getElementById('subjectSelect');

    courses.forEach(c => {
        const opt = document.createElement('option');
        opt.value = c.id; opt.textContent = c.title;
        csel.appendChild(opt);
    });

    csel.addEventListener('change', async function() {
        ssel.innerHTML = '<option value="">Loading...</option>';
        ssel.disabled = true;
        if (!this.value) { ssel.innerHTML = '<option value="">Select Course First</option>'; return; }
        const res = await fetch(`/api/subject/course/${this.value}`);
        const subs = await res.json();
        ssel.innerHTML = '<option value="">Select Subject</option>';
        subs.forEach(s => {
            const opt = document.createElement('option');
            opt.value = s.id; opt.textContent = s.name;
            ssel.appendChild(opt);
        });
        ssel.disabled = false;
    });

    const d = new Date();
    d.setDate(d.getDate() + 14);
    document.querySelector('[name="examDate"]').value = d.toISOString().slice(0, 16);
</script>
}
