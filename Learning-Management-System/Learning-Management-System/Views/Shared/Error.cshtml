@model ErrorViewModel
@{
    ViewData["Title"] = "Error";
}

<div style="display:flex;flex-direction:column;align-items:center;justify-content:center;min-height:60vh;text-align:center;padding:40px">
    <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="var(--rose)" stroke-width="1.5" style="margin-bottom:16px"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
    <div style="font-size:22px;font-weight:700;color:var(--text);margin-bottom:8px">Something went wrong</div>
    <div style="font-size:14px;color:var(--text-muted);margin-bottom:12px;max-width:400px">An unexpected error occurred while processing your request.</div>
    @if (Model?.ShowRequestId == true)
    {
        <div style="font-family:var(--font-mono);font-size:12px;color:var(--text-faint);background:var(--bg-muted);padding:6px 12px;border-radius:6px;margin-bottom:24px">
            Request ID: @Model.RequestId
        </div>
    }
    <div style="display:flex;gap:10px">
        <a href="javascript:history.back()" class="btn-lms-ghost">
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="15 18 9 12 15 6"/></svg>
            Go Back
        </a>
        <a asp-controller="Home" asp-action="Index" class="btn-lms-primary">Dashboard</a>
    </div>
</div>
