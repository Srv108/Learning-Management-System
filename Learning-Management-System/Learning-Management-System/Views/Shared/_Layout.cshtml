<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - EduCore LMS</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=DM+Sans:opsz,wght@9..40,300;9..40,400;9..40,500;9..40,600;9..40,700&family=Playfair+Display:ital,wght@0,600;0,700;1,600&family=DM+Mono:wght@400;500&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <script type="importmap"></script>
</head>
<body>
@{
    var userEmail    = Context.Session.GetString("UserEmail");
    var jwtToken     = Context.Session.GetString("JwtToken");
    var userRole     = Context.Session.GetString("UserRole") ?? "Guest";
    var userFullName = Context.Session.GetString("UserFullName") ?? userEmail ?? "Guest";
    var isAuth       = !string.IsNullOrEmpty(userEmail) && !string.IsNullOrEmpty(jwtToken);

    bool IsStudent()        => userRole == "Student";
    bool IsTeacher()        => userRole == "Teacher";
    bool IsCoordinator()    => userRole == "CourseCoordinator";
    bool IsExamController() => userRole == "ExamController";
    bool IsAdmin()          => userRole == "Admin";
    bool CanManageCourse()  => IsTeacher() || IsCoordinator() || IsAdmin();
    bool CanManageExam()    => IsExamController() || IsCoordinator() || IsAdmin() || IsTeacher();
    bool CanViewAnalytics() => IsTeacher() || IsCoordinator() || IsAdmin() || IsExamController();

    string AvatarClass() => userRole switch {
        "Teacher"           => "av-teal",
        "CourseCoordinator" => "av-amber",
        "ExamController"    => "av-purple",
        "Admin"             => "av-rose",
        _                   => "av-sky"
    };
    string RoleChipClass() => userRole switch {
        "Admin"             => "role-admin",
        "Teacher"           => "role-teacher",
        "CourseCoordinator" => "role-coordinator",
        "ExamController"    => "role-examcontroller",
        _                   => "role-student"
    };
    string RoleLabel() => userRole switch {
        "CourseCoordinator" => "Coordinator",
        "ExamController"    => "Exam Ctrl",
        _ => userRole
    };
    string AvatarLetter() => (userFullName?.Length > 0 ? userFullName[0].ToString().ToUpper() : "?");
    var currentPath = Context.Request.Path.Value ?? "";
    bool IsActive(string path) => currentPath.StartsWith(path, StringComparison.OrdinalIgnoreCase);
}

@if (!isAuth)
{
    @RenderBody()
}
else
{
<!-- ── SIDEBAR ── -->
<aside class="lms-sidebar">
    <div class="sidebar-brand">
        <div class="brand-icon">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2.2">
                <path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/>
                <path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/>
            </svg>
        </div>
        <div>
            <div class="brand-name">EduCore</div>
            <div class="brand-tagline">Learning Management</div>
        </div>
    </div>

    <div class="sidebar-user">
        <div class="sidebar-user-avatar lms-avatar @AvatarClass()">@AvatarLetter()</div>
        <div style="flex:1;min-width:0">
            <div class="sidebar-user-name" style="white-space:nowrap;overflow:hidden;text-overflow:ellipsis">@userFullName</div>
            <div class="sidebar-user-role">@RoleLabel()</div>
        </div>
    </div>

    <nav class="sidebar-nav">
        <div class="nav-section-label">Overview</div>
        <a class="sidebar-link @(IsActive("/Home/Index") || currentPath == "/" ? "active" : "")"
           asp-controller="Home" asp-action="Index">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/>
                <rect x="3" y="14" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/>
            </svg>
            <span>Dashboard</span>
        </a>

        @if (IsStudent())
        {
        <!-- ── STUDENT: My Learning ── -->
        <div class="nav-section-label">My Learning</div>
        <a class="sidebar-link @(IsActive("/EnrollmentMvc/MyEnrollments") ? "active" : "")"
           asp-controller="EnrollmentMvc" asp-action="MyEnrollments">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/>
                <circle cx="9" cy="7" r="4"/>
            </svg>
            <span>My Enrollments</span>
        </a>
        <a class="sidebar-link @(IsActive("/AttendanceMvc/MyAttendance") ? "active" : "")"
           asp-controller="AttendanceMvc" asp-action="MyAttendance">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <polyline points="9 11 12 14 22 4"/>
                <path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11"/>
            </svg>
            <span>My Attendance</span>
        </a>
        <a class="sidebar-link @(IsActive("/AssignmentMvc/MyAssignments") ? "active" : "")"
           asp-controller="AssignmentMvc" asp-action="MyAssignments">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
                <polyline points="14 2 14 8 20 8"/>
            </svg>
            <span>My Assignments</span>
        </a>
        <a class="sidebar-link @(IsActive("/AssignmentMvc/MyGrades") ? "active" : "")"
           asp-controller="AssignmentMvc" asp-action="MyGrades">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M12 20h9"/><path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z"/>
            </svg>
            <span>My Grades</span>
        </a>
        <a class="sidebar-link @(IsActive("/ExamMvc/MyResults") ? "active" : "")"
           asp-controller="ExamMvc" asp-action="MyResults">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <circle cx="12" cy="12" r="10"/>
                <polyline points="12 6 12 12 16 14"/>
            </svg>
            <span>Exam Results</span>
        </a>
        <a class="sidebar-link @(IsActive("/ProgressMvc/MyProgress") ? "active" : "")"
           asp-controller="ProgressMvc" asp-action="MyProgress">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <line x1="18" y1="20" x2="18" y2="10"/>
                <line x1="12" y1="20" x2="12" y2="4"/>
                <line x1="6"  y1="20" x2="6"  y2="14"/>
            </svg>
            <span>My Progress</span>
        </a>
        }

        @if (IsTeacher())
        {
        <!-- ── TEACHER: Teaching + Analytics ── -->
        <div class="nav-section-label">Teaching</div>
        <a class="sidebar-link @(IsActive("/CourseMvc") ? "active" : "")"
           asp-controller="CourseMvc" asp-action="Index">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/>
                <path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/>
            </svg>
            <span>Courses</span>
        </a>
        <a class="sidebar-link @(IsActive("/AttendanceMvc") ? "active" : "")"
           asp-controller="AttendanceMvc" asp-action="Index">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <polyline points="9 11 12 14 22 4"/>
                <path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11"/>
            </svg>
            <span>Attendance</span>
        </a>
        <a class="sidebar-link @(IsActive("/AssignmentMvc") ? "active" : "")"
           asp-controller="AssignmentMvc" asp-action="Index">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
                <polyline points="14 2 14 8 20 8"/>
            </svg>
            <span>Assignments</span>
        </a>
        <a class="sidebar-link @(IsActive("/ExamMvc") ? "active" : "")"
           asp-controller="ExamMvc" asp-action="Index">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <circle cx="12" cy="12" r="10"/>
                <polyline points="12 6 12 12 16 14"/>
            </svg>
            <span>Exams</span>
        </a>
        <div class="nav-section-label">Analytics</div>
        <a class="sidebar-link @(IsActive("/ProgressMvc/Analytics") ? "active" : "")"
           asp-controller="ProgressMvc" asp-action="Analytics">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <line x1="18" y1="20" x2="18" y2="10"/>
                <line x1="12" y1="20" x2="12" y2="4"/>
                <line x1="6"  y1="20" x2="6"  y2="14"/>
            </svg>
            <span>Analytics</span>
        </a>
        <a class="sidebar-link @(IsActive("/ProgressMvc/AtRisk") ? "active" : "")"
           asp-controller="ProgressMvc" asp-action="AtRisk">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/>
                <line x1="12" y1="9" x2="12" y2="13"/>
                <line x1="12" y1="17" x2="12.01" y2="17"/>
            </svg>
            <span>At-Risk Students</span>
        </a>
        }

        @if (IsExamController())
        {
        <!-- ── EXAM CONTROLLER: Examinations only ── -->
        <div class="nav-section-label">Examinations</div>
        <a class="sidebar-link @(IsActive("/ExamMvc/Index") || (IsActive("/ExamMvc") && !IsActive("/ExamMvc/RecordResults")) ? "active" : "")"
           asp-controller="ExamMvc" asp-action="Index">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <circle cx="12" cy="12" r="10"/>
                <polyline points="12 6 12 12 16 14"/>
            </svg>
            <span>Exams</span>
        </a>
        <a class="sidebar-link @(IsActive("/ExamMvc/RecordResults") ? "active" : "")"
           asp-controller="ExamMvc" asp-action="RecordResults">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M12 20h9"/><path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z"/>
            </svg>
            <span>Record Results</span>
        </a>
        }

        @if (IsCoordinator() || IsAdmin())
        {
        <!-- ── COORDINATOR / ADMIN: Full Academic + Administration ── -->
        <div class="nav-section-label">Academic</div>
        <a class="sidebar-link @(IsActive("/CourseMvc") ? "active" : "")"
           asp-controller="CourseMvc" asp-action="Index">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/>
                <path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/>
            </svg>
            <span>Courses</span>
        </a>
        <a class="sidebar-link @(IsActive("/EnrollmentMvc/Index") || IsActive("/EnrollmentMvc/Enroll") ? "active" : "")"
           asp-controller="EnrollmentMvc" asp-action="Index">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/>
                <circle cx="9" cy="7" r="4"/>
                <path d="M23 21v-2a4 4 0 0 0-3-3.87"/>
                <path d="M16 3.13a4 4 0 0 1 0 7.75"/>
            </svg>
            <span>Enrollments</span>
        </a>
        <a class="sidebar-link @(IsActive("/AttendanceMvc") ? "active" : "")"
           asp-controller="AttendanceMvc" asp-action="Index">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <polyline points="9 11 12 14 22 4"/>
                <path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11"/>
            </svg>
            <span>Attendance</span>
        </a>
        <a class="sidebar-link @(IsActive("/AssignmentMvc") ? "active" : "")"
           asp-controller="AssignmentMvc" asp-action="Index">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
                <polyline points="14 2 14 8 20 8"/>
            </svg>
            <span>Assignments</span>
        </a>
        <a class="sidebar-link @(IsActive("/ExamMvc") ? "active" : "")"
           asp-controller="ExamMvc" asp-action="Index">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <circle cx="12" cy="12" r="10"/>
                <polyline points="12 6 12 12 16 14"/>
            </svg>
            <span>Exams</span>
        </a>
        <div class="nav-section-label">Analytics</div>
        <a class="sidebar-link @(IsActive("/ProgressMvc/Analytics") ? "active" : "")"
           asp-controller="ProgressMvc" asp-action="Analytics">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <line x1="18" y1="20" x2="18" y2="10"/>
                <line x1="12" y1="20" x2="12" y2="4"/>
                <line x1="6"  y1="20" x2="6"  y2="14"/>
            </svg>
            <span>Analytics</span>
        </a>
        <a class="sidebar-link @(IsActive("/ProgressMvc/AtRisk") ? "active" : "")"
           asp-controller="ProgressMvc" asp-action="AtRisk">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/>
                <line x1="12" y1="9" x2="12" y2="13"/>
                <line x1="12" y1="17" x2="12.01" y2="17"/>
            </svg>
            <span>At-Risk Students</span>
        </a>
        <div class="nav-section-label">Administration</div>
        <a class="sidebar-link @(IsActive("/AdminMvc/Users") ? "active" : "")"
           asp-controller="AdminMvc" asp-action="Users">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/>
                <circle cx="12" cy="7" r="4"/>
            </svg>
            <span>User Management</span>
        </a>
        <a class="sidebar-link @(IsActive("/AdminMvc/AssignRole") ? "active" : "")"
           asp-controller="AdminMvc" asp-action="AssignRole">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
            </svg>
            <span>Assign Roles</span>
        </a>
        <a class="sidebar-link @(IsActive("/ProgressMvc/SeedData") ? "active" : "")"
           asp-controller="ProgressMvc" asp-action="SeedData">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <ellipse cx="12" cy="5" rx="9" ry="3"/>
                <path d="M21 12c0 1.66-4 3-9 3s-9-1.34-9-3"/>
                <path d="M3 5v14c0 1.66 4 3 9 3s9-1.34 9-3V5"/>
            </svg>
            <span>Seed Data</span>
        </a>
        @if (IsAdmin())
        {
        <a class="sidebar-link @(IsActive("/ProgressMvc/SystemAnalytics") ? "active" : "")"
           asp-controller="ProgressMvc" asp-action="SystemAnalytics">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <circle cx="12" cy="12" r="3"/>
                <path d="M19.07 4.93a10 10 0 0 1 0 14.14M4.93 4.93a10 10 0 0 0 0 14.14"/>
            </svg>
            <span>System Analytics</span>
        </a>
        }
        }
    </nav>

    <div class="sidebar-footer">
        <a href="/swagger" target="_blank" class="sidebar-link">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
                <polyline points="14 2 14 8 20 8"/>
                <line x1="16" y1="13" x2="8" y2="13"/>
                <line x1="16" y1="17" x2="8" y2="17"/>
            </svg>
            <span>API Docs</span>
        </a>
        <form method="post" asp-action="Logout" asp-controller="AuthMvc" style="margin:0">
            <button type="submit" class="sidebar-link" style="width:100%;background:none;border:none;cursor:pointer;text-align:left">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/>
                    <polyline points="16 17 21 12 16 7"/>
                    <line x1="21" y1="12" x2="9" y2="12"/>
                </svg>
                <span>Logout</span>
            </button>
        </form>
    </div>
</aside>

<!-- ── MAIN ── -->
<div class="lms-main">
    <!-- Topbar -->
    <header class="lms-topbar">
        <div class="topbar-breadcrumb">
            @if (ViewData["Breadcrumb"] != null)
            {
                @Html.Raw(ViewData["Breadcrumb"])
            }
            else
            {
                <span class="current">@(ViewData["Title"] ?? "Dashboard")</span>
            }
        </div>
        <div class="topbar-spacer"></div>

        @if (TempData["Success"] != null)
        {
            <div style="display:flex;align-items:center;gap:6px;padding:6px 12px;background:var(--green-soft);border:1px solid rgba(22,163,74,0.2);border-radius:8px;font-size:12.5px;color:var(--green);font-weight:500">
                <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>
                @TempData["Success"]
            </div>
        }
        @if (TempData["Error"] != null)
        {
            <div style="display:flex;align-items:center;gap:6px;padding:6px 12px;background:var(--rose-soft);border:1px solid rgba(225,29,72,0.2);border-radius:8px;font-size:12.5px;color:var(--rose);font-weight:500">
                <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><circle cx="12" cy="12" r="10"/><line x1="15" y1="9" x2="9" y2="15"/><line x1="9" y1="9" x2="15" y2="15"/></svg>
                @TempData["Error"]
            </div>
        }

        <div class="topbar-icon-btn" id="profileDropdownTrigger" onclick="toggleProfileDropdown(event)" title="View profile" style="position:relative;cursor:pointer">
            <div class="lms-avatar @AvatarClass()" style="width:28px;height:28px;font-size:11px">@AvatarLetter()</div>
            <div id="profileDropdown" style="display:none;position:absolute;top:calc(100% + 10px);right:0;background:var(--bg-card);border:1px solid var(--border);border-radius:12px;box-shadow:0 8px 28px rgba(13,27,62,0.13);min-width:230px;z-index:2000;padding:16px 16px 10px">
                <div style="display:flex;align-items:center;gap:12px;margin-bottom:14px;padding-bottom:14px;border-bottom:1px solid var(--border)">
                    <div class="lms-avatar @AvatarClass()" style="width:42px;height:42px;font-size:17px;flex-shrink:0">@AvatarLetter()</div>
                    <div style="min-width:0">
                        <div style="font-weight:600;font-size:14px;color:var(--navy-deep);white-space:nowrap;overflow:hidden;text-overflow:ellipsis">@userFullName</div>
                        <div style="font-size:12px;color:var(--text-muted);white-space:nowrap;overflow:hidden;text-overflow:ellipsis;margin-top:2px">@userEmail</div>
                        <span class="role-chip @RoleChipClass()" style="margin-top:6px;display:inline-block">@RoleLabel()</span>
                    </div>
                </div>
                <form method="post" asp-action="Logout" asp-controller="AuthMvc" style="margin:0">
                    <button type="submit" style="display:flex;align-items:center;gap:8px;width:100%;padding:8px 6px;border:none;background:none;border-radius:8px;color:var(--rose);font-size:13px;font-weight:500;cursor:pointer;text-align:left;transition:background 0.15s"
                            onmouseover="this.style.background='var(--rose-soft)'" onmouseout="this.style.background='transparent'">
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/></svg>
                        Sign Out
                    </button>
                </form>
            </div>
        </div>
    </header>
    <script>
    function toggleProfileDropdown(e) {
        e.stopPropagation();
        const d = document.getElementById('profileDropdown');
        d.style.display = d.style.display === 'none' ? 'block' : 'none';
    }
    document.addEventListener('click', function(e) {
        const trigger = document.getElementById('profileDropdownTrigger');
        if (trigger && !trigger.contains(e.target)) {
            const d = document.getElementById('profileDropdown');
            if (d) d.style.display = 'none';
        }
    });
    </script>

    <!-- Page content -->
    <main class="lms-page">
        @RenderBody()
    </main>

    <footer style="padding:12px 26px;border-top:1px solid var(--border);background:var(--bg-card);flex-shrink:0">
        <div style="display:flex;align-items:center;justify-content:space-between">
            <span style="font-family:var(--font-mono);font-size:10.5px;color:var(--text-faint)">EduCore LMS · Academic Year 2025–26</span>
            <span class="role-chip @RoleChipClass()">@userRole</span>
        </div>
    </footer>
</div>
}

<script src="~/lib/jquery/dist/jquery.min.js"></script>
<script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
<script src="~/js/site.js" asp-append-version="true"></script>
@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
