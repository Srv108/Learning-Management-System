@{
    ViewData["Title"] = "User Management";
    var usersJson = ViewBag.UsersJson as string ?? "[]";
    var roleCountsJson = ViewBag.RoleCountsJson as string ?? "{}";
    var totalUsers = ViewBag.TotalUsers ?? 0;
    var search = ViewBag.Search as string ?? "";
    var filterRole = ViewBag.FilterRole as string ?? "";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h4 class="fw-bold mb-1">👥 User Management</h4>
        <p class="text-muted mb-0">@totalUsers total registered users</p>
    </div>
    <a asp-action="AssignRole" class="btn btn-primary">+ Assign Role</a>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show">@TempData["Success"]<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show">@TempData["Error"]<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>
}

<!-- Role Stats -->
<div class="row g-3 mb-4" id="roleStats"></div>

<!-- Filters -->
<div class="card border-0 shadow-sm mb-4">
    <div class="card-body py-3">
        <form method="get" asp-action="Users" class="row g-2 align-items-end">
            <div class="col-md-5">
                <label class="form-label small fw-semibold">Search</label>
                <input type="text" name="search" class="form-control" placeholder="Name or email..." value="@search" />
            </div>
            <div class="col-md-4">
                <label class="form-label small fw-semibold">Filter by Role</label>
                <select name="filterRole" class="form-select">
                    <option value="">All Roles</option>
                    @foreach (var r in new[] { "Student", "Teacher", "CourseCoordinator", "ExamController", "Admin" })
                    {
                        <option value="@r" selected="@(filterRole == r ? "selected" : null)">@r</option>
                    }
                </select>
            </div>
            <div class="col-md-3 d-flex gap-2">
                <button type="submit" class="btn btn-primary w-100">Filter</button>
                <a asp-action="Users" class="btn btn-outline-secondary">Reset</a>
            </div>
        </form>
    </div>
</div>

<!-- User Table -->
<div class="card border-0 shadow-sm">
    <div class="card-header bg-white py-3 d-flex justify-content-between align-items-center">
        <h6 class="fw-bold mb-0">Users</h6>
        <span class="badge bg-primary" id="userCount">0</span>
    </div>
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead class="table-light">
                    <tr><th>Name</th><th>Email</th><th>Role</th><th>Actions</th></tr>
                </thead>
                <tbody id="usersBody">
                    <tr><td colspan="4" class="text-center py-4 text-muted">Loading...</td></tr>
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
<script>
const users = @Html.Raw(usersJson);
const roleCounts = @Html.Raw(roleCountsJson);
const roleColors = {
    Student: { bg: '#dbeafe', color: '#1d4ed8', icon: '👨‍🎓' },
    Teacher: { bg: '#d1fae5', color: '#065f46', icon: '👨‍🏫' },
    CourseCoordinator: { bg: '#fef3c7', color: '#92400e', icon: '📋' },
    ExamController: { bg: '#fce7f3', color: '#9d174d', icon: '📝' },
    Admin: { bg: '#fee2e2', color: '#991b1b', icon: '⚙️' }
};

// Role stat cards
const statsEl = document.getElementById('roleStats');
Object.entries(roleCounts).forEach(([role, count]) => {
    const c = roleColors[role] || { bg: '#f3f4f6', color: '#374151', icon: '👤' };
    statsEl.innerHTML += `
        <div class="col-6 col-md-2">
            <div class="card border-0 shadow-sm text-center py-3">
                <div class="fs-2 mb-1">${c.icon}</div>
                <div class="fw-bold fs-4" style="color:${c.color}">${count}</div>
                <div class="text-muted small">${role==='CourseCoordinator'?'Coordinator':role==='ExamController'?'Exam Ctrl':role}</div>
            </div>
        </div>`;
});

const badge = (role) => {
    const c = roleColors[role] || { bg: '#f3f4f6', color: '#374151' };
    return `<span class="badge" style="background:${c.bg};color:${c.color}">${role}</span>`;
};

document.getElementById('userCount').textContent = users.length;
const tbody = document.getElementById('usersBody');

if (!users || users.length === 0) {
    tbody.innerHTML = `<tr><td colspan="4" class="text-center py-5 text-muted">No users found.</td></tr>`;
} else {
    tbody.innerHTML = users.map(u => `
        <tr>
            <td>
                <div class="d-flex align-items-center gap-2">
                    <span class="rounded-circle d-inline-flex align-items-center justify-content-center fw-bold flex-shrink-0"
                          style="width:36px;height:36px;background:#ede9fe;color:#4f46e5;font-size:.85rem">
                        ${((u.fullName||u.email||'?')[0]).toUpperCase()}
                    </span>
                    <div class="fw-semibold">${u.fullName||'-'}</div>
                </div>
            </td>
            <td><small class="text-muted">${u.email||''}</small></td>
            <td>${badge(u.role||'No Role')}</td>
            <td>
                <div class="d-flex gap-1 flex-wrap">
                    <a href="/AdminMvc/AssignRole" class="btn btn-sm btn-outline-primary py-0">+ Role</a>
                    ${u.role&&u.role!=='No Role'?`
                    <form method="post" action="/AdminMvc/RemoveRole"
                          onsubmit="return confirm('Remove role from ${(u.email||'').replace(/'/g,"\\'")}?')">
                        <input type="hidden" name="userId" value="${u.id}" />
                        <input type="hidden" name="role" value="${u.role}" />
                        <button class="btn btn-sm btn-outline-danger py-0">✕ ${u.role}</button>
                    </form>`:''}
                </div>
            </td>
        </tr>`).join('');
}
</script>
}
