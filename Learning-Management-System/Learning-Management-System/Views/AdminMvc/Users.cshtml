@{
    ViewData["Title"] = "User Management";
    var usersJson = ViewBag.UsersJson as string ?? "[]";
    var roleCountsJson = ViewBag.RoleCountsJson as string ?? "{}";
    var totalUsers = ViewBag.TotalUsers ?? 0;
    var search = ViewBag.Search as string ?? "";
    var filterRole = ViewBag.FilterRole as string ?? "";
}

<div class="page-header">
    <div>
        <div class="page-title">User Management</div>
        <div class="page-sub">@totalUsers total registered users</div>
    </div>
    <a asp-action="AssignRole" class="btn-lms-primary">
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
        Assign Role
    </a>
</div>

<!-- Role Stats -->
<div id="roleStats" class="stats-grid-5" style="margin-bottom:24px"></div>

<!-- Filters -->
<div class="lms-card" style="margin-bottom:20px">
    <form method="get" asp-action="Users" style="display:grid;grid-template-columns:1fr 1fr auto;gap:12px;align-items:flex-end">
        <div class="lms-form-group" style="margin-bottom:0">
            <label class="lms-label">Search</label>
            <input type="text" name="search" class="lms-input" placeholder="Name or email..." value="@search" />
        </div>
        <div class="lms-form-group" style="margin-bottom:0">
            <label class="lms-label">Filter by Role</label>
            <select name="filterRole" class="lms-select">
                <option value="">All Roles</option>
                @foreach (var r in new[] { "Student", "Teacher", "CourseCoordinator", "ExamController", "Admin" })
                {
                    <option value="@r" selected="@(filterRole == r ? "selected" : null)">@r</option>
                }
            </select>
        </div>
        <div style="display:flex;gap:8px">
            <button type="submit" class="btn-lms-primary">Filter</button>
            <a asp-action="Users" class="btn-lms-ghost">Reset</a>
        </div>
    </form>
</div>

<div class="lms-card" style="padding:0">
    <div style="display:flex;justify-content:space-between;align-items:center;padding:16px 20px;border-bottom:1px solid var(--border)">
        <span style="font-weight:600;font-size:14px">Users</span>
        <span class="lms-badge" style="background:var(--sky-soft);color:var(--sky)" id="userCount">0</span>
    </div>
    <div style="overflow-x:auto">
        <table class="lms-table">
            <thead>
                <tr><th>Name</th><th>Email</th><th>Role</th><th>Actions</th></tr>
            </thead>
            <tbody id="usersBody">
                <tr><td colspan="4" style="text-align:center;padding:32px;color:var(--text-muted)">Loading...</td></tr>
            </tbody>
        </table>
    </div>
</div>

@section Scripts {
<script>
const users = @Html.Raw(usersJson);
const roleCounts = @Html.Raw(roleCountsJson);

const roleStyles = {
    Student: { bg: 'var(--sky-soft)', color: 'var(--sky)' },
    Teacher: { bg: 'var(--green-soft)', color: 'var(--green)' },
    CourseCoordinator: { bg: 'var(--amber-soft)', color: 'var(--amber)' },
    ExamController: { bg: '#f3e8ff', color: '#7c3aed' },
    Admin: { bg: 'var(--rose-soft)', color: 'var(--rose)' }
};

// Role stat cards
const statsEl = document.getElementById('roleStats');
Object.entries(roleCounts).forEach(([role, count]) => {
    const s = roleStyles[role] || { bg: 'var(--bg-muted)', color: 'var(--text-muted)' };
    statsEl.innerHTML += `
        <div class="stat-card" style="text-align:center">
            <div class="stat-val" style="color:${s.color}">${count}</div>
            <div class="stat-label">${role === 'CourseCoordinator' ? 'Coordinator' : role === 'ExamController' ? 'Exam Ctrl' : role}</div>
        </div>`;
});

const roleBadge = (role) => {
    const s = roleStyles[role] || { bg: 'var(--bg-muted)', color: 'var(--text-muted)' };
    return `<span class="lms-badge" style="background:${s.bg};color:${s.color}">${role}</span>`;
};

const avatarColor = (role) => {
    const map = { Student: 'av-sky', Teacher: 'av-teal', CourseCoordinator: 'av-amber', ExamController: 'av-purple', Admin: 'av-rose' };
    return map[role] || 'av-sky';
};

document.getElementById('userCount').textContent = users.length;
const tbody = document.getElementById('usersBody');

if (!users || users.length === 0) {
    tbody.innerHTML = `<tr><td colspan="4" style="text-align:center;padding:40px;color:var(--text-muted)">No users found.</td></tr>`;
} else {
    tbody.innerHTML = users.map(u => `
        <tr>
            <td>
                <div style="display:flex;align-items:center;gap:10px">
                    <div class="lms-avatar ${avatarColor(u.role)}" style="width:32px;height:32px;font-size:11px;flex-shrink:0">
                        ${((u.fullName||u.email||'?')[0]).toUpperCase()}
                    </div>
                    <div style="font-weight:600">${u.fullName||'-'}</div>
                </div>
            </td>
            <td style="font-size:12.5px;color:var(--text-muted)">${u.email||''}</td>
            <td>${roleBadge(u.role||'No Role')}</td>
            <td>
                <div style="display:flex;gap:6px;flex-wrap:wrap;align-items:center">
                    <a href="/AdminMvc/AssignRole" class="btn-lms-ghost btn-lms-sm">+ Role</a>
                    ${u.role&&u.role!=='No Role'?`
                    <form method="post" action="/AdminMvc/RemoveRole" style="display:inline"
                          onsubmit="return confirm('Remove role from ${(u.email||'').replace(/'/g,"\\'")}?')">
                        <input type="hidden" name="userId" value="${u.id}" />
                        <input type="hidden" name="role" value="${u.role}" />
                        <button class="btn-lms-danger btn-lms-sm">Remove ${u.role}</button>
                    </form>`:''}
                </div>
            </td>
        </tr>`).join('');
}
</script>
<style>
.stats-grid-5 { display:grid;grid-template-columns:repeat(5,1fr);gap:16px }
@@media(max-width:960px){.stats-grid-5{grid-template-columns:repeat(3,1fr)}}
@@media(max-width:600px){.stats-grid-5{grid-template-columns:repeat(2,1fr)}}
</style>
}
