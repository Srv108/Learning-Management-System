@{
    ViewData["Title"] = "Assign Role";
}

<nav aria-label="breadcrumb" class="mb-3">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a asp-action="Users">Admin</a></li>
        <li class="breadcrumb-item active">Assign Role</li>
    </ol>
</nav>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show">
        @TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show">
        @TempData["Error"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="row justify-content-center">
    <div class="col-md-6">
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-white py-3">
                <h5 class="fw-bold mb-0">🔑 Assign User Role</h5>
            </div>
            <div class="card-body p-4">
                <div class="alert alert-info small mb-4">
                    <strong>Note:</strong> This will add the specified role to the user. Users can have multiple roles.
                    Use this to promote students to teachers, or to create course coordinators.
                </div>
                <form method="post" asp-action="AssignRole">
                    <div class="mb-3">
                        <label class="form-label fw-semibold">User Email *</label>
                        <input type="email" name="email" class="form-control" required
                               placeholder="user@example.com" />
                        <div class="form-text">Enter the email address of the user to assign the role to</div>
                    </div>
                    <div class="mb-4">
                        <label class="form-label fw-semibold">Role *</label>
                        <select name="role" class="form-select" required>
                            <option value="">Select a role...</option>
                            <option value="Student">Student</option>
                            <option value="Teacher">Teacher</option>
                            <option value="CourseCoordinator">Course Coordinator</option>
                            <option value="ExamController">Exam Controller</option>
                            <option value="Admin">Admin</option>
                        </select>
                    </div>
                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary px-4">Assign Role</button>
                        <a asp-action="Users" class="btn btn-outline-secondary">Cancel</a>
                    </div>
                </form>
            </div>
        </div>

        <!-- Role descriptions -->
        <div class="card border-0 shadow-sm mt-4">
            <div class="card-header bg-white py-3 fw-semibold">Role Descriptions</div>
            <div class="card-body p-3">
                <div class="d-flex align-items-start gap-2 mb-2">
                    <span class="badge" style="background:#dbeafe;color:#1d4ed8;white-space:nowrap">Student</span>
                    <small class="text-muted">Can view own enrollments, attendance, assignments, grades & progress</small>
                </div>
                <div class="d-flex align-items-start gap-2 mb-2">
                    <span class="badge" style="background:#d1fae5;color:#065f46;white-space:nowrap">Teacher</span>
                    <small class="text-muted">Can create courses, mark attendance, create & grade assignments, schedule exams</small>
                </div>
                <div class="d-flex align-items-start gap-2 mb-2">
                    <span class="badge" style="background:#fef3c7;color:#92400e;white-space:nowrap">CourseCoordinator</span>
                    <small class="text-muted">Can manage enrollments, all courses/batches, delete resources</small>
                </div>
                <div class="d-flex align-items-start gap-2 mb-2">
                    <span class="badge" style="background:#fce7f3;color:#9d174d;white-space:nowrap">ExamController</span>
                    <small class="text-muted">Can schedule exams and record exam results</small>
                </div>
                <div class="d-flex align-items-start gap-2">
                    <span class="badge" style="background:#fee2e2;color:#991b1b;white-space:nowrap">Admin</span>
                    <small class="text-muted">Full system access including user management and role assignment</small>
                </div>
            </div>
        </div>
    </div>
</div>
