@{
    ViewData["Title"] = "Course Details";
    var userRole = ViewBag.UserRole as string ?? "Student";
    var courseId = ViewBag.CourseId;
    var courseJson = ViewBag.CourseJson as string ?? "{}";
    var subjectsJson = ViewBag.SubjectsJson as string ?? "[]";
    var batchesJson = ViewBag.BatchesJson as string ?? "[]";
    bool canManage = userRole == "Teacher" || userRole == "CourseCoordinator" || userRole == "Admin";
    bool canDelete = userRole == "CourseCoordinator" || userRole == "Admin";
    ViewData["Breadcrumb"] = "<a href='/CourseMvc/Index' style='color:var(--text-muted);text-decoration:none'>Courses</a> <span style='margin:0 6px;color:var(--border-strong)'>›</span> <span class='current'>Details</span>";
}

<div id="courseDetail"></div>

<div style="display:grid;grid-template-columns:1fr 1fr;gap:20px;margin-top:20px" id="detailGrid">
    <div class="lms-card" style="padding:0">
        <div style="display:flex;justify-content:space-between;align-items:center;padding:16px 20px;border-bottom:1px solid var(--border)">
            <span style="font-weight:600;font-size:14px">Subjects</span>
            @if (canManage)
            {
                <button class="btn-lms-primary btn-lms-sm" onclick="document.getElementById('addSubjectModal').style.display='flex'">+ Add Subject</button>
            }
        </div>
        <div id="subjectsContainer" style="padding:12px 0">
            <div style="text-align:center;padding:24px;color:var(--text-muted)">Loading...</div>
        </div>
    </div>

    <div class="lms-card" style="padding:0">
        <div style="display:flex;justify-content:space-between;align-items:center;padding:16px 20px;border-bottom:1px solid var(--border)">
            <span style="font-weight:600;font-size:14px">Batches</span>
            @if (canManage)
            {
                <button class="btn-lms-primary btn-lms-sm" onclick="document.getElementById('addBatchModal').style.display='flex'">+ Add Batch</button>
            }
        </div>
        <div id="batchesContainer" style="padding:12px 0">
            <div style="text-align:center;padding:24px;color:var(--text-muted)">Loading...</div>
        </div>
    </div>
</div>

@if (canManage)
{
    <!-- Add Subject Modal -->
    <div id="addSubjectModal" style="display:none;position:fixed;inset:0;background:rgba(0,0,0,0.5);z-index:1000;align-items:center;justify-content:center">
        <div class="lms-card" style="width:480px;max-width:90vw">
            <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:20px">
                <span style="font-weight:600;font-size:16px">Add Subject</span>
                <button onclick="document.getElementById('addSubjectModal').style.display='none'" style="background:none;border:none;cursor:pointer;color:var(--text-muted);font-size:20px;line-height:1">&times;</button>
            </div>
            <form method="post" asp-action="AddSubject" style="display:flex;flex-direction:column;gap:14px">
                <input type="hidden" name="courseId" value="@courseId" />
                <div class="lms-form-group">
                    <label class="lms-label">Subject Name <span style="color:var(--rose)">*</span></label>
                    <input type="text" name="name" class="lms-input" required placeholder="e.g., Data Structures" />
                </div>
                <div class="lms-form-group">
                    <label class="lms-label">Description</label>
                    <textarea name="description" class="lms-textarea" rows="2" placeholder="Brief description"></textarea>
                </div>
                <div style="display:flex;gap:10px;justify-content:flex-end">
                    <button type="button" onclick="document.getElementById('addSubjectModal').style.display='none'" class="btn-lms-ghost">Cancel</button>
                    <button type="submit" class="btn-lms-primary">Add Subject</button>
                </div>
            </form>
        </div>
    </div>

    <!-- Add Batch Modal -->
    <div id="addBatchModal" style="display:none;position:fixed;inset:0;background:rgba(0,0,0,0.5);z-index:1000;align-items:center;justify-content:center">
        <div class="lms-card" style="width:480px;max-width:90vw">
            <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:20px">
                <span style="font-weight:600;font-size:16px">Add Batch</span>
                <button onclick="document.getElementById('addBatchModal').style.display='none'" style="background:none;border:none;cursor:pointer;color:var(--text-muted);font-size:20px;line-height:1">&times;</button>
            </div>
            <form method="post" asp-action="AddBatch" style="display:flex;flex-direction:column;gap:14px">
                <input type="hidden" name="courseId" value="@courseId" />
                <div class="lms-form-group">
                    <label class="lms-label">Batch Name <span style="color:var(--rose)">*</span></label>
                    <input type="text" name="batchName" class="lms-input" required placeholder="e.g., Batch 2026-A" />
                </div>
                <div class="lms-form-group">
                    <label class="lms-label">Start Date <span style="color:var(--rose)">*</span></label>
                    <input type="date" name="startDate" class="lms-input" required />
                </div>
                <div class="lms-form-group">
                    <label class="lms-label">End Date <span style="color:var(--rose)">*</span></label>
                    <input type="date" name="endDate" class="lms-input" required />
                </div>
                <div style="display:flex;gap:10px;justify-content:flex-end">
                    <button type="button" onclick="document.getElementById('addBatchModal').style.display='none'" class="btn-lms-ghost">Cancel</button>
                    <button type="submit" class="btn-lms-primary">Add Batch</button>
                </div>
            </form>
        </div>
    </div>
}

@section Scripts {
<script>
    const course = @Html.Raw(courseJson);
    const subjects = @Html.Raw(subjectsJson);
    const batches = @Html.Raw(batchesJson);
    const canManage = @Html.Raw(canManage.ToString().ToLower());
    const canDelete = @Html.Raw(canDelete.ToString().ToLower());
    const canAssignTeacher = @Html.Raw((userRole == "Admin" || userRole == "CourseCoordinator").ToString().ToLower());
    const isStudent = @Html.Raw((userRole == "Student").ToString().ToLower());

    function batchButtons(b) {
        if (isStudent) {
            return `<form method="post" action="/EnrollmentMvc/SelfEnroll" style="display:inline">
                        <input type="hidden" name="batchId" value="${b.id}">
                        <button type="submit" class="btn-lms-primary btn-lms-sm">Enroll in Batch</button>
                    </form>
                    <a href="/EnrollmentMvc/MyEnrollments" class="btn-lms-ghost btn-lms-sm">My Enrollments</a>`;
        }
        return `<a href="/EnrollmentMvc/Index?batchId=${b.id}" class="btn-lms-ghost btn-lms-sm">Enrollment</a>
                <a href="/AttendanceMvc/Index?batchId=${b.id}" class="btn-lms-ghost btn-lms-sm">Attendance</a>`;
    }

    // Render course header
    document.getElementById('courseDetail').innerHTML = `
        <div class="lms-card">
            <div style="display:flex;justify-content:space-between;align-items:flex-start;flex-wrap:wrap;gap:16px">
                <div style="flex:1">
                    <span class="lms-badge" style="background:var(--green-soft);color:var(--green);margin-bottom:10px;display:inline-block">${course.status || 'ACTIVE'}</span>
                    <h2 style="font-family:var(--font-display);font-size:24px;font-weight:700;color:var(--navy-deep);margin:0 0 8px">${course.title || 'Course'}</h2>
                    <p style="color:var(--text-muted);margin:0 0 16px;font-size:14px">${course.description || ''}</p>
                    <div style="display:flex;gap:24px;font-size:13px;color:var(--text-muted)">
                        <span><strong style="color:var(--text)">${course.credits || 0}</strong> Credits</span>
                        <span><strong style="color:var(--text)">${course.subjectCount || 0}</strong> Subjects</span>
                        <span><strong style="color:var(--text)">${course.batchCount || 0}</strong> Batches</span>
                        ${course.createdByName ? `<span>by <strong>${course.createdByName}</strong></span>` : ''}
                    </div>
                </div>
                <div style="display:flex;gap:8px">
                    ${canManage ? `<a href="/CourseMvc/Edit/${course.id}" class="btn-lms-ghost btn-lms-sm">Edit</a>` : ''}
                    ${canDelete ? `<form method="post" action="/CourseMvc/Delete/${course.id}" onsubmit="return confirm('Delete this course?')">
                        <button type="submit" class="btn-lms-danger btn-lms-sm">Delete</button>
                    </form>` : ''}
                </div>
            </div>
        </div>`;

    // Render subjects
    const subjectsEl = document.getElementById('subjectsContainer');
    if (subjects && subjects.length > 0) {
        subjectsEl.innerHTML = subjects.map(s => `
            <div style="padding:14px 20px;border-bottom:1px solid var(--border);last-child:{border:none}">
                <div style="display:flex;justify-content:space-between;align-items:flex-start;gap:8px">
                    <div style="flex:1">
                        <div style="font-weight:600;font-size:14px;margin-bottom:2px">${s.name}</div>
                        ${s.description ? `<div style="font-size:12.5px;color:var(--text-muted)">${s.description}</div>` : ''}
                        <div style="font-size:12px;color:var(--text-muted);margin-top:4px">${s.teacherCount || 0} teacher(s) assigned</div>
                        <div style="display:flex;gap:6px;flex-wrap:wrap;margin-top:8px">
                            <a href="/AssignmentMvc/Index?subjectId=${s.id}" class="btn-lms-ghost btn-lms-sm">Assignments</a>
                            <a href="/AttendanceMvc/Index?subjectId=${s.id}" class="btn-lms-ghost btn-lms-sm">Attendance</a>
                            <a href="/ExamMvc/Index?subjectId=${s.id}" class="btn-lms-ghost btn-lms-sm">Exams</a>
                        </div>
                    </div>
                    ${canAssignTeacher ? `<a href="/SubjectTeacherMvc/Index?subjectId=${s.id}" class="btn-lms-amber btn-lms-sm" style="flex-shrink:0">Teachers</a>` : ''}
                </div>
            </div>`).join('');
    } else {
        subjectsEl.innerHTML = `<div style="text-align:center;padding:32px;color:var(--text-muted);font-size:13px">No subjects added yet</div>`;
    }

    // Render batches
    const batchesEl = document.getElementById('batchesContainer');
    if (batches && batches.length > 0) {
        batchesEl.innerHTML = batches.map(b => `
            <div style="padding:14px 20px;border-bottom:1px solid var(--border)">
                <div style="font-weight:600;font-size:14px;margin-bottom:4px">${b.batchName}</div>
                <div style="font-size:12.5px;color:var(--text-muted);margin-bottom:8px">
                    ${b.startDate ? new Date(b.startDate).toLocaleDateString() : ''} –
                    ${b.endDate ? new Date(b.endDate).toLocaleDateString() : ''}
                    &nbsp;·&nbsp; ${b.enrollmentCount || 0} students
                </div>
                <div style="display:flex;gap:6px;flex-wrap:wrap">${batchButtons(b)}</div>
            </div>`).join('');
    } else {
        batchesEl.innerHTML = `<div style="text-align:center;padding:32px;color:var(--text-muted);font-size:13px">No batches created yet</div>`;
    }
</script>
}
