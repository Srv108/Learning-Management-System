@{
    ViewData["Title"] = "Courses";
    var userRole = ViewBag.UserRole as string ?? "Student";
    var coursesJson = ViewBag.CoursesJson as string ?? "[]";
    bool canManage = userRole == "Teacher" || userRole == "CourseCoordinator" || userRole == "Admin";
    bool canDelete = userRole == "CourseCoordinator" || userRole == "Admin";
}

<div class="page-header">
    <div>
        <div class="page-title">Courses</div>
        <div class="page-sub">Browse available courses in the system</div>
    </div>
    @if (canManage)
    {
        <a asp-action="Create" class="btn-lms-primary">
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
            Create Course
        </a>
    }
</div>

<div id="coursesContainer" class="content-grid-3">
    <div style="grid-column:1/-1;text-align:center;padding:48px 0;color:var(--text-muted)">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" style="animation:spin 1s linear infinite;margin-bottom:8px"><polyline points="23 4 23 10 17 10"/><path d="M20.49 15a9 9 0 1 1-.04-4.73"/></svg>
        <div>Loading courses...</div>
    </div>
</div>

@section Scripts {
<script>
    const coursesJson = @Html.Raw(coursesJson);
    const canManage = @Html.Raw(canManage.ToString().ToLower());
    const canDelete = @Html.Raw(canDelete.ToString().ToLower());

    function renderCourses(courses) {
        const container = document.getElementById('coursesContainer');
        if (!courses || courses.length === 0) {
            container.innerHTML = `<div class="lms-card" style="grid-column:1/-1;text-align:center;padding:48px">
                <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="var(--text-faint)" stroke-width="1.2" style="margin-bottom:12px"><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/></svg>
                <div style="font-weight:600;color:var(--text-dim);margin-bottom:4px">No courses found</div>
                <div style="font-size:13px;color:var(--text-muted)">No courses have been created yet</div>
            </div>`;
            return;
        }

        container.innerHTML = courses.map(c => `
            <div class="course-card animate-up">
                <div class="course-card-header">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2"><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/></svg>
                </div>
                <div class="course-card-body">
                    <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:8px">
                        <span class="lms-badge" style="background:var(--green-soft);color:var(--green)">${c.status || 'ACTIVE'}</span>
                        <span style="font-family:var(--font-mono);font-size:11px;color:var(--text-muted)">${c.credits || 0} credits</span>
                    </div>
                    <div class="course-title">${c.title || 'Untitled'}</div>
                    <div class="course-desc">${(c.description || 'No description').substring(0, 100)}${(c.description||'').length > 100 ? '...' : ''}</div>
                    <div style="display:flex;gap:16px;font-size:12.5px;color:var(--text-muted);margin-bottom:16px">
                        <span>${c.subjectCount || 0} subjects</span>
                        <span>${c.batchCount || 0} batches</span>
                        ${c.createdByName ? `<span>by ${c.createdByName}</span>` : ''}
                    </div>
                    <div style="display:flex;gap:8px;flex-wrap:wrap">
                        <a href="/CourseMvc/Details/${c.id}" class="btn-lms-primary btn-lms-sm">View Details</a>
                        ${canManage ? `<a href="/CourseMvc/Edit/${c.id}" class="btn-lms-ghost btn-lms-sm">Edit</a>` : ''}
                        ${canDelete ? `<form method="post" action="/CourseMvc/Delete/${c.id}" style="display:inline" onsubmit="return confirm('Delete this course?')">
                            <button type="submit" class="btn-lms-danger btn-lms-sm">Delete</button>
                        </form>` : ''}
                    </div>
                </div>
            </div>
        `).join('');
    }

    renderCourses(coursesJson);
</script>
<style>
@@keyframes spin { from{transform:rotate(0deg)} to{transform:rotate(360deg)} }
</style>
}
