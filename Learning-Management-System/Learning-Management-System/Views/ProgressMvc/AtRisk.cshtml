@{
    ViewData["Title"] = "At-Risk Students";
    var atRiskJson = ViewBag.AtRiskJson as string ?? "null";
    var coursesJson = ViewBag.CoursesJson as string ?? "[]";
    var courseId = ViewBag.CourseId;
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h4 class="fw-bold mb-1">⚠️ At-Risk Students</h4>
        <p class="text-muted mb-0">Students with low attendance (&lt;75%) or failing exam scores (&lt;50)</p>
    </div>
    <a asp-action="Analytics" class="btn btn-outline-primary btn-sm">📈 Course Analytics</a>
</div>

<!-- Filter -->
<div class="card border-0 shadow-sm mb-4">
    <div class="card-body py-3">
        <div class="row g-2 align-items-end">
            <div class="col-md-4">
                <label class="form-label small fw-semibold">Filter by Course</label>
                <select class="form-select" id="courseSelect"
                        onchange="window.location.href='/ProgressMvc/AtRisk'+(this.value?'?courseId='+this.value:'')">
                    <option value="">All Courses</option>
                </select>
            </div>
        </div>
    </div>
</div>

<div id="atRiskContainer"></div>

@section Scripts {
<script>
    const courses = @Html.Raw(coursesJson);
    const atRiskData = @Html.Raw(atRiskJson);
    const selectedId = @Html.Raw(courseId?.ToString() ?? "null");

    const sel = document.getElementById('courseSelect');
    courses.forEach(c => {
        const opt = document.createElement('option');
        opt.value = c.id; opt.textContent = c.title;
        if (c.id == selectedId) opt.selected = true;
        sel.appendChild(opt);
    });

    const container = document.getElementById('atRiskContainer');

    if (!atRiskData || atRiskData.totalAtRisk === 0 || !atRiskData.students || atRiskData.students.length === 0) {
        container.innerHTML = `
            <div class="card border-0 shadow-sm">
                <div class="card-body text-center py-5">
                    <div class="fs-1 mb-2">✅</div>
                    <h5 class="text-success">No at-risk students</h5>
                    <p class="text-muted">All students are performing well!</p>
                </div>
            </div>`;
        return;
    }

    const students = atRiskData.students || [];

    container.innerHTML = `
        <div class="alert alert-warning mb-4">
            <strong>⚠️ ${atRiskData.totalAtRisk || students.length} students need attention</strong> — low attendance or failing grades.
        </div>
        <div class="card border-0 shadow-sm">
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover mb-0">
                        <thead class="table-light">
                            <tr><th>Student</th><th>Course</th><th>Attendance</th><th>Exam Avg</th><th>Overall</th><th>Risk Factors</th></tr>
                        </thead>
                        <tbody>
                            ${students.map(s => `
                                <tr>
                                    <td>
                                        <div class="fw-semibold">${s.studentName || '-'}</div>
                                        <div class="text-muted small">${s.email || ''}</div>
                                    </td>
                                    <td>${s.courseName || '-'}</td>
                                    <td>
                                        <span class="badge ${(s.attendancePercentage||0) >= 75 ? 'bg-success' : 'bg-danger'}">
                                            ${(s.attendancePercentage||0).toFixed(1)}%
                                        </span>
                                    </td>
                                    <td>
                                        <span class="badge ${(s.examAvgScore||0) >= 50 ? 'bg-success' : 'bg-danger'}">
                                            ${(s.examAvgScore||0).toFixed(1)}
                                        </span>
                                    </td>
                                    <td><span class="badge bg-secondary">${s.overallGrade || 'N/A'}</span></td>
                                    <td>
                                        ${(s.riskFactors || []).map(f =>
                                            `<span class="badge bg-danger me-1">${f}</span>`
                                        ).join('')}
                                    </td>
                                </tr>`).join('')}
                        </tbody>
                    </table>
                </div>
            </div>
        </div>`;
</script>
}
