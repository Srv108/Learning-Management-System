@{
    ViewData["Title"] = "At-Risk Students";
    var atRiskJson = ViewBag.AtRiskJson as string ?? "null";
    var coursesJson = ViewBag.CoursesJson as string ?? "[]";
    var courseId = ViewBag.CourseId;
}

<div class="page-header">
    <div>
        <div class="page-title">At-Risk Students</div>
        <div class="page-sub">Students with low attendance (&lt;75%) or failing exam scores (&lt;50)</div>
    </div>
    <a asp-action="Analytics" class="btn-lms-ghost btn-lms-sm">Course Analytics</a>
</div>

<div class="lms-card" style="margin-bottom:20px">
    <div style="display:flex;gap:12px;align-items:flex-end">
        <div class="lms-form-group" style="margin-bottom:0;flex:1;max-width:360px">
            <label class="lms-label">Filter by Course</label>
            <select class="lms-select" id="courseSelect"
                    onchange="window.location.href='/ProgressMvc/AtRisk'+(this.value?'?courseId='+this.value:'')">
                <option value="">All Courses</option>
            </select>
        </div>
    </div>
</div>

<div id="atRiskContainer"></div>

@section Scripts {
<script>
    const courses = @Html.Raw(coursesJson);
    const atRiskData = @Html.Raw(atRiskJson);
    const selectedId = @Html.Raw(courseId?.ToString() ?? "null");

    const sel = document.getElementById('courseSelect');
    courses.forEach(c => {
        const opt = document.createElement('option');
        opt.value = c.id; opt.textContent = c.title;
        if (c.id == selectedId) opt.selected = true;
        sel.appendChild(opt);
    });

    const container = document.getElementById('atRiskContainer');

    if (!atRiskData || atRiskData.totalAtRisk === 0 || !atRiskData.students || atRiskData.students.length === 0) {
        container.innerHTML = `
            <div class="lms-card" style="text-align:center;padding:48px">
                <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="var(--green)" stroke-width="1.5" style="margin-bottom:12px"><polyline points="20 6 9 17 4 12"/></svg>
                <div style="font-weight:600;color:var(--green);margin-bottom:4px">No at-risk students</div>
                <div style="font-size:13px;color:var(--text-muted)">All students are performing well!</div>
            </div>`;
        return;
    }

    const students = atRiskData.students || [];

    container.innerHTML = `
        <div class="lms-alert danger" style="margin-bottom:20px">
            <div class="alert-icon">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
            </div>
            <div><strong>${atRiskData.totalAtRisk || students.length} students need attention</strong> — low attendance or failing grades.</div>
        </div>
        <div class="lms-card" style="padding:0">
            <div style="overflow-x:auto">
                <table class="lms-table">
                    <thead>
                        <tr><th>Student</th><th>Course</th><th>Attendance</th><th>Exam Avg</th><th>Overall</th><th>Risk Factors</th></tr>
                    </thead>
                    <tbody>
                        ${students.map(s => `
                            <tr>
                                <td>
                                    <div style="font-weight:600">${s.studentName || '-'}</div>
                                    <div style="font-size:12.5px;color:var(--text-muted)">${s.email || ''}</div>
                                </td>
                                <td>${s.courseName || '-'}</td>
                                <td>
                                    <span class="lms-badge" style="${(s.attendancePercentage||0) >= 75 ? 'background:var(--green-soft);color:var(--green)' : 'background:var(--rose-soft);color:var(--rose)'}">
                                        ${(s.attendancePercentage||0).toFixed(1)}%
                                    </span>
                                </td>
                                <td>
                                    <span class="lms-badge" style="${(s.examAvgScore||0) >= 50 ? 'background:var(--green-soft);color:var(--green)' : 'background:var(--rose-soft);color:var(--rose)'}">
                                        ${(s.examAvgScore||0).toFixed(1)}
                                    </span>
                                </td>
                                <td><span class="lms-badge" style="background:var(--bg-muted);color:var(--text-muted)">${s.overallGrade || 'N/A'}</span></td>
                                <td>
                                    ${(s.riskFactors || []).map(f =>
                                        `<span class="lms-badge" style="background:var(--rose-soft);color:var(--rose);margin-right:4px">${f}</span>`
                                    ).join('')}
                                </td>
                            </tr>`).join('')}
                    </tbody>
                </table>
            </div>
        </div>`;
</script>
}
