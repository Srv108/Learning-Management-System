@{
    ViewData["Title"] = "System Analytics";
    var analyticsJson = ViewBag.AnalyticsJson as string ?? "null";
}

<div class="page-header">
    <div>
        <div class="page-title">System-Wide Analytics</div>
        <div class="page-sub">Platform-wide student performance overview</div>
    </div>
    <div style="display:flex;gap:8px">
        <a asp-action="Analytics" class="btn-lms-ghost btn-lms-sm">Course Analytics</a>
        <a asp-action="AtRisk" class="btn-lms-danger btn-lms-sm">At-Risk Students</a>
    </div>
</div>

<div id="analyticsContainer">
    <div style="text-align:center;padding:48px;color:var(--text-muted)">Loading analytics...</div>
</div>

@section Scripts {
<script>
const data = @Html.Raw(analyticsJson);
const container = document.getElementById('analyticsContainer');

if (!data || (Array.isArray(data) && data.length === 0)) {
    container.innerHTML = `<div class="lms-card" style="text-align:center;padding:48px">
        <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="var(--text-faint)" stroke-width="1.2" style="margin-bottom:12px"><line x1="18" y1="20" x2="18" y2="10"/><line x1="12" y1="20" x2="12" y2="4"/><line x1="6" y1="20" x2="6" y2="14"/></svg>
        <div style="font-weight:600;color:var(--text-dim);margin-bottom:8px">No analytics data available</div>
        <div style="font-size:13px;color:var(--text-muted)">Analytics data appears after student progress has been calculated.</div>
    </div>`;
    return;
}

const records = Array.isArray(data) ? data : (data.students || []);
const totalStudents = records.length;
const avgAttendance = totalStudents > 0 ? records.reduce((s, r) => s + (r.attendancePercentage || 0), 0) / totalStudents : 0;
const avgExam = totalStudents > 0 ? records.reduce((s, r) => s + (r.examAvgScore || 0), 0) / totalStudents : 0;
const avgAssignment = totalStudents > 0 ? records.reduce((s, r) => s + (r.assignmentAvgScore || 0), 0) / totalStudents : 0;
const passCount = records.filter(r => r.overallGrade && r.overallGrade !== 'F').length;

const gradeStyle = g => {
    if (!g) return 'background:var(--bg-muted);color:var(--text-muted)';
    if (g === 'A+' || g === 'A') return 'background:var(--green-soft);color:var(--green)';
    if (g === 'B') return 'background:var(--sky-soft);color:var(--sky)';
    if (g === 'C' || g === 'D') return 'background:var(--amber-soft);color:var(--amber)';
    return 'background:var(--rose-soft);color:var(--rose)';
};

container.innerHTML = `
    <div class="stats-grid-4" style="margin-bottom:24px">
        <div class="stat-card">
            <div class="stat-label">Total Records</div>
            <div class="stat-val">${totalStudents}</div>
        </div>
        <div class="stat-card">
            <div class="stat-label">Avg Attendance</div>
            <div class="stat-val" style="color:${avgAttendance>=75?'var(--green)':'var(--rose)'}">${avgAttendance.toFixed(1)}%</div>
        </div>
        <div class="stat-card">
            <div class="stat-label">Avg Exam Score</div>
            <div class="stat-val" style="color:${avgExam>=50?'var(--green)':'var(--rose)'}">${avgExam.toFixed(1)}</div>
        </div>
        <div class="stat-card">
            <div class="stat-label">Passing</div>
            <div class="stat-val" style="color:var(--green)">${passCount} / ${totalStudents}</div>
        </div>
    </div>

    <div class="lms-card" style="padding:0">
        <div style="padding:16px 20px;border-bottom:1px solid var(--border);font-weight:600;font-size:14px">Student Progress Records</div>
        <div style="overflow-x:auto">
            <table class="lms-table">
                <thead>
                    <tr><th>Student</th><th>Course</th><th>Attendance</th><th>Assignment</th><th>Exam</th><th>Grade</th></tr>
                </thead>
                <tbody>
                    ${records.map(r => `
                        <tr>
                            <td style="font-weight:600">${r.studentName || r.studentId || '-'}</td>
                            <td style="color:var(--text-muted);font-size:12.5px">${r.courseName || '-'}</td>
                            <td>
                                <span class="lms-badge" style="${(r.attendancePercentage||0)>=75?'background:var(--green-soft);color:var(--green)':'background:var(--rose-soft);color:var(--rose)'}">
                                    ${(r.attendancePercentage||0).toFixed(1)}%
                                </span>
                            </td>
                            <td>${(r.assignmentAvgScore||0).toFixed(1)}</td>
                            <td>
                                <span class="lms-badge" style="${(r.examAvgScore||0)>=50?'background:var(--green-soft);color:var(--green)':'background:var(--rose-soft);color:var(--rose)'}">
                                    ${(r.examAvgScore||0).toFixed(1)}
                                </span>
                            </td>
                            <td><span class="lms-badge" style="${gradeStyle(r.overallGrade)}">${r.overallGrade||'N/A'}</span></td>
                        </tr>`).join('')}
                </tbody>
            </table>
        </div>
    </div>`;
</script>
}
