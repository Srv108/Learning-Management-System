@{
    ViewData["Title"] = "Enroll Student";
    var coursesJson = ViewBag.CoursesJson as string ?? "[]";
    ViewData["Breadcrumb"] = "<a href='/EnrollmentMvc/Index' style='color:var(--text-muted);text-decoration:none'>Enrollments</a> <span style='margin:0 6px;color:var(--border-strong)'>›</span> <span class='current'>Enroll Student</span>";
}

<div class="page-header">
    <div>
        <div class="page-title">Enroll Student</div>
        <div class="page-sub">Add a student to a course batch</div>
    </div>
    <a asp-action="Index" class="btn-lms-ghost">
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="15 18 9 12 15 6"/></svg>
        Back to Enrollments
    </a>
</div>

<div style="max-width:520px">
    <div class="lms-card">
        <form method="post" asp-action="Enroll" style="display:flex;flex-direction:column;gap:18px">
            <div class="lms-form-group">
                <label class="lms-label">Student ID <span style="color:var(--rose)">*</span></label>
                <input type="text" name="studentId" class="lms-input" required placeholder="Enter student's user ID" />
                <span style="font-size:12px;color:var(--text-muted);margin-top:4px;display:block">Find student IDs in the User Management section</span>
            </div>
            <div class="lms-form-group">
                <label class="lms-label">Course <span style="color:var(--rose)">*</span></label>
                <select class="lms-select" id="courseSelect" required>
                    <option value="">Select a course</option>
                </select>
            </div>
            <div class="lms-form-group">
                <label class="lms-label">Batch <span style="color:var(--rose)">*</span></label>
                <select class="lms-select" id="batchSelect" name="batchId" required disabled>
                    <option value="">Select a course first</option>
                </select>
            </div>
            <div style="display:flex;gap:10px;padding-top:4px">
                <button type="submit" class="btn-lms-primary">Enroll Student</button>
                <a asp-action="Index" class="btn-lms-ghost">Cancel</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
<script>
    const courses = @Html.Raw(coursesJson);
    const courseSelect = document.getElementById('courseSelect');
    const batchSelect = document.getElementById('batchSelect');

    courses.forEach(c => {
        const opt = document.createElement('option');
        opt.value = c.id;
        opt.textContent = c.title;
        courseSelect.appendChild(opt);
    });

    courseSelect.addEventListener('change', async function() {
        batchSelect.innerHTML = '<option value="">Loading...</option>';
        batchSelect.disabled = true;
        if (!this.value) { batchSelect.innerHTML = '<option value="">Select a course first</option>'; return; }
        try {
            const res = await fetch(`/api/coursebatch/course/${this.value}`);
            const batches = await res.json();
            batchSelect.innerHTML = '<option value="">Select a batch</option>';
            batches.forEach(b => {
                const opt = document.createElement('option');
                opt.value = b.id;
                opt.textContent = `${b.batchName} (${b.enrollmentCount} enrolled)`;
                batchSelect.appendChild(opt);
            });
            batchSelect.disabled = false;
        } catch {
            batchSelect.innerHTML = '<option value="">Error loading batches</option>';
        }
    });
</script>
}
