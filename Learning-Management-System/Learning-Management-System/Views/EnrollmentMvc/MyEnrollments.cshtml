@{
    ViewData["Title"] = "My Enrollments";
    var enrollmentsJson = ViewBag.EnrollmentsJson as string ?? "[]";
}

<div class="page-header">
    <div>
        <div class="page-title">My Enrollments</div>
        <div class="page-sub">Your enrolled courses and batch information</div>
    </div>
</div>

@if (ViewBag.Error != null)
{
    <div class="lms-alert danger" style="margin-bottom:20px">
        <div class="alert-icon">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="15" y1="9" x2="9" y2="15"/><line x1="9" y1="9" x2="15" y2="15"/></svg>
        </div>
        <div>Could not load enrollments. Please try again.</div>
    </div>
}

<div id="enrollmentsList"></div>

@section Scripts {
<script>
    const enrollments = @Html.Raw(enrollmentsJson);
    const container = document.getElementById('enrollmentsList');

    const statusStyle = s => {
        if (s === 'ACTIVE') return 'background:var(--green-soft);color:var(--green)';
        if (s === 'COMPLETED') return 'background:var(--sky-soft);color:var(--sky)';
        return 'background:var(--bg-muted);color:var(--text-muted)';
    };

    if (!enrollments || enrollments.length === 0) {
        container.innerHTML = `
            <div class="lms-card" style="text-align:center;padding:48px">
                <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="var(--text-faint)" stroke-width="1.2" style="margin-bottom:12px"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/></svg>
                <div style="font-weight:600;color:var(--text-dim);margin-bottom:4px">No enrollments found</div>
                <div style="font-size:13px;color:var(--text-muted);margin-bottom:20px">You are not enrolled in any course batch yet.</div>
                <a href="/CourseMvc/Index" class="btn-lms-primary">Browse Courses</a>
            </div>`;
    } else {
        container.innerHTML = `
            <div class="content-grid-3">
                ${enrollments.map(e => `
                    <div class="lms-card animate-up">
                        <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:12px">
                            <span class="lms-badge" style="${statusStyle(e.status)}">${e.status}</span>
                        </div>
                        <div style="font-weight:700;font-size:16px;margin-bottom:4px">${e.batchName || 'Batch'}</div>
                        <div style="font-size:12.5px;color:var(--text-muted);margin-bottom:16px">
                            Enrolled: ${e.enrolledAt ? new Date(e.enrolledAt).toLocaleDateString() : new Date(e.createdAt).toLocaleDateString()}
                        </div>
                        <div style="display:flex;gap:8px;flex-wrap:wrap">
                            <a href="/AttendanceMvc/MyAttendance" class="btn-lms-ghost btn-lms-sm">My Attendance</a>
                            <a href="/AssignmentMvc/MyAssignments" class="btn-lms-ghost btn-lms-sm">Assignments</a>
                        </div>
                    </div>
                `).join('')}
            </div>`;
    }
</script>
}
