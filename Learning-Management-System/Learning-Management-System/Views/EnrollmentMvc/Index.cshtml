@{
    ViewData["Title"] = "Enrollment Management";
    var userRole = ViewBag.UserRole as string ?? "CourseCoordinator";
    var enrollmentsJson = ViewBag.EnrollmentsJson as string ?? "[]";
    var coursesJson = ViewBag.CoursesJson as string ?? "[]";
    var batchId = ViewBag.BatchId;
}

<div class="page-header">
    <div>
        <div class="page-title">Enrollment Management</div>
        <div class="page-sub">Manage student enrollments in course batches</div>
    </div>
    <a asp-action="Enroll" class="btn-lms-primary">
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
        Enroll Student
    </a>
</div>

<!-- Filter Panel -->
<div class="lms-card" style="margin-bottom:20px">
    <div style="display:grid;grid-template-columns:1fr 1fr auto;gap:12px;align-items:flex-end">
        <div class="lms-form-group" style="margin-bottom:0">
            <label class="lms-label">Filter by Course</label>
            <select class="lms-select" id="courseFilter">
                <option value="">Select Course</option>
            </select>
        </div>
        <div class="lms-form-group" style="margin-bottom:0">
            <label class="lms-label">Filter by Batch</label>
            <select class="lms-select" id="batchFilter">
                <option value="">Select Batch</option>
            </select>
        </div>
        <button class="btn-lms-primary" onclick="loadEnrollments()">Filter</button>
    </div>
</div>

<div class="lms-card" style="padding:0">
    <div style="overflow-x:auto">
        <table class="lms-table">
            <thead>
                <tr>
                    <th>Student</th>
                    <th>Email</th>
                    <th>Batch</th>
                    <th>Status</th>
                    <th>Enrolled On</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody id="enrollmentsBody">
                <tr><td colspan="6" style="text-align:center;padding:32px;color:var(--text-muted)">Select a batch to view enrollments</td></tr>
            </tbody>
        </table>
    </div>
</div>

@section Scripts {
<script>
    const allCourses = @Html.Raw(coursesJson);
    const initialEnrollments = @Html.Raw(enrollmentsJson);
    const initialBatchId = @Html.Raw(batchId?.ToString() ?? "null");

    const courseFilter = document.getElementById('courseFilter');
    if (allCourses && allCourses.length) {
        allCourses.forEach(c => {
            const opt = document.createElement('option');
            opt.value = c.id;
            opt.textContent = c.title;
            courseFilter.appendChild(opt);
        });
    }

    courseFilter.addEventListener('change', async function() {
        const batchSel = document.getElementById('batchFilter');
        batchSel.innerHTML = '<option value="">Select Batch</option>';
        if (!this.value) return;
        const res = await fetch(`/api/coursebatch/course/${this.value}`);
        if (res.ok) {
            const batches = await res.json();
            batches.forEach(b => {
                const opt = document.createElement('option');
                opt.value = b.id;
                opt.textContent = b.batchName;
                batchSel.appendChild(opt);
            });
        }
    });

    function loadEnrollments() {
        const batchId = document.getElementById('batchFilter').value;
        if (!batchId) { alert('Please select a batch'); return; }
        window.location.href = `/EnrollmentMvc/Index?batchId=${batchId}`;
    }

    const statusBadge = s => {
        const map = { ACTIVE: 'var(--green-soft);color:var(--green)', SUSPENDED: 'var(--amber-soft);color:var(--amber)', COMPLETED: 'var(--sky-soft);color:var(--sky)', DROPPED: 'var(--rose-soft);color:var(--rose)' };
        const style = map[s] || 'var(--bg-muted);color:var(--text-muted)';
        return `<span class="lms-badge" style="background:${style}">${s}</span>`;
    };

    function renderEnrollments(enrollments) {
        const tbody = document.getElementById('enrollmentsBody');
        if (!enrollments || enrollments.length === 0) {
            tbody.innerHTML = '<tr><td colspan="6" style="text-align:center;padding:32px;color:var(--text-muted)">No enrollments found</td></tr>';
            return;
        }
        tbody.innerHTML = enrollments.map(e => `
            <tr>
                <td style="font-weight:600">${e.studentName || '-'}</td>
                <td style="color:var(--text-muted);font-size:13px">${e.studentEmail || '-'}</td>
                <td>${e.batchName || '-'}</td>
                <td>${statusBadge(e.status)}</td>
                <td style="font-size:12.5px;color:var(--text-muted)">${e.enrolledAt ? new Date(e.enrolledAt).toLocaleDateString() : e.createdAt ? new Date(e.createdAt).toLocaleDateString() : '-'}</td>
                <td>
                    <div style="display:flex;gap:6px;align-items:center">
                        <form method="post" action="/EnrollmentMvc/UpdateStatus" style="display:inline">
                            <input type="hidden" name="id" value="${e.id}" />
                            <input type="hidden" name="batchId" value="${e.batchId}" />
                            <select name="status" class="lms-select" style="padding:4px 8px;height:auto;font-size:12px;min-width:100px" onchange="this.form.submit()">
                                <option value="ACTIVE" ${e.status === 'ACTIVE' ? 'selected' : ''}>Active</option>
                                <option value="SUSPENDED" ${e.status === 'SUSPENDED' ? 'selected' : ''}>Suspended</option>
                                <option value="COMPLETED" ${e.status === 'COMPLETED' ? 'selected' : ''}>Completed</option>
                                <option value="DROPPED" ${e.status === 'DROPPED' ? 'selected' : ''}>Dropped</option>
                            </select>
                        </form>
                        <form method="post" action="/EnrollmentMvc/Delete" style="display:inline" onsubmit="return confirm('Remove enrollment?')">
                            <input type="hidden" name="id" value="${e.id}" />
                            <input type="hidden" name="batchId" value="${e.batchId}" />
                            <button type="submit" class="btn-lms-danger btn-lms-sm">Remove</button>
                        </form>
                    </div>
                </td>
            </tr>
        `).join('');
    }

    renderEnrollments(initialEnrollments);
    if (initialBatchId) {
        document.getElementById('batchFilter').value = initialBatchId;
    }
</script>
}
