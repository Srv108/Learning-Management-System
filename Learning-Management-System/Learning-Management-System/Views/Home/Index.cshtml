@{
    ViewData["Title"] = "Dashboard";
    var userRole     = ViewBag.UserRole as string ?? "Student";
    var userFullName = ViewBag.UserFullName as string ?? "User";
    var userId       = ViewBag.UserId as string ?? "";

    bool IsStudent()        => userRole == "Student";
    bool IsTeacher()        => userRole == "Teacher";
    bool IsCoordinator()    => userRole == "CourseCoordinator";
    bool IsExamController() => userRole == "ExamController";
    bool IsAdmin()          => userRole == "Admin";

    string Greeting() {
        var h = DateTime.Now.Hour;
        if (h < 12) return "Good morning";
        if (h < 17) return "Good afternoon";
        return "Good evening";
    }
}

<!-- ─── ADMIN DASHBOARD ─── -->
@if (IsAdmin())
{
<div style="margin-bottom:22px;display:flex;align-items:flex-end;justify-content:space-between">
    <div>
        <div class="page-eyebrow">System Overview</div>
        <div class="page-title">Admin Dashboard</div>
        <div class="page-subtitle">Academic Year 2025–26 · Full system access</div>
    </div>
    <div style="display:flex;gap:8px">
        <a asp-controller="AdminMvc" asp-action="Users" class="btn-lms btn-lms-ghost">
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/></svg>
            Manage Users
        </a>
        <a asp-controller="CourseMvc" asp-action="Create" class="btn-lms btn-lms-primary">
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 5v14M5 12h14"/></svg>
