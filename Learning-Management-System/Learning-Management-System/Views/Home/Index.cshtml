@{
    ViewData["Title"] = "Dashboard";
    var userRole = ViewBag.UserRole as string ?? "Student";
    var userFullName = ViewBag.UserFullName as string ?? "User";
    var userId = ViewBag.UserId as string ?? "";

    bool IsStudent() => userRole == "Student";
    bool IsTeacher() => userRole == "Teacher";
    bool IsCoordinator() => userRole == "CourseCoordinator";
    bool IsExamController() => userRole == "ExamController";
    bool IsAdmin() => userRole == "Admin";
}

<div class="d-flex align-items-center justify-content-between mb-4">
    <div>
        <h4 class="fw-bold mb-1">Welcome back, @userFullName! 👋</h4>
        <p class="text-muted mb-0">
            @{
                var roleDesc = userRole switch {
                    "Student" => "Track your learning journey, assignments, and exam results.",
                    "Teacher" => "Manage your courses, assignments, and student attendance.",
                    "CourseCoordinator" => "Oversee enrollments, course batches, and curriculum.",
                    "ExamController" => "Schedule exams and record student results.",
                    "Admin" => "Full system access — manage users, courses, and all modules.",
                    _ => "Learning Management System"
                };
            }
            @roleDesc
        </p>
    </div>
    <span class="badge fs-6 px-3 py-2" style="background:#ede9fe;color:#4f46e5;">@userRole</span>
</div>

@* Student Dashboard *@
@if (IsStudent())
{
    <div class="row g-4 mb-4">
        <div class="col-md-4">
            <a asp-controller="CourseMvc" asp-action="Index" class="text-decoration-none">
                <div class="card border-0 shadow-sm h-100 dashboard-card">
                    <div class="card-body text-center py-4">
                        <div class="fs-1 mb-2">📚</div>
                        <h5 class="fw-semibold">Browse Courses</h5>
                        <p class="text-muted small">View all available courses</p>
                    </div>
                </div>
            </a>
        </div>
        <div class="col-md-4">
            <a asp-controller="EnrollmentMvc" asp-action="MyEnrollments" class="text-decoration-none">
                <div class="card border-0 shadow-sm h-100 dashboard-card">
                    <div class="card-body text-center py-4">
                        <div class="fs-1 mb-2">📋</div>
                        <h5 class="fw-semibold">My Enrollments</h5>
                        <p class="text-muted small">View your enrolled courses & batches</p>
                    </div>
                </div>
            </a>
        </div>
        <div class="col-md-4">
            <a asp-controller="AttendanceMvc" asp-action="MyAttendance" class="text-decoration-none">
                <div class="card border-0 shadow-sm h-100 dashboard-card">
                    <div class="card-body text-center py-4">
                        <div class="fs-1 mb-2">✅</div>
                        <h5 class="fw-semibold">My Attendance</h5>
                        <p class="text-muted small">Check your attendance records</p>
                    </div>
                </div>
            </a>
        </div>
        <div class="col-md-4">
            <a asp-controller="AssignmentMvc" asp-action="MyAssignments" class="text-decoration-none">
                <div class="card border-0 shadow-sm h-100 dashboard-card">
                    <div class="card-body text-center py-4">
                        <div class="fs-1 mb-2">📝</div>
                        <h5 class="fw-semibold">My Assignments</h5>
                        <p class="text-muted small">Submit and track your assignments</p>
                    </div>
                </div>
            </a>
        </div>
        <div class="col-md-4">
            <a asp-controller="ExamMvc" asp-action="MyResults" class="text-decoration-none">
                <div class="card border-0 shadow-sm h-100 dashboard-card">
                    <div class="card-body text-center py-4">
                        <div class="fs-1 mb-2">🎯</div>
                        <h5 class="fw-semibold">My Exam Results</h5>
                        <p class="text-muted small">View your exam scores and grades</p>
                    </div>
                </div>
            </a>
        </div>
        <div class="col-md-4">
            <a asp-controller="ProgressMvc" asp-action="MyProgress" class="text-decoration-none">
                <div class="card border-0 shadow-sm h-100 dashboard-card">
                    <div class="card-body text-center py-4">
                        <div class="fs-1 mb-2">📈</div>
                        <h5 class="fw-semibold">My Progress</h5>
                        <p class="text-muted small">Performance analytics & reports</p>
                    </div>
                </div>
            </a>
        </div>
    </div>
}

