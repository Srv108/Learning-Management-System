    <a asp-controller="AttendanceMvc" asp-action="Index" class="qa-card">
        <div class="qa-icon" style="background:var(--green-soft)">✅</div>
        <div><div class="qa-title">Attendance</div><div class="qa-sub">390 sessions tracked</div></div>
    </a>
    <a asp-controller="ExamMvc" asp-action="Index" class="qa-card">
        <div class="qa-icon" style="background:var(--rose-soft)">📊</div>
        <div><div class="qa-title">Exams</div><div class="qa-sub">78 exams · 1716 results</div></div>
    </a>
