                    <div class="card border-left-warning">
                        <div class="card-body">
                            <h6 class="card-title text-warning">
                                <i class="bi bi-exclamation-circle"></i> Avg Absent
                            </h6>
                            <h2 class="mb-0">7.7%</h2>
                            <small class="text-muted">Absence rate</small>
                        </div>
                    </div>
                </div>
                <div class="col-md-6 col-lg-3 mb-4">
                    <div class="card border-left-danger">
                        <div class="card-body">
                            <h6 class="card-title text-danger">
                                <i class="bi bi-calendar-x"></i> Low Attendance
