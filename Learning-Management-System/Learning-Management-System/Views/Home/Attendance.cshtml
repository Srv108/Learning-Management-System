            <div class="card shadow mt-4">
                <div class="card-header bg-light">
                    <h6 class="mb-0">Student Attendance Summary</h6>
                </div>
                <div class="card-body">
                    <div class="table-responsive">
                        <table class="table table-sm">
                            <thead>
                                <tr>
                                    <th>Student Name</th>
                                    <th>Total Sessions</th>
                                    <th>Present</th>
