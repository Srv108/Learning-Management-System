@{
    ViewData["Title"] = "Attendance Tracking";
}

<div class="container-fluid px-4 py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="display-5 fw-bold">Attendance Tracking & Management</h1>
        <button class="btn btn-warning btn-lg" data-bs-toggle="modal" data-bs-target="#newSessionModal">
            <i class="bi bi-calendar-check"></i> New Session
        </button>
    </div>

    <!-- Filter Section -->
    <div class="row mb-4">
        <div class="col-md-4">
            <select class="form-select form-select-lg" id="subjectFilter">
                <option value="">All Subjects</option>
                <option value="1">Calculus I</option>
                <option value="2">Linear Algebra</option>
                <option value="3">Mechanics</option>
                <option value="4">Organic Chemistry</option>
            </select>
        </div>
        <div class="col-md-4">
            <input type="date" class="form-control form-control-lg" id="dateFilter">
        </div>
        <div class="col-md-4">
            <button class="btn btn-outline-secondary btn-lg w-100" onclick="viewAttendanceReport()">
                <i class="bi bi-file-earmark-pdf"></i> Attendance Report
            </button>
        </div>
    </div>

    <!-- Attendance Sessions Tabs -->
    <ul class="nav nav-tabs mb-4" role="tablist">
        <li class="nav-item" role="presentation">
            <button class="nav-link active" id="sessionsTab" data-bs-toggle="tab" data-bs-target="#sessionsContent" role="tab">
                <i class="bi bi-calendar-check"></i> Sessions
            </button>
        </li>
        <li class="nav-item" role="presentation">
            <button class="nav-link" id="recordsTab" data-bs-toggle="tab" data-bs-target="#recordsContent" role="tab">
                <i class="bi bi-list-check"></i> Attendance Records
            </button>
        </li>
        <li class="nav-item" role="presentation">
            <button class="nav-link" id="summaryTab" data-bs-toggle="tab" data-bs-target="#summaryContent" role="tab">
                <i class="bi bi-bar-chart"></i> Summary
            </button>
        </li>
    </ul>

