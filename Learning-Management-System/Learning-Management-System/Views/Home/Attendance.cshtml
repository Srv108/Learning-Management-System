                                        <span class="badge bg-success">90%</span>
                                    </td>
                                </tr>
                                <tr>
                                    <td>Mike Johnson</td>
                                    <td>50</td>
                                    <td>42</td>
                                    <td>8</td>
                                    <td>
                                        <span class="badge bg-warning">84%</span>
                                    </td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- New Session Modal -->
<div class="modal fade" id="newSessionModal" tabindex="-1">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header bg-warning text-dark">
                <h5 class="modal-title">Create New Attendance Session</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <form id="sessionForm">
                    <div class="mb-3">
                        <label for="sessionSubject" class="form-label">Subject *</label>
                        <select class="form-select form-select-lg" id="sessionSubject" required>
                            <option selected disabled>Select a subject</option>
                            <option value="1">Calculus I</option>
                            <option value="2">Linear Algebra</option>
                            <option value="3">Mechanics</option>
                            <option value="4">Organic Chemistry</option>
                        </select>
                    </div>
                    <div class="mb-3">
                        <label for="sessionDate" class="form-label">Date *</label>
                        <input type="date" class="form-control form-control-lg" id="sessionDate" required>
                    </div>
                    <div class="mb-3">
                        <label for="sessionTime" class="form-label">Time *</label>
                        <input type="time" class="form-control form-control-lg" id="sessionTime" required>
                    </div>
                </form>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary btn-lg" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-warning btn-lg" onclick="createSession()">
                    <i class="bi bi-calendar-check"></i> Create Session
                </button>
            </div>
        </div>
    </div>
</div>

<!-- View Session Modal -->
<div class="modal fade" id="viewSessionModal" tabindex="-1">
    <div class="modal-dialog modal-xl">
        <div class="modal-content">
            <div class="modal-header bg-warning text-dark">
                <h5 class="modal-title">Mark Attendance - Calculus I (2024-03-28)</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <div class="mb-3">
                    <input type="text" class="form-control form-control-lg" placeholder="Search student name...">
                </div>
                <div class="table-responsive">
                    <table class="table table-hover">
                        <thead class="table-light">
                            <tr>
                                <th>Student Name</th>
                                <th>Email</th>
                                <th>Status</th>
                                <th>Action</th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr>
                                <td>John Doe</td>
                                <td>john.doe@student.com</td>
                                <td>
                                    <span class="badge bg-success">PRESENT</span>
                                </td>
                                <td>
                                    <button class="btn btn-sm btn-outline-danger" onclick="markAbsent()">Mark Absent</button>
                                </td>
                            </tr>
                            <tr>
                                <td>Jane Smith</td>
                                <td>jane.smith@student.com</td>
                                <td>
                                    <span class="badge bg-success">PRESENT</span>
                                </td>
                                <td>
                                    <button class="btn btn-sm btn-outline-danger">Mark Absent</button>
                                </td>
                            </tr>
                            <tr>
                                <td>Mike Johnson</td>
                                <td>mike.johnson@student.com</td>
                                <td>
                                    <span class="badge bg-danger">ABSENT</span>
                                </td>
                                <td>
                                    <button class="btn btn-sm btn-outline-success" onclick="markPresent()">Mark Present</button>
                                </td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary btn-lg" data-bs-dismiss="modal">Close</button>
                <button type="button" class="btn btn-primary btn-lg" onclick="saveAttendance()">
                    <i class="bi bi-check-circle"></i> Save Attendance
                </button>
            </div>
        </div>
    </div>
</div>

<style>
    .border-left-primary {
        border-left: 4px solid #0d6efd;
    }

    .border-left-success {
        border-left: 4px solid #198754;
    }

    .border-left-warning {
        border-left: 4px solid #ffc107;
    }

    .border-left-danger {
        border-left: 4px solid #dc3545;
    }

    .card {
        border: none;
        border-radius: 0.5rem;
        transition: all 0.3s ease;
    }

    .card:hover {
        box-shadow: 0 0.5rem 1rem rgba(0, 0, 0, 0.15);
    }

    .nav-tabs .nav-link {
        color: #495057;
        border: none;
        border-bottom: 3px solid transparent;
    }

    .nav-tabs .nav-link.active {
        color: #0d6efd;
        background-color: transparent;
        border-color: #0d6efd;
    }

    @@media (max-width: 768px) {
        .table {
            font-size: 0.85rem;
        }

        .btn-sm {
            padding: 0.3rem 0.5rem;
            font-size: 0.75rem;
        }
    }
</style>
