@{
    ViewData["Title"] = "Student Enrollment";
}

<div class="container-fluid px-4 py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="display-5 fw-bold">Student Enrollment Management</h1>
        <button class="btn btn-info btn-lg" data-bs-toggle="modal" data-bs-target="#enrollStudentModal">
            <i class="bi bi-person-plus"></i> Enroll Student
        </button>
    </div>

    <!-- Filter Section -->
    <div class="row mb-4">
        <div class="col-md-3">
            <input type="text" class="form-control form-control-lg" id="studentSearch" placeholder="Search by name or email...">
        </div>
        <div class="col-md-3">
            <select class="form-select form-select-lg" id="batchFilter">
                <option value="">All Batches</option>
                <option value="1">Batch 2024-A (Mathematics)</option>
                <option value="2">Batch 2024-B (Physics)</option>
                <option value="3">Batch 2024-C (Chemistry)</option>
            </select>
        </div>
        <div class="col-md-3">
            <select class="form-select form-select-lg" id="statusFilter">
                <option value="">All Status</option>
                <option value="ACTIVE">Active</option>
                <option value="DROPPED">Dropped</option>
                <option value="COMPLETED">Completed</option>
            </select>
        </div>
        <div class="col-md-3">
            <button class="btn btn-outline-secondary btn-lg w-100" onclick="exportEnrollments()">
                <i class="bi bi-download"></i> Export
            </button>
        </div>
    </div>

    <!-- Enrollments Table -->
    <div class="table-responsive shadow-sm rounded">
        <table class="table table-hover table-striped mb-0">
            <thead class="table-info">
                <tr>
                    <th>Student Name</th>
                    <th>Email</th>
                    <th>Batch</th>
                    <th>Status</th>
                    <th>Enrolled Date</th>
                    <th>Progress</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                <tr>
                    <td>
                        <strong>John Doe</strong>
                    </td>
                    <td>john.doe@student.com</td>
                    <td>
                        <span class="badge bg-primary">Batch 2024-A</span>
                    </td>
                    <td>
                        <span class="badge bg-success">Active</span>
                    </td>
                    <td>2024-01-15</td>
                    <td>
                        <div class="progress" style="height: 20px;">
                            <div class="progress-bar bg-success" role="progressbar" style="width: 75%">75%</div>
                        </div>
                    </td>
                    <td>
                        <button class="btn btn-sm btn-outline-primary me-2" data-bs-toggle="modal" data-bs-target="#viewEnrollmentModal">
                            <i class="bi bi-eye"></i> View
                        </button>
                        <button class="btn btn-sm btn-outline-warning me-2">
                            <i class="bi bi-pencil"></i> Edit
                        </button>
                        <button class="btn btn-sm btn-outline-danger" onclick="dropEnrollment(1)">
                            <i class="bi bi-x-circle"></i> Drop
                        </button>
                    </td>
                </tr>
                <tr>
                    <td>
                        <strong>Jane Smith</strong>
                    </td>
                    <td>jane.smith@student.com</td>
                    <td>
                        <span class="badge bg-primary">Batch 2024-A</span>
                    </td>
                    <td>
                        <span class="badge bg-success">Active</span>
                    </td>
                    <td>2024-01-20</td>
                    <td>
                        <div class="progress" style="height: 20px;">
                            <div class="progress-bar bg-success" role="progressbar" style="width: 85%">85%</div>
                        </div>
                    </td>
                    <td>
                        <button class="btn btn-sm btn-outline-primary me-2">
                            <i class="bi bi-eye"></i> View
                        </button>
                        <button class="btn btn-sm btn-outline-warning me-2">
                            <i class="bi bi-pencil"></i> Edit
                        </button>
                        <button class="btn btn-sm btn-outline-danger">
                            <i class="bi bi-x-circle"></i> Drop
                        </button>
                    </td>
                </tr>
                <tr>
                    <td>
                        <strong>Mike Johnson</strong>
                    </td>
                    <td>mike.johnson@student.com</td>
                    <td>
                        <span class="badge bg-success">Batch 2024-B</span>
                    </td>
                    <td>
                        <span class="badge bg-warning text-dark">In Progress</span>
                    </td>
                    <td>2024-02-01</td>
                    <td>
                        <div class="progress" style="height: 20px;">
                            <div class="progress-bar bg-warning" role="progressbar" style="width: 55%">55%</div>
                        </div>
                    </td>
                    <td>
                        <button class="btn btn-sm btn-outline-primary me-2">
                            <i class="bi bi-eye"></i> View
                        </button>
                        <button class="btn btn-sm btn-outline-warning me-2">
                            <i class="bi bi-pencil"></i> Edit
                        </button>
                        <button class="btn btn-sm btn-outline-danger">
                            <i class="bi bi-x-circle"></i> Drop
