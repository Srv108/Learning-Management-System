    <!-- Pagination -->
    <nav aria-label="Page navigation" class="mt-4">
        <ul class="pagination justify-content-center">
            <li class="page-item disabled">
                <a class="page-link" href="#" tabindex="-1">Previous</a>
            </li>
            <li class="page-item active"><a class="page-link" href="#">1</a></li>
            <li class="page-item"><a class="page-link" href="#">2</a></li>
            <li class="page-item"><a class="page-link" href="#">3</a></li>
            <li class="page-item">
                <a class="page-link" href="#">Next</a>
            </li>
        </ul>
    </nav>
</div>

<!-- Enroll Student Modal -->
<div class="modal fade" id="enrollStudentModal" tabindex="-1">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header bg-info text-white">
                <h5 class="modal-title">Enroll New Student</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <form id="enrollForm">
                    <div class="mb-3">
                        <label for="enrollStudent" class="form-label">Select Student *</label>
                        <select class="form-select form-select-lg" id="enrollStudent" required>
                            <option selected disabled>Choose a student</option>
                            <option value="1">John Doe (john.doe@student.com)</option>
                            <option value="2">Jane Smith (jane.smith@student.com)</option>
                            <option value="3">Mike Johnson (mike.johnson@student.com)</option>
                            <option value="4">Sarah Williams (sarah.williams@student.com)</option>
                        </select>
                    </div>
                    <div class="mb-3">
                        <label for="enrollBatch" class="form-label">Select Batch *</label>
                        <select class="form-select form-select-lg" id="enrollBatch" required>
                            <option selected disabled>Choose a batch</option>
                            <option value="1">Batch 2024-A (Mathematics)</option>
                            <option value="2">Batch 2024-B (Physics)</option>
                            <option value="3">Batch 2024-C (Chemistry)</option>
                        </select>
                    </div>
                    <div class="alert alert-info" role="alert">
                        <i class="bi bi-info-circle"></i> The student will be enrolled with ACTIVE status from today onwards.
                    </div>
                </form>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary btn-lg" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-info btn-lg" onclick="enrollStudent()">
                    <i class="bi bi-person-plus"></i> Enroll Student
                </button>
            </div>
        </div>
    </div>
</div>

<!-- View Enrollment Modal -->
<div class="modal fade" id="viewEnrollmentModal" tabindex="-1">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header bg-info text-white">
                <h5 class="modal-title">Enrollment Details</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <div class="row mb-3">
                    <div class="col-md-6">
                        <strong>Student Name:</strong>
                        <p>John Doe</p>
                    </div>
                    <div class="col-md-6">
                        <strong>Email:</strong>
                        <p>john.doe@student.com</p>
                    </div>
                </div>
                <div class="row mb-3">
                    <div class="col-md-6">
                        <strong>Batch:</strong>
                        <p>Batch 2024-A (Mathematics)</p>
                    </div>
                    <div class="col-md-6">
                        <strong>Status:</strong>
                        <p><span class="badge bg-success">Active</span></p>
                    </div>
                </div>
                <div class="row mb-3">
                    <div class="col-md-6">
                        <strong>Enrolled Date:</strong>
                        <p>2024-01-15</p>
                    </div>
                    <div class="col-md-6">
                        <strong>Attendance:</strong>
                        <p>92% (46/50 Sessions)</p>
                    </div>
                </div>
                <hr>
                <h6 class="mb-3">Course Progress</h6>
                <div class="progress mb-2" style="height: 25px;">
                    <div class="progress-bar bg-success" role="progressbar" style="width: 75%">75% Complete</div>
                </div>
                <small class="text-muted">Assignments Completed: 18/24 | Exams Taken: 3/4</small>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary btn-lg" data-bs-dismiss="modal">Close</button>
            </div>
        </div>
    </div>
</div>

<style>
    .display-5 {
        font-weight: 700;
    }

    .table-responsive {
        border-radius: 0.5rem;
        overflow: hidden;
    }

    .table {
        margin-bottom: 0;
    }

    .table-hover tbody tr:hover {
        background-color: #e8f4f8;
    }

    .progress {
        background-color: #e9ecef;
        border-radius: 0.25rem;
    }

    .badge {
        font-size: 0.875rem;
        padding: 0.4rem 0.8rem;
    }

    .btn-sm {
        transition: all 0.2s ease;
    }

    .btn-sm:hover {
        transform: scale(1.05);
    }

    @@media (max-width: 768px) {
        .table {
            font-size: 0.85rem;
        }

        .btn-sm {
            padding: 0.3rem 0.5rem;
            font-size: 0.75rem;
        }

        .progress {
            height: 15px !important;
        }

        .container-fluid {
            padding: 1rem;
        }
    }

