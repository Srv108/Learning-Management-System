@model Learning_Management_System.Controllers.RegisterViewModel
@{
    ViewData["Title"] = "Create Account";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="login-shell">
    <!-- Left panel -->
    <div class="login-left">
        <div class="login-left-bg"></div>
        <div class="login-left-grid"></div>

        <!-- Logo -->
        <div style="display:flex;align-items:center;gap:10px;margin-bottom:48px;position:relative;z-index:1">
            <div class="brand-icon" style="width:40px;height:40px">
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2.2">
                    <path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/>
                    <path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/>
                </svg>
            </div>
            <div>
                <div style="font-family:var(--font-display);font-size:18px;font-weight:600;color:white">EduCore</div>
                <div style="font-size:10px;color:rgba(255,255,255,0.32);font-family:var(--font-mono);text-transform:uppercase;letter-spacing:0.08em">Learning Management</div>
            </div>
        </div>

        <h2 class="login-headline">
            Start your academic<br>
            <em>journey today.</em>
        </h2>
        <p class="login-desc">Join EduCore to access courses, track your progress, submit assignments, and stay on top of exams — all in one place.</p>

        <div class="login-stats-grid">
            <div class="login-stat">
                <div class="login-stat-val">30</div>
                <div class="login-stat-label">Active Students</div>
            </div>
            <div class="login-stat">
                <div class="login-stat-val">6</div>
                <div class="login-stat-label">Courses Running</div>
            </div>
            <div class="login-stat">
                <div class="login-stat-val">78</div>
                <div class="login-stat-label">Exams Scheduled</div>
            </div>
            <div class="login-stat">
                <div class="login-stat-val">62</div>
                <div class="login-stat-label">API Endpoints</div>
            </div>
        </div>
    </div>

    <!-- Right panel -->
    <div class="login-right">
        <div class="login-form-title">Create account</div>
        <div class="login-form-sub">Join EduCore LMS</div>

        @if (TempData["Error"] != null)
        {
            <div class="lms-alert danger" style="margin-bottom:16px">
                <div class="alert-icon">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="15" y1="9" x2="9" y2="15"/><line x1="9" y1="9" x2="15" y2="15"/></svg>
                </div>
                <div>
                    <div class="alert-title">Registration failed</div>
                    <div style="font-size:12.5px">@TempData["Error"]</div>
                </div>
            </div>
        }

        <form method="post" asp-action="Register" asp-controller="AuthMvc" style="display:flex;flex-direction:column;gap:14px" id="registerForm">
            <div asp-validation-summary="ModelOnly" class="lms-alert danger" style="display:none"></div>

            <div class="lms-form-group" style="margin-bottom:0">
                <label class="lms-label">Full Name</label>
                <input type="text" class="lms-input" asp-for="FullName" placeholder="Your full name" required autofocus autocomplete="name">
                <span asp-validation-for="FullName" style="font-size:11.5px;color:var(--rose);margin-top:3px"></span>
            </div>

            <div class="lms-form-group" style="margin-bottom:0">
                <label class="lms-label">Email Address</label>
                <input type="email" class="lms-input" asp-for="Email" placeholder="your@email.com" required autocomplete="email">
                <span asp-validation-for="Email" style="font-size:11.5px;color:var(--rose);margin-top:3px"></span>
            </div>

            <div class="lms-form-group" style="margin-bottom:0">
                <label class="lms-label">Register As</label>
                <select class="lms-select" asp-for="Role" required>
                    <option value="Student">Student</option>
                    <option value="Teacher">Teacher</option>
                </select>
                <span style="font-size:11.5px;color:var(--text-muted);margin-top:4px;display:block">Contact admin to register as Coordinator or Admin</span>
            </div>

            <div class="lms-form-group" style="margin-bottom:0">
                <label class="lms-label">Password</label>
                <div style="position:relative">
                    <input type="password" class="lms-input" id="passwordInput" asp-for="Password"
                           placeholder="Min 8 chars, upper, lower, digit" required autocomplete="new-password"
                           style="padding-right:42px">
                    <button type="button" id="togglePwd" tabindex="-1"
                            style="position:absolute;right:12px;top:50%;transform:translateY(-50%);background:none;border:none;cursor:pointer;color:var(--text-dim);padding:0;display:grid;place-items:center">
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/>
                            <circle cx="12" cy="12" r="3"/>
                        </svg>
                    </button>
                </div>
                <span asp-validation-for="Password" style="font-size:11.5px;color:var(--rose);margin-top:3px"></span>
            </div>

            <div class="lms-form-group" style="margin-bottom:0">
                <label class="lms-label">Confirm Password</label>
                <input type="password" class="lms-input" id="confirmInput" asp-for="ConfirmPassword"
                       placeholder="Re-enter your password" required autocomplete="new-password">
                <span asp-validation-for="ConfirmPassword" style="font-size:11.5px;color:var(--rose);margin-top:3px"></span>
            </div>

            <button type="submit" class="login-submit-btn" id="submitBtn">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/>
                    <circle cx="9" cy="7" r="4"/>
                    <path d="M22 21v-2a4 4 0 0 0-3-3.87M16 3.13a4 4 0 0 1 0 7.75"/>
                </svg>
                Create Account
            </button>

            <div style="text-align:center;font-size:12.5px;color:var(--text-muted)">
                Already have an account?
                <a asp-controller="AuthMvc" asp-action="Login"
                   style="color:var(--amber);font-weight:500;text-decoration:none">Sign in</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
<script>
document.getElementById('togglePwd').addEventListener('click', function() {
    const inp = document.getElementById('passwordInput');
    inp.type = inp.type === 'password' ? 'text' : 'password';
});
document.getElementById('registerForm').addEventListener('submit', function(e) {
    const pwd = document.getElementById('passwordInput').value;
    const confirm = document.getElementById('confirmInput').value;
    if (pwd !== confirm) {
        e.preventDefault();
        alert('Passwords do not match!');
        return;
    }
    const hasUpper = /[A-Z]/.test(pwd);
    const hasLower = /[a-z]/.test(pwd);
    const hasDigit = /[0-9]/.test(pwd);
    if (!hasUpper || !hasLower || !hasDigit || pwd.length < 8) {
        e.preventDefault();
        alert('Password must contain uppercase, lowercase, digit, and be at least 8 characters!');
        return;
    }
    const btn = document.getElementById('submitBtn');
    btn.innerHTML = '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="animation:spin 0.8s linear infinite"><polyline points="23 4 23 10 17 10"/><path d="M20.49 15a9 9 0 1 1-.04-4.73"/></svg> Creating account...';
    btn.disabled = true;
});
</script>
<style>
@@keyframes spin { from{transform:rotate(0deg)} to{transform:rotate(360deg)} }
body { margin:0; padding:0; background: var(--navy-deep); }
</style>
}
