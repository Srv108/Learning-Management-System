@model Learning_Management_System.Controllers.LoginViewModel
@{
    ViewData["Title"] = "Sign In";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="login-shell">
    <!-- Left panel -->
    <div class="login-left">
        <div class="login-left-bg"></div>
        <div class="login-left-grid"></div>

        <!-- Logo -->
        <div style="display:flex;align-items:center;gap:10px;margin-bottom:48px;position:relative;z-index:1">
            <div class="brand-icon" style="width:40px;height:40px">
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2.2">
                    <path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/>
                    <path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/>
                </svg>
            </div>
            <div>
                <div style="font-family:var(--font-display);font-size:18px;font-weight:600;color:white">EduCore</div>
                <div style="font-size:10px;color:rgba(255,255,255,0.32);font-family:var(--font-mono);text-transform:uppercase;letter-spacing:0.08em">Learning Management</div>
            </div>
        </div>

        <h2 class="login-headline">
            Academic excellence,<br>
            <em>systematically managed.</em>
        </h2>
        <p class="login-desc">A complete platform for courses, attendance, assignments, exams, and student progress — built for modern institutions.</p>

        <div class="login-stats-grid">
            <div class="login-stat">
                <div class="login-stat-val">30</div>
                <div class="login-stat-label">Active Students</div>
            </div>
            <div class="login-stat">
                <div class="login-stat-val">6</div>
                <div class="login-stat-label">Courses Running</div>
            </div>
            <div class="login-stat">
                <div class="login-stat-val">78</div>
                <div class="login-stat-label">Exams Scheduled</div>
            </div>
            <div class="login-stat">
                <div class="login-stat-val">62</div>
                <div class="login-stat-label">API Endpoints</div>
            </div>
        </div>
    </div>

    <!-- Right panel -->
    <div class="login-right">
        <div class="login-form-title">Welcome back</div>
        <div class="login-form-sub">Sign in to your EduCore account</div>

        @if (TempData["Error"] != null)
        {
            <div class="lms-alert danger" style="margin-bottom:16px">
                <div class="alert-icon">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="15" y1="9" x2="9" y2="15"/><line x1="9" y1="9" x2="15" y2="15"/></svg>
                </div>
                <div>
                    <div class="alert-title">Sign in failed</div>
                    <div style="font-size:12.5px">@TempData["Error"]</div>
                </div>
            </div>
        }

        <form method="post" asp-action="Login" asp-controller="AuthMvc" style="display:flex;flex-direction:column;gap:14px">
            <div asp-validation-summary="ModelOnly" class="lms-alert danger" style="display:none"></div>

            <div class="lms-form-group" style="margin-bottom:0">
                <label class="lms-label">Email Address</label>
                <input type="email" class="lms-input" id="emailInput" asp-for="Email"
                       placeholder="your@email.com" required autofocus autocomplete="email">
                <span asp-validation-for="Email" style="font-size:11.5px;color:var(--rose);margin-top:3px"></span>
            </div>

            <div class="lms-form-group" style="margin-bottom:0">
                <label class="lms-label">Password</label>
                <div style="position:relative">
                    <input type="password" class="lms-input" id="passwordInput" asp-for="Password"
                           placeholder="••••••••••" required autocomplete="current-password"
                           style="padding-right:42px">
                    <button type="button" id="togglePwd" tabindex="-1"
                            style="position:absolute;right:12px;top:50%;transform:translateY(-50%);background:none;border:none;cursor:pointer;color:var(--text-dim);padding:0;display:grid;place-items:center">
                        <svg id="eyeIcon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/>
                            <circle cx="12" cy="12" r="3"/>
                        </svg>
                    </button>
                </div>
                <span asp-validation-for="Password" style="font-size:11.5px;color:var(--rose);margin-top:3px"></span>
            </div>

            <button type="submit" class="login-submit-btn" id="submitBtn">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M15 3h4a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2h-4M10 17l5-5-5-5M15 12H3"/>
                </svg>
                Sign In to Dashboard
            </button>

            <div class="login-divider">Quick demo access</div>

            <div class="login-demo-box">
                <div class="login-demo-title">Select a role to pre-fill credentials</div>
                <div class="login-demo-roles">
                    <div class="login-demo-role" onclick="fillDemo('admin@lms.com','Admin')">
                        <span style="width:8px;height:8px;border-radius:50%;background:var(--navy)"></span>Admin
                    </div>
                    <div class="login-demo-role" onclick="fillDemo('coordinator@lms.com','Coordinator')">
                        <span style="width:8px;height:8px;border-radius:50%;background:var(--amber)"></span>Coordinator
                    </div>
                    <div class="login-demo-role" onclick="fillDemo('teacher1@lms.com','Teacher')">
                        <span style="width:8px;height:8px;border-radius:50%;background:var(--teal)"></span>Teacher
                    </div>
                    <div class="login-demo-role" onclick="fillDemo('examcontroller@lms.com','ExamCtrl')">
                        <span style="width:8px;height:8px;border-radius:50%;background:#7C3AED"></span>ExamController
                    </div>
                    <div class="login-demo-role" onclick="fillDemo('student1@lms.com','Student')">
                        <span style="width:8px;height:8px;border-radius:50%;background:var(--sky)"></span>Student
                    </div>
                </div>
            </div>

            <div style="text-align:center;font-size:12.5px;color:var(--text-muted)">
                Don't have an account?
                <a asp-controller="AuthMvc" asp-action="Register"
                   style="color:var(--amber);font-weight:500;text-decoration:none">Create account</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
<script>
function fillDemo(email, label) {
    document.getElementById('emailInput').value = email;
    document.getElementById('passwordInput').value = 'Password@123';
    document.querySelectorAll('.login-demo-role').forEach(el => el.classList.remove('selected'));
    event.currentTarget.classList.add('selected');
}
document.getElementById('togglePwd').addEventListener('click', function() {
    const inp = document.getElementById('passwordInput');
    inp.type = inp.type === 'password' ? 'text' : 'password';
});
document.querySelector('form').addEventListener('submit', function() {
    const btn = document.getElementById('submitBtn');
    btn.innerHTML = '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="animation:spin 0.8s linear infinite"><polyline points="23 4 23 10 17 10"/><path d="M20.49 15a9 9 0 1 1-.04-4.73"/></svg> Signing in...';
    btn.disabled = true;
});
</script>
<style>
@@keyframes spin { from{transform:rotate(0deg)} to{transform:rotate(360deg)} }
body { margin:0; padding:0; background: var(--navy-deep); }
</style>
}
