@model Learning_Management_System.Models.ForgotPasswordViewModel

@{
    ViewData["Title"] = "Forgot password";
    ViewData["HideNavBar"] = true;
    ViewData["HideFooter"] = true;
}

<div class="auth-page">
    <div class="auth-card">
        <div class="mb-4">
            <h1 class="auth-title">Forgot password?</h1>
            <div class="auth-subtitle">Enter your email and we'll send instructions to reset your password.</div>
        </div>

        @if (TempData["SuccessMessage"] != null)
        {
            <div class="alert alert-success border-0 shadow-sm mb-4">
                <i class="bi bi-check-circle-fill me-2"></i> @TempData["SuccessMessage"]
            </div>
            <div class="text-center">
                <a class="btn btn-primary w-100" asp-action="Login">Back to login</a>
            </div>
        }
        else
        {
            <form method="post" asp-action="ForgotPassword" asp-controller="AuthMvc">
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                <div class="mb-4">
                    <label class="form-label auth-label" asp-for="Email">EMAIL ADDRESS</label>
                    <input type="email" class="form-control" asp-for="Email" placeholder="name@company.com" required autofocus />
                    <span asp-validation-for="Email" class="text-danger small"></span>
                </div>

                <button type="submit" class="btn btn-primary w-100 mb-3">Send Reset Link</button>

                <div class="text-center mt-3">
                    <span class="text-muted">Remember your password? </span>
                    <a class="text-decoration-none" asp-controller="AuthMvc" asp-action="Login">Sign in</a>
                </div>
            </form>
        }
    </div>
</div>

<style>
    .auth-page {
        min-height: 100vh; /* Fixed from 100% to 100vh to ensure it centers correctly */
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 1rem 0;
    }

    .auth-card {
        width: 100%;
        max-width: 420px;
        background: #fff;
        border: 1px solid rgba(0, 0, 0, 0.08);
        border-radius: 12px;
        padding: 1.25rem;
        box-shadow: 0 10px 25px rgba(0, 0, 0, 0.06);
    }

    @@media (min-width: 768px) {
        .auth-card {
            padding: 1.75rem;
        }
    }

    .auth-title {
        font-size: 1.5rem;
        font-weight: 700;
        margin: 0;
    }

    .auth-subtitle {
        color: #6c757d;
        margin-top: 0.25rem;
    }

    .auth-label {
        font-size: 0.75rem;
        font-weight: 700;
        letter-spacing: 0.08em;
        color: #343a40;
        text-transform: uppercase;
    }

    /* Input styling to match login page exactly */
    .form-control {
        padding: 0.6rem 0.75rem;
        border: 1px solid #dee2e6;
    }

    .form-control:focus {
        box-shadow: 0 0 0 0.25rem rgba(13, 110, 253, 0.15);
    }
</style>