{
  "Logging": {
    "LogLevel": {
      "Default": "Warning",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Warning"
    }
  },
  "ConnectionStrings": {
    "DefaultConnection": "Data Source=localhost\\SQLEXPRESS;Initial Catalog=LMS_Prod;Integrated Security=True;TrustServerCertificate=True;Pooling=True;MultipleActiveResultSets=True;Command Timeout=30"
